<%- include('../../partials/header-parent') %>

<style>
    .section { background: white; border-radius: 14px; padding: 20px; margin-bottom: 20px; box-shadow: 0 1px 6px rgba(0,0,0,0.04); }
    .badge { padding: 4px 10px; border-radius: 20px; font-size: 0.72rem; font-weight: 600; }
    .badge-danger { background: #f8d7da; color: #721c24; }
    .badge-warning { background: #fff3cd; color: #856404; }
</style>

<h2 style="display:flex;align-items:center;gap:10px;margin-bottom:20px;">
    <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="#002FA7" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="4.93" y1="4.93" x2="19.07" y2="19.07"/></svg>
    Absences & Retards - <span id="enfantTitre" style="color:#888;font-size:0.9rem;"></span>
</h2>

<div id="noEnfant" style="display:none;"><div class="section"><p style="color:#888;">⚠️ Aucun enfant sélectionné. <a href="/dashboard/parent">Retour</a></p></div></div>
<div id="contentEnfant"><div id="absencesEnfant"><p style="color:#888;">Chargement...</p></div></div>

<script>
    var enfantNom = localStorage.getItem('enfantNom');
    var enfantPrenom = localStorage.getItem('enfantPrenom');
    if (!enfantNom) { document.getElementById('noEnfant').style.display = 'block'; document.getElementById('contentEnfant').style.display = 'none'; }
    else {
        document.getElementById('enfantTitre').textContent = enfantNom + ' ' + enfantPrenom + ' - ' + localStorage.getItem('enfantClasse');
        loadAbsences();
    }
    async function loadAbsences() {
        var r = await fetch('/parent/api/absences?eleve_nom=' + encodeURIComponent(enfantNom) + '&eleve_prenom=' + encodeURIComponent(enfantPrenom));
        var absences = await r.json();
        document.getElementById('absencesEnfant').innerHTML = absences.length ? '<table class="data-table"><thead><tr><th>Date</th><th>Type</th><th>Motif</th><th>Justifié</th><th>Durée</th></tr></thead><tbody>' + absences.map(function(a) {
            return '<tr><td>' + a.date_absence + '</td><td><span class="badge ' + (a.type==='absence'?'badge-danger':'badge-warning') + '">' + a.type + '</span></td><td>' + a.motif + '</td><td>' + (a.justifie?'✅':'❌') + '</td><td>' + (a.duree_minutes||0) + ' min</td></tr>';
        }).join('') + '</tbody></table>' : '<p style="color:#888;">Aucune absence</p>';
    }
</script>
<%- include('../../partials/footer-parent') %>