<%- include('../../partials/header-parent') %>

<style>
    .edt-grid { display: grid; grid-template-columns: 100px repeat(6, 1fr); gap: 2px; background: #e0e0e0; border-radius: 12px; overflow-x: auto; font-size: 0.75rem; min-width: 700px; }
    .edt-cell { background: white; padding: 6px; min-height: 60px; }
    .edt-header { background: #002FA7; color: white; font-weight: 700; text-align: center; padding: 10px 4px; font-size: 0.78rem; }
    .edt-time { background: #f8f9fa; font-weight: 600; text-align: center; display: flex; align-items: center; justify-content: center; color: #555; font-size: 0.7rem; flex-direction: column; }
    .edt-cours { background: #f0f4ff; border-left: 3px solid #002FA7; padding: 5px 6px; border-radius: 4px; margin: 2px 0; font-size: 0.68rem; }
    .badge { padding: 4px 10px; border-radius: 20px; font-size: 0.72rem; font-weight: 600; }
    .badge-info { background: #d1ecf1; color: #0c5460; }
    .section { background: white; border-radius: 14px; padding: 20px; margin-bottom: 20px; box-shadow: 0 1px 6px rgba(0,0,0,0.04); }
    @media (max-width: 768px) { .edt-grid { font-size: 0.6rem; grid-template-columns: 60px repeat(6, 1fr); min-width: 500px; } }
</style>

<h2 style="display:flex;align-items:center;gap:10px;margin-bottom:20px;">
    <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="#002FA7" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/></svg>
    Emploi du temps - <span id="enfantTitre" style="color:#888;font-size:0.9rem;"></span>
</h2>

<div id="noEnfant" style="display:none;">
    <div class="section"><p style="color:#888;">⚠️ Aucun enfant sélectionné. <a href="/dashboard/parent">Retour</a></p></div>
</div>

<div id="contentEnfant"><div id="edtEnfant"><p style="color:#888;">Chargement...</p></div></div>

<script>
    var enfantNom = localStorage.getItem('enfantNom');
    var enfantClasse = localStorage.getItem('enfantClasse');

    if (!enfantNom) {
        document.getElementById('noEnfant').style.display = 'block';
        document.getElementById('contentEnfant').style.display = 'none';
    } else {
        document.getElementById('enfantTitre').textContent = enfantNom + ' ' + localStorage.getItem('enfantPrenom') + ' - ' + enfantClasse;
        loadEDT();
    }

    async function loadEDT() {
        var r = await fetch('/parent/api/edt?classe=' + encodeURIComponent(enfantClasse));
        var edt = await r.json();
        var jours = ['Lundi','Mardi','Mercredi','Jeudi','Vendredi','Samedi'];
        var plages = [{d:'07:00',f:'08:00'},{d:'08:00',f:'09:00'},{d:'09:00',f:'10:00'},{d:'10:00',f:'11:00'},{d:'11:00',f:'12:00'},{d:'12:00',f:'13:00'},{d:'13:00',f:'14:00'},{d:'14:00',f:'15:00'},{d:'15:00',f:'16:00'},{d:'16:00',f:'17:00'},{d:'17:00',f:'18:00'}];
        var html = '<div style="overflow-x:auto;"><div class="edt-grid"><div class="edt-header">Heure</div>';
        jours.forEach(function(j) { html += '<div class="edt-header">' + j + '</div>'; });
        plages.forEach(function(p) {
            html += '<div class="edt-time"><span>' + p.d + '</span><span>' + p.f + '</span></div>';
            jours.forEach(function(j) {
                var cours = edt.filter(function(e) { return e.jour === j && e.heure_debut >= p.d + ':00' && e.heure_debut < p.f + ':00'; });
                html += '<div class="edt-cell">';
                if (cours.length > 0) {
                    cours.forEach(function(c) {
                        html += '<div class="edt-cours"><strong>' + c.matiere + '</strong><br><small>' + (c.salle||'') + ' ' + (c.prof_nom||'') + '</small></div>';
                    });
                } else { html += '<div style="display:flex;align-items:center;justify-content:center;color:#ccc;font-size:0.65rem;height:100%;">-</div>'; }
                html += '</div>';
            });
        });
        html += '</div></div>';
        document.getElementById('edtEnfant').innerHTML = edt.length ? html : '<p style="color:#888;">Aucun cours</p>';
    }
</script>

<%- include('../../partials/footer-parent') %>