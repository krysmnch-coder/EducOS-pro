<%- include('../../partials/header-parent') %>

<style>
    .section { background: white; border-radius: 14px; padding: 20px; margin-bottom: 20px; box-shadow: 0 1px 6px rgba(0,0,0,0.04); }
    .ressource-card { background: #f8f9fa; border-radius: 10px; padding: 12px; margin-bottom: 8px; }
    .badge { padding: 4px 10px; border-radius: 20px; font-size: 0.72rem; font-weight: 600; }
    .badge-info { background: #d1ecf1; color: #0c5460; }
    .badge-warning { background: #fff3cd; color: #856404; }
</style>

<h2 style="display:flex;align-items:center;gap:10px;margin-bottom:20px;">
    <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="#002FA7" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/></svg>
    Ressources - <span id="enfantTitre" style="color:#888;font-size:0.9rem;"></span>
</h2>

<div id="noEnfant" style="display:none;"><div class="section"><p style="color:#888;">⚠️ Aucun enfant sélectionné. <a href="/dashboard/parent">Retour</a></p></div></div>
<div id="contentEnfant"><div id="ressourcesEnfant"><p style="color:#888;">Chargement...</p></div></div>

<script>
    var enfantNom = localStorage.getItem('enfantNom');
    var enfantClasse = localStorage.getItem('enfantClasse');
    if (!enfantNom) { document.getElementById('noEnfant').style.display = 'block'; document.getElementById('contentEnfant').style.display = 'none'; }
    else {
        document.getElementById('enfantTitre').textContent = enfantNom + ' ' + localStorage.getItem('enfantPrenom') + ' - ' + enfantClasse;
        loadRessources();
    }
    async function loadRessources() {
        var r = await fetch('/parent/api/ressources?classe=' + encodeURIComponent(enfantClasse));
        var ressources = await r.json();
        document.getElementById('ressourcesEnfant').innerHTML = ressources.length ? ressources.map(function(rs) {
            return '<div class="ressource-card"><strong>' + rs.titre + '</strong> <span class="badge badge-info">' + rs.type + '</span><br><small>' + (rs.prof_nom||'') + ' | ' + (rs.matiere||'') + '</small>' + (rs.fichier ? ' <a href="/uploads/' + rs.fichier + '" target="_blank">📎 Télécharger</a>' : '') + (rs.date_limite ? ' <span class="badge badge-warning">Limite: ' + rs.date_limite + '</span>' : '') + '</div>';
        }).join('') : '<p style="color:#888;">Aucune ressource</p>';
    }
</script>
<%- include('../../partials/footer-parent') %>