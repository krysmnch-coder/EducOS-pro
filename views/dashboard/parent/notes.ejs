<%- include('../../partials/header-parent') %>

<style>
    .section { background: white; border-radius: 14px; padding: 20px; margin-bottom: 20px; box-shadow: 0 1px 6px rgba(0,0,0,0.04); }
    .note-card { background: #f8f9fa; border-radius: 10px; padding: 12px; text-align: center; }
    .note-card .note-value { font-size: 1.5rem; font-weight: 700; color: #002FA7; }
    .note-card .note-label { font-size: 0.72rem; color: #888; }
    .notes-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(140px, 1fr)); gap: 10px; }
    .badge { padding: 4px 10px; border-radius: 20px; font-size: 0.72rem; font-weight: 600; }
    .badge-info { background: #d1ecf1; color: #0c5460; }
</style>

<h2 style="display:flex;align-items:center;gap:10px;margin-bottom:20px;">
    <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="#002FA7" stroke-width="2"><path d="M9 11l3 3L22 4"/></svg>
    Notes - <span id="enfantTitre" style="color:#888;font-size:0.9rem;"></span>
</h2>

<div id="noEnfant" style="display:none;">
    <div class="section">
        <p style="color:#888;">⚠️ Aucun enfant sélectionné. <a href="/dashboard/parent">Retour au tableau de bord</a></p>
    </div>
</div>

<div id="contentEnfant">
    <div class="section">
        <h3>📝 Notes par matière</h3>
        <div id="notesEnfant"><p style="color:#888;">Chargement...</p></div>
    </div>
</div>

<script>
    var enfantNom = localStorage.getItem('enfantNom');
    var enfantPrenom = localStorage.getItem('enfantPrenom');
    var enfantClasse = localStorage.getItem('enfantClasse');

    if (!enfantNom) {
        document.getElementById('noEnfant').style.display = 'block';
        document.getElementById('contentEnfant').style.display = 'none';
    } else {
        document.getElementById('enfantTitre').textContent = enfantNom + ' ' + enfantPrenom + ' - ' + enfantClasse;
        loadNotes();
    }

    async function loadNotes() {
        var r = await fetch('/parent/api/notes?eleve_nom=' + encodeURIComponent(enfantNom) + '&eleve_prenom=' + encodeURIComponent(enfantPrenom));
        var notes = await r.json();
        document.getElementById('notesEnfant').innerHTML = notes.length ? '<div class="notes-grid">' + notes.map(function(n) {
            return '<div class="note-card"><div class="note-value">' + n.moyenne.toFixed(2) + '/20</div><div class="note-label">' + n.matiere + '</div><small style="font-size:0.65rem;color:#888;">NJ1:' + n.nj1 + ' NJ2:' + n.nj2 + ' Ex:' + n.examen + '</small></div>';
        }).join('') + '</div>' : '<p style="color:#888;">Aucune note disponible</p>';
    }
</script>

<%- include('../../partials/footer-parent') %>