<%- include('../../partials/header-admin') %>

<style>
    .section { background: white; border-radius: 14px; padding: 24px; margin-bottom: 20px; box-shadow: 0 1px 6px rgba(0,0,0,0.04); }
    .section h3 { font-size: 1rem; font-weight: 700; margin-bottom: 16px; display: flex; align-items: center; gap: 8px; }
    .form-group { margin-bottom: 18px; }
    .form-group label { display: block; margin-bottom: 6px; font-weight: 600; font-size: 0.85rem; color: #333; }
    .form-control { width: 100%; padding: 10px 14px; border: 2px solid #e0e0e0; border-radius: 8px; font-size: 0.88rem; font-family: 'Inter', sans-serif; }
    .form-control:focus { border-color: #002FA7; outline: none; }
    .form-row { display: flex; gap: 16px; }
    .form-row .form-group { flex: 1; }
    .btn { padding: 12px 24px; border: none; border-radius: 8px; cursor: pointer; font-size: 0.9rem; font-weight: 600; display: inline-flex; align-items: center; gap: 8px; font-family: 'Inter', sans-serif; transition: all 0.2s; }
    .btn-primary { background: #002FA7; color: white; }
    .btn-primary:hover { background: #003fd6; }
    .btn svg { width: 16px; height: 16px; stroke: currentColor; }
    .btn-primary svg { stroke: white; }
    .info-banner { background: #f0f4ff; border: 1px solid #d0d8ff; border-radius: 10px; padding: 14px 18px; margin-bottom: 20px; font-size: 0.85rem; color: #002FA7; display: flex; align-items: center; gap: 10px; }
    .toast { position: fixed; top: 20px; right: 20px; padding: 14px 20px; border-radius: 10px; color: white; font-weight: 600; z-index: 3000; display: none; white-space: pre-wrap; max-width: 450px; }
    .toast.success { background: #27ae60; }
    .toast.error { background: #e74c3c; }
    @media (max-width: 768px) { .form-row { flex-direction: column; } }
</style>

<h2 style="display:flex;align-items:center;gap:10px;margin-bottom:20px;">
    <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="#002FA7" stroke-width="2"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
    Établissement
</h2>

<div class="info-banner">
    <svg viewBox="0 0 24 24" fill="none" stroke="#002FA7" stroke-width="2" width="20" height="20"><circle cx="12" cy="12" r="10"/><line x1="12" y1="16" x2="12" y2="12"/><line x1="12" y1="8" x2="12.01" y2="8"/></svg>
    <span>Remplissez les informations de votre établissement. Une base de données dédiée sera créée automatiquement.</span>
</div>

<div class="section">
    <form id="etablissementForm" onsubmit="return false;">
        <div class="form-group">
            <label>Nom de l'établissement *</label>
            <input type="text" id="nom" class="form-control" required placeholder="Ex: Collège Jean Dupont">
        </div>
        <div class="form-group">
            <label>Code établissement</label>
            <input type="text" id="code" class="form-control" disabled placeholder="Généré automatiquement">
        </div>
        <div class="form-group">
            <label>Adresse</label>
            <input type="text" id="adresse" class="form-control" placeholder="Ex: 123 Rue de l'École">
        </div>
        <div class="form-row">
            <div class="form-group">
                <label>Téléphone</label>
                <input type="text" id="telephone" class="form-control" placeholder="+261 20 22 333 44">
            </div>
            <div class="form-group">
                <label>Email</label>
                <input type="email" id="email_etab" class="form-control" placeholder="contact@ecole.mg">
            </div>
        </div>
        <div class="form-group">
            <label>Site web</label>
            <input type="text" id="site_web" class="form-control" placeholder="www.mon-ecole.mg">
        </div>
        <div class="form-group">
            <label>Directeur / Principal</label>
            <input type="text" id="directeur" class="form-control" placeholder="M. Rakoto Jean">
        </div>
        <div class="form-group">
            <label>Année scolaire</label>
            <input type="text" id="annee_scolaire" class="form-control" placeholder="2024-2025">
        </div>
        <button type="button" class="btn btn-primary" onclick="enregistrerEtablissement()">
            <svg viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2"><path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"/><polyline points="17 21 17 13 7 13 7 21"/></svg>
            Enregistrer l'établissement
        </button>
    </form>
</div>

<div class="toast" id="toast"></div>

<script>
    // Charger les données existantes
    fetch('/admin/api/etablissement')
        .then(function(r) { return r.json(); })
        .then(function(d) {
            if (d && d.nom) {
                document.getElementById('nom').value = d.nom || '';
                document.getElementById('code').value = d.code || '';
                document.getElementById('adresse').value = d.adresse || '';
                document.getElementById('telephone').value = d.telephone || '';
                document.getElementById('email_etab').value = d.email || '';
                document.getElementById('site_web').value = d.site_web || '';
                document.getElementById('directeur').value = d.directeur || '';
                document.getElementById('annee_scolaire').value = d.annee_scolaire || '';
            }
        })
        .catch(function(err) {
            console.log('Aucun établissement existant');
        });

    async function enregistrerEtablissement() {
        var nom = document.getElementById('nom').value.trim();
        if (!nom) {
            showToast('❌ Le nom de l\'établissement est obligatoire', 'error');
            return;
        }

        var data = {
            nom: nom,
            adresse: document.getElementById('adresse').value.trim(),
            telephone: document.getElementById('telephone').value.trim(),
            email: document.getElementById('email_etab').value.trim(),
            site_web: document.getElementById('site_web').value.trim(),
            directeur: document.getElementById('directeur').value.trim(),
            annee_scolaire: document.getElementById('annee_scolaire').value.trim()
        };

        showToast('⏳ Enregistrement en cours...', 'success');

        try {
            var r = await fetch('/admin/api/etablissement', {
                method: 'PUT',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(data)
            });
            var j = await r.json();
            
            if (j.success) {
                document.getElementById('code').value = j.code || '';
                showToast(j.message, 'success');
            } else {
                showToast('❌ ' + (j.error || 'Erreur inconnue'), 'error');
            }
        } catch(e) {
            showToast('❌ Erreur réseau : ' + e.message, 'error');
        }
    }

    function showToast(msg, type) {
        var t = document.getElementById('toast');
        t.textContent = msg;
        t.className = 'toast ' + (type || 'success');
        t.style.display = 'block';
        setTimeout(function() { t.style.display = 'none'; }, 6000);
    }
</script>

<%- include('../../partials/footer-admin') %>