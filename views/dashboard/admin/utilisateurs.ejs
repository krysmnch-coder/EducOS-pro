<%- include('../../partials/header-admin') %>

<style>
    .btn { padding: 8px 16px; border: none; border-radius: 8px; cursor: pointer; font-size: 0.85rem; font-weight: 600; display: inline-flex; align-items: center; gap: 6px; transition: all 0.2s; font-family: 'Inter', sans-serif; }
    .btn-primary { background: #002FA7; color: white; }
    .btn-primary:hover { background: #003fd6; }
    .btn-danger { background: #e74c3c; color: white; }
    .btn-danger:hover { background: #c0392b; }
    .btn-warning { background: #f39c12; color: white; }
    .btn-success { background: #27ae60; color: white; }
    .btn-info { background: #6366f1; color: white; }
    .btn-sm { padding: 6px 10px; font-size: 0.73rem; }
    .btn svg { width: 14px; height: 14px; stroke: currentColor; }
    .btn-primary svg, .btn-danger svg, .btn-success svg, .btn-info svg { stroke: white; }
    .modal { display: none; position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0,0,0,0.5); z-index: 2000; align-items: center; justify-content: center; padding: 20px; }
    .modal.active { display: flex; }
    .modal-content { background: white; border-radius: 16px; padding: 24px; width: 100%; max-width: 500px; max-height: 80vh; overflow-y: auto; }
    .modal-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px; }
    .close-modal { background: none; border: none; font-size: 1.4rem; cursor: pointer; color: #666; }
    .form-group { margin-bottom: 14px; }
    .form-group label { display: block; margin-bottom: 5px; font-weight: 600; font-size: 0.85rem; color: #333; }
    .form-control { width: 100%; padding: 10px 12px; border: 2px solid #e0e0e0; border-radius: 8px; font-size: 0.88rem; font-family: 'Inter', sans-serif; }
    .form-control:focus { border-color: #002FA7; outline: none; }
    .form-row { display: flex; gap: 12px; }
    .form-row .form-group { flex: 1; }
    .badge { padding: 4px 10px; border-radius: 20px; font-size: 0.72rem; font-weight: 600; }
    .badge-success { background: #d4edda; color: #155724; }
    .badge-danger { background: #f8d7da; color: #721c24; }
    .search-bar { display: flex; gap: 10px; margin-bottom: 16px; flex-wrap: wrap; align-items: center; }
    .search-wrapper { position: relative; flex: 1; min-width: 180px; }
    .search-icon-svg { position: absolute; left: 12px; top: 50%; transform: translateY(-50%); width: 16px; height: 16px; stroke: #999; pointer-events: none; }
    .search-wrapper input { padding: 10px 12px 10px 36px !important; border: 2px solid #e0e0e0; border-radius: 8px; font-size: 0.88rem; font-family: 'Inter', sans-serif; width: 100%; }
    .search-wrapper input:focus { border-color: #002FA7; outline: none; }
    .search-bar select { padding: 10px 12px; border: 2px solid #e0e0e0; border-radius: 8px; font-size: 0.88rem; font-family: 'Inter', sans-serif; }
    .pagination { display: flex; gap: 6px; justify-content: center; margin-top: 16px; }
    .pagination button { padding: 7px 12px; border: 1px solid #e0e0e0; background: white; border-radius: 6px; cursor: pointer; font-family: 'Inter', sans-serif; }
    .pagination button.active { background: #002FA7; color: white; border-color: #002FA7; }
    .toast { position: fixed; top: 20px; right: 20px; padding: 14px 20px; border-radius: 10px; color: white; font-weight: 600; z-index: 3000; display: none; }
    .toast.success { background: #27ae60; }
    .toast.error { background: #e74c3c; }
    .table-actions { display: flex; gap: 6px; }
</style>

<div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:24px;flex-wrap:wrap;gap:10px;">
    <h2 style="display:flex;align-items:center;gap:10px;">
        <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="#002FA7" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
        Gestion des utilisateurs
    </h2>
    <button class="btn btn-primary" onclick="openCreateModal()">
        <svg viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
        Ajouter
    </button>
</div>

<div class="section">
    <div class="search-bar">
        <div class="search-wrapper">
            <svg class="search-icon-svg" viewBox="0 0 24 24" fill="none" stroke="#999" stroke-width="2"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
            <input type="text" id="searchInput" placeholder="Rechercher..." onkeyup="loadUsers()">
        </div>
        <select id="roleFilter" onchange="loadUsers()">
            <option value="">Tous les rôles</option>
            <option value="admin">Administrateur</option>
            <option value="vie_scolaire">Vie Scolaire</option>
            <option value="prof">Professeur</option>
            <option value="parent">Parent</option>
            <option value="eleve">Élève</option>
        </select>
    </div>
    <div class="table-container">
        <table class="data-table">
            <thead><tr><th>ID</th><th>Utilisateur</th><th>Email</th><th>Rôle</th><th>Statut</th><th>Créé le</th><th>Actions</th></tr></thead>
            <tbody id="usersTableBody"><tr><td colspan="7">Chargement...</td></tr></tbody>
        </table>
    </div>
    <div class="pagination" id="pagination"></div>
</div>

<div class="modal" id="userModal">
    <div class="modal-content">
        <div class="modal-header">
            <h3 id="modalTitle">Ajouter un utilisateur</h3>
            <button class="close-modal" onclick="closeModal()">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="20" height="20"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
            </button>
        </div>
        <form id="userForm" onsubmit="saveUser(event)">
            <input type="hidden" id="userId">
            <div class="form-row">
                <div class="form-group"><label>Nom *</label><input type="text" id="userNom" class="form-control" required></div>
                <div class="form-group"><label>Prénom *</label><input type="text" id="userPrenom" class="form-control" required></div>
            </div>
            <div class="form-group"><label>Email *</label><input type="email" id="userEmail" class="form-control" required></div>
            <div class="form-group">
                <label>Rôle *</label>
                <select id="userRole" class="form-control" required>
                    <option value="">Sélectionner</option>
                    <option value="admin">Administrateur</option>
                    <option value="vie_scolaire">Vie Scolaire</option>
                    <option value="prof">Professeur</option>
                    <option value="parent">Parent</option>
                    <option value="eleve">Élève</option>
                </select>
            </div>
            <div class="form-group" id="passwordGroup"><label>Mot de passe *</label><input type="password" id="userPassword" class="form-control" minlength="8"></div>
            <button type="submit" class="btn btn-primary" style="width:100%;">
                <svg viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2"><path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"/><polyline points="17 21 17 13 7 13 7 21"/></svg>
                Enregistrer
            </button>
        </form>
    </div>
</div>

<div class="toast" id="toast"></div>

<script>
    let currentPage = 1, editingUserId = null;
    async function loadUsers(page = 1) {
        currentPage = page;
        const search = document.getElementById('searchInput').value, role = document.getElementById('roleFilter').value;
        const res = await fetch(`/admin/api/users?page=${page}&search=${encodeURIComponent(search)}&role=${encodeURIComponent(role)}`);
        const data = await res.json();
        const tbody = document.getElementById('usersTableBody');
        if (!data.users?.length) { tbody.innerHTML = '<tr><td colspan="7">Aucun</td></tr>'; return; }
        tbody.innerHTML = data.users.map(u => `
            <tr><td>#${u.id}</td><td><strong>${u.nom} ${u.prenom}</strong></td><td>${u.email}</td><td>${u.role}</td>
            <td><span class="badge ${u.compte_actif?'badge-success':'badge-danger'}">${u.compte_actif?'Actif':'Inactif'}</span></td>
            <td>${new Date(u.created_at).toLocaleDateString('fr-FR')}</td>
            <td><div class="table-actions">
                <button class="btn btn-warning btn-sm" onclick="editUser(${u.id})"><svg viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg></button>
                <button class="btn btn-info btn-sm" onclick="resetPassword(${u.id})"><svg viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg></button>
                <button class="btn btn-sm ${u.compte_actif?'btn-danger':'btn-success'}" onclick="toggleStatus(${u.id})"><svg viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2">${u.compte_actif?'<circle cx="12" cy="12" r="10"/><line x1="4.93" y1="4.93" x2="19.07" y2="19.07"/>':'<circle cx="12" cy="12" r="10"/><polyline points="9 12 11 14 15 10"/>'}</svg></button>
                <button class="btn btn-danger btn-sm" onclick="deleteUser(${u.id},'${u.nom} ${u.prenom}')"><svg viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2"><polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/></svg></button>
            </div></td></tr>`).join('');
        let pag = '';
        for(let i=1; i<=data.pagination.totalPages; i++) pag += `<button class="${i===page?'active':''}" onclick="loadUsers(${i})">${i}</button>`;
        document.getElementById('pagination').innerHTML = pag;
    }
    function openCreateModal() {
        editingUserId = null;
        document.getElementById('modalTitle').textContent = 'Ajouter un utilisateur';
        document.getElementById('userForm').reset();
        document.getElementById('passwordGroup').style.display = 'block';
        document.getElementById('userPassword').required = true;
        document.getElementById('userModal').classList.add('active');
    }
    async function editUser(id) {
        const res = await fetch('/admin/api/users?page=1&search=&role=');
        const data = await res.json();
        const u = data.users.find(x => x.id === id);
        if(!u) return;
        editingUserId = id;
        document.getElementById('modalTitle').textContent = 'Modifier';
        document.getElementById('userId').value = u.id;
        document.getElementById('userNom').value = u.nom;
        document.getElementById('userPrenom').value = u.prenom;
        document.getElementById('userEmail').value = u.email;
        document.getElementById('userRole').value = u.role;
        document.getElementById('passwordGroup').style.display = 'none';
        document.getElementById('userPassword').required = false;
        document.getElementById('userModal').classList.add('active');
    }
    async function saveUser(e) {
        e.preventDefault();
        const data = {nom:document.getElementById('userNom').value, prenom:document.getElementById('userPrenom').value, email:document.getElementById('userEmail').value, role:document.getElementById('userRole').value};
        if(!editingUserId) data.password = document.getElementById('userPassword').value;
        const url = editingUserId ? `/admin/api/users/${editingUserId}` : '/admin/api/users';
        const res = await fetch(url, {method:editingUserId?'PUT':'POST', headers:{'Content-Type':'application/json'}, body:JSON.stringify(data)});
        const j = await res.json();
        showToast(j.message||j.error, res.ok?'success':'error');
        if(res.ok) { closeModal(); loadUsers(); }
    }
    async function resetPassword(id) { if(!confirm('Réinitialiser ?')) return; const res = await fetch(`/admin/api/users/${id}/reset-password`, {method:'POST'}); const j = await res.json(); showToast(j.tempPassword ? `MDP: ${j.tempPassword}` : j.error, j.success?'success':'error'); }
    async function toggleStatus(id) { await fetch(`/admin/api/users/${id}/toggle-status`, {method:'PUT'}); loadUsers(); }
    async function deleteUser(id, name) { if(!confirm(`Supprimer ${name} ?`)) return; await fetch(`/admin/api/users/${id}`, {method:'DELETE'}); loadUsers(); }
    function closeModal() { document.getElementById('userModal').classList.remove('active'); }
    function showToast(msg, type) { const t = document.getElementById('toast'); t.textContent = msg; t.className = `toast ${type}`; t.style.display = 'block'; setTimeout(() => t.style.display = 'none', 3000); }
    document.getElementById('userModal').addEventListener('click', function(e) { if(e.target===this) closeModal(); });
    loadUsers();
</script>

<%- include('../../partials/footer-admin') %>