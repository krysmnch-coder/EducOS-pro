<%- include('../../partials/header-admin') %>

<style>
    .messages-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; }
    .msg-card { background: white; border-radius: 14px; padding: 20px; box-shadow: 0 1px 6px rgba(0,0,0,0.04); }
    .msg-item { padding: 12px 14px; border: 1px solid #e8e8e8; border-radius: 10px; margin-bottom: 8px; cursor: pointer; }
    .msg-item:hover { background: #fafafa; }
    .msg-item.non-lu { border-left: 3px solid #002FA7; background: #f8f9ff; }
    .btn { padding: 10px 18px; border: none; border-radius: 8px; cursor: pointer; font-size: 0.85rem; font-weight: 600; display: inline-flex; align-items: center; gap: 8px; font-family: 'Inter', sans-serif; }
    .btn-primary { background: #002FA7; color: white; }
    .btn-primary:hover { background: #003fd6; }
    .btn svg { width: 16px; height: 16px; }
    .btn-primary svg { stroke: white; }
    .form-group { margin-bottom: 14px; }
    .form-group label { display: block; margin-bottom: 5px; font-weight: 600; font-size: 0.85rem; color: #333; }
    .form-control { width: 100%; padding: 10px 12px; border: 2px solid #e0e0e0; border-radius: 8px; font-size: 0.88rem; font-family: 'Inter', sans-serif; }
    .form-control:focus { border-color: #002FA7; outline: none; }
    textarea.form-control { resize: vertical; min-height: 80px; }
    .file-upload-label { display: inline-flex; align-items: center; gap: 6px; padding: 8px 16px; background: #f0f4ff; border: 2px dashed #002FA7; border-radius: 8px; cursor: pointer; font-size: 0.85rem; color: #002FA7; font-weight: 500; }
    .file-name { font-size: 0.8rem; color: #27ae60; margin-top: 4px; }
    .toast { position: fixed; top: 20px; right: 20px; padding: 14px 20px; border-radius: 10px; color: white; font-weight: 600; z-index: 3000; display: none; }
    .toast.success { background: #27ae60; }
    .toast.error { background: #e74c3c; }
    @media (max-width: 768px) { .messages-grid { grid-template-columns: 1fr; } }
</style>

<h2 style="display:flex;align-items:center;gap:10px;margin-bottom:24px;">
    <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="#002FA7" stroke-width="2"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
    Messagerie
</h2>

<div class="messages-grid">
    <div class="msg-card">
        <h3 style="display:flex;align-items:center;gap:8px;margin-bottom:16px;">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#002FA7" stroke-width="2"><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg>
            Nouveau message
        </h3>
        <form id="msgForm" onsubmit="return false;">
            <div class="form-group">
                <label>Destinataire</label>
                <select id="msgDest" class="form-control" onchange="toggleDest()">
                    <option value="all">Tout le monde</option>
                    <option value="role">Par rôle</option>
                    <option value="user">Personne spécifique</option>
                </select>
            </div>
            <div class="form-group" id="msgRoleGrp" style="display:none;">
                <label>Rôle</label>
                <select id="msgRole" class="form-control">
                    <option value="admin">Admin</option><option value="vie_scolaire">Vie Scolaire</option><option value="prof">Professeur</option><option value="parent">Parent</option><option value="eleve">Élève</option>
                </select>
            </div>
            <div class="form-group" id="msgUserGrp" style="display:none;">
                <label>Utilisateur</label>
                <select id="msgUserId" class="form-control"></select>
            </div>
            <div class="form-group"><label>Sujet *</label><input type="text" id="msgSujet" class="form-control" required></div>
            <div class="form-group"><label>Message *</label><textarea id="msgContenu" class="form-control" rows="4" required></textarea></div>
            <div class="form-group">
                <label>Pièce jointe</label>
                <div>
                    <label class="file-upload-label" for="msgFichier">
                        <svg viewBox="0 0 24 24" fill="none" stroke="#002FA7" stroke-width="2" width="16" height="16"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
                        Choisir un fichier
                    </label>
                    <input type="file" id="msgFichier" style="display:none;" onchange="showFileName()">
                </div>
                <div class="file-name" id="fileName"></div>
            </div>
            <button type="button" class="btn btn-primary" style="width:100%;" onclick="sendMessage()">
                <svg viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2"><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg>
                Envoyer
            </button>
        </form>
    </div>
    <div class="msg-card">
        <h3 style="display:flex;align-items:center;gap:8px;margin-bottom:16px;">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#002FA7" stroke-width="2"><path d="M22 12h-6l-3 9-3-18-3 9H2"/></svg>
            Messages reçus
        </h3>
        <div id="messagesList" style="max-height:450px;overflow-y:auto;"><p style="text-align:center;color:#888;">Chargement...</p></div>
    </div>
</div>

<div class="toast" id="toast"></div>

<script>
    function toggleDest() {
        var t = document.getElementById('msgDest').value;
        document.getElementById('msgRoleGrp').style.display = t==='role'?'block':'none';
        document.getElementById('msgUserGrp').style.display = t==='user'?'block':'none';
    }
    
    function showFileName() {
        var file = document.getElementById('msgFichier').files[0];
        document.getElementById('fileName').textContent = file ? '📎 ' + file.name : '';
    }

    async function loadMessages() {
        try {
            var r = await fetch('/admin/api/messages');
            var msgs = await r.json();
            document.getElementById('messagesList').innerHTML = msgs.length ? msgs.map(function(m) {
                var fichierIcon = m.fichier ? ' 📎' : '';
                return '<div class="msg-item ' + (m.lu?'':'non-lu') + '" onclick="openMessageDetail(' + m.id + ')">' +
                    '<div style="display:flex;align-items:center;gap:8px;margin-bottom:4px;">' +
                    '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="' + (m.lu?'#888':'#002FA7') + '" stroke-width="2"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>' +
                    '<strong>' + m.sujet + '</strong>' + fichierIcon + '</div>' +
                    '<div style="font-size:0.78rem;color:#888;margin-left:22px;">De: ' + m.exp_nom + ' ' + m.exp_prenom + ' • ' + new Date(m.created_at).toLocaleString('fr-FR') + '</div>' +
                    '<div style="font-size:0.85rem;margin-top:6px;margin-left:22px;">' + m.contenu.substring(0, 120) + '</div>' +
                    '</div>';
            }).join('') : '<p style="text-align:center;color:#888;">Aucun message</p>';
        } catch(e) { console.error(e); }
    }

    async function openMessageDetail(id) {
        try {
            var r = await fetch('/admin/api/messages/' + id);
            var msg = await r.json();
            document.getElementById('modalMessageSujet').textContent = msg.sujet || '';
            document.getElementById('modalMessageFrom').textContent = 'De: ' + (msg.exp_nom||'') + ' ' + (msg.exp_prenom||'');
            document.getElementById('modalMessageContenu').textContent = msg.contenu || '';
            document.getElementById('modalMessageDate').textContent = new Date(msg.created_at).toLocaleString('fr-FR');
            if (msg.fichier) {
                document.getElementById('modalMessageFichier').innerHTML = '<a href="/uploads/' + msg.fichier + '" target="_blank" style="color:#002FA7;">📎 Télécharger ' + msg.fichier + '</a>';
                document.getElementById('modalMessageFichier').style.display = 'block';
            } else {
                document.getElementById('modalMessageFichier').style.display = 'none';
            }
            document.getElementById('messageModal').classList.add('active');
        } catch(e) {}
    }

    async function loadUsers() {
        try {
            var r = await fetch('/admin/api/users-list');
            var u = await r.json();
            document.getElementById('msgUserId').innerHTML = u.map(function(x) { return '<option value="' + x.id + '">' + x.nom + ' ' + x.prenom + ' (' + x.role + ')</option>'; }).join('');
        } catch(e) {}
    }

    async function sendMessage() {
        var sujet = document.getElementById('msgSujet').value.trim();
        var contenu = document.getElementById('msgContenu').value.trim();
        
        if (!sujet || !contenu) {
            showToast('Sujet et contenu requis', 'error');
            return;
        }

        var formData = new FormData();
        formData.append('sujet', sujet);
        formData.append('contenu', contenu);
        
        var type = document.getElementById('msgDest').value;
        if (type === 'role') formData.append('destinataire_role', document.getElementById('msgRole').value);
        else if (type === 'user') formData.append('destinataire_id', document.getElementById('msgUserId').value);
        else formData.append('destinataire_role', 'all');
        
        var fichier = document.getElementById('msgFichier').files[0];
        if (fichier) formData.append('fichier', fichier);
        
        try {
            var r = await fetch('/admin/api/messages', { method: 'POST', body: formData });
            var j = await r.json();
            showToast(j.message || j.error, r.ok ? 'success' : 'error');
            if (r.ok) {
                document.getElementById('msgSujet').value = '';
                document.getElementById('msgContenu').value = '';
                document.getElementById('msgFichier').value = '';
                document.getElementById('fileName').textContent = '';
                loadMessages();
            }
        } catch(e) {
            showToast('Erreur réseau', 'error');
        }
    }

    function showToast(msg, type) {
        var t = document.getElementById('toast');
        t.textContent = msg; t.className = 'toast ' + type; t.style.display = 'block';
        setTimeout(function() { t.style.display = 'none'; }, 3000);
    }

    loadMessages();
    loadUsers();
</script>

<%- include('../../partials/footer-admin') %>