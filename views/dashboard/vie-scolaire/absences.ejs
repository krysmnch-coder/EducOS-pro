<%- include('../../partials/header-vs') %>
<h2 style="display:flex;align-items:center;gap:10px;margin-bottom:20px;">
    <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="#002FA7" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="4.93" y1="4.93" x2="19.07" y2="19.07"/></svg>
    Absences & Retards
</h2>
<div style="display:flex;justify-content:space-between;margin-bottom:16px;"><h3>Gestion</h3><button class="btn btn-primary" onclick="openModal('absenceModal')">+ Signaler</button></div>
<div class="search-bar">
    <div class="search-wrapper" style="flex:1;min-width:180px;position:relative;">
        <svg class="search-icon-svg" viewBox="0 0 24 24" fill="none" stroke="#999" stroke-width="2"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
        <input type="text" id="searchAbsence" placeholder="Rechercher..." onkeyup="loadAbsences()" class="form-control" style="padding-left:36px;">
    </div>
    <select id="filtreTypeAbsence" onchange="loadAbsences()" class="form-control" style="width:auto;"><option value="">Tous</option><option value="absence">Absence</option><option value="retard">Retard</option></select>
</div>
<div class="table-container"><table class="data-table"><thead><tr><th>Date</th><th>Élève</th><th>Type</th><th>Motif</th><th>Justifié</th><th>Action</th></tr></thead><tbody id="absencesBody"></tbody></table></div>
<div class="pagination" id="paginationAbsences"></div>

<div class="modal" id="absenceModal"><div class="modal-content"><div class="modal-header"><h3>Signaler</h3><button class="close-modal" onclick="closeModal('absenceModal')">✕</button></div>
<form onsubmit="saveAbsence(event)"><div class="form-group"><label>Élève</label><select id="absEleveId" class="form-control" required></select></div>
<div class="form-row"><div class="form-group"><label>Type</label><select id="absType" class="form-control"><option value="absence">Absence</option><option value="retard">Retard</option></select></div><div class="form-group"><label>Date</label><input type="date" id="absDate" class="form-control" required></div></div>
<div class="form-row"><div class="form-group"><label>Motif</label><input type="text" id="absMotif" class="form-control"></div><div class="form-group"><label>Durée (min)</label><input type="number" id="absDuree" class="form-control" value="0"></div></div>
<div class="form-group"><label><input type="checkbox" id="absJustifie"> Justifié</label></div>
<button class="btn btn-primary" style="width:100%;">Enregistrer</button></form></div></div>
<div class="toast" id="toast"></div>

<script>
    async function loadAbsences(p=1) {
        var params = new URLSearchParams({page:p, type:document.getElementById('filtreTypeAbsence').value, search:document.getElementById('searchAbsence').value});
        var r = await fetch('/vie-scolaire/api/absences?'+params);
        var d = await r.json();
        document.getElementById('absencesBody').innerHTML = d.absences?.length ? d.absences.map(a => `<tr><td>${a.date_absence}</td><td>${a.nom} ${a.prenom}</td><td>${a.type}</td><td>${a.motif}</td><td>${a.justifie?'✅':'❌'}</td><td><button class="btn btn-sm btn-danger" onclick="deleteAbsence(${a.id})">🗑️</button></td></tr>`).join('') : '<tr><td colspan="6">Aucune</td></tr>';
        var pag = ''; for(var i=1; i<=d.pagination.totalPages; i++) pag += '<button class="'+(i===p?'active':'')+'" onclick="loadAbsences('+i+')">'+i+'</button>';
        document.getElementById('paginationAbsences').innerHTML = pag;
    }
    async function saveAbsence(e) {
        e.preventDefault();
        var data = {eleve_id:document.getElementById('absEleveId').value, date_absence:document.getElementById('absDate').value, type:document.getElementById('absType').value, motif:document.getElementById('absMotif').value, justifie:document.getElementById('absJustifie').checked?1:0, duree_minutes:document.getElementById('absDuree').value};
        var r = await fetch('/vie-scolaire/api/absences', {method:'POST', headers:{'Content-Type':'application/json'}, body:JSON.stringify(data)});
        var j = await r.json();
        showToast(j.message||j.error, r.ok?'success':'error');
        if(r.ok) { closeModal('absenceModal'); loadAbsences(); }
    }
    async function deleteAbsence(id) { if(!confirm('Supprimer ?')) return; await fetch('/vie-scolaire/api/absences/'+id, {method:'DELETE'}); loadAbsences(); }
    function openModal(id) { document.getElementById(id).classList.add('active'); }
    function closeModal(id) { document.getElementById(id).classList.remove('active'); }
    function showToast(msg, type) { var t = document.getElementById('toast'); t.textContent = msg; t.className = 'toast '+type; t.style.display = 'block'; setTimeout(function() { t.style.display = 'none'; }, 3000); }
    document.getElementById('absDate').value = new Date().toISOString().split('T')[0];
    fetch('/vie-scolaire/api/eleves').then(r=>r.json()).then(e => { document.getElementById('absEleveId').innerHTML = e.map(x=>'<option value="'+x.id+'">'+x.nom+' '+x.prenom+'</option>').join(''); });
    loadAbsences();
</script>
<%- include('../../partials/footer-vs') %>