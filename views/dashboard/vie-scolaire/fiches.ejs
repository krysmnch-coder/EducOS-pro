<%- include('../../partials/header-vs') %>

<style>
    .section { background: white; border-radius: 14px; padding: 20px; margin-bottom: 20px; box-shadow: 0 1px 6px rgba(0,0,0,0.04); }
    .section h3 { font-size: 1rem; font-weight: 700; margin-bottom: 16px; display: flex; align-items: center; gap: 8px; }
    .fiche-card { background: #f8f9fa; border-radius: 10px; padding: 16px; margin-bottom: 12px; cursor: pointer; border: 2px solid transparent; transition: all 0.2s; }
    .fiche-card:hover { border-color: #002FA7; background: #f0f4ff; }
    .fiche-card .header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 8px; }
    .badge { padding: 4px 10px; border-radius: 20px; font-size: 0.7rem; font-weight: 600; }
    .badge-info { background: #d1ecf1; color: #0c5460; }
    .badge-warning { background: #fff3cd; color: #856404; }
    .badge-danger { background: #f8d7da; color: #721c24; }
    .badge-success { background: #d4edda; color: #155724; }
    .search-bar { display: flex; gap: 10px; margin-bottom: 16px; flex-wrap: wrap; }
    .search-bar input { padding: 10px 12px; border: 2px solid #e0e0e0; border-radius: 8px; font-size: 0.88rem; flex: 1; min-width: 200px; font-family: 'Inter', sans-serif; }
    .modal { display: none; position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0,0,0,0.5); z-index: 2000; align-items: center; justify-content: center; padding: 20px; }
    .modal.active { display: flex; }
    .modal-content { background: white; border-radius: 16px; padding: 24px; width: 100%; max-width: 700px; max-height: 85vh; overflow-y: auto; }
    .modal-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px; }
    .close-modal { background: none; border: none; cursor: pointer; font-size: 1.5rem; }
    .detail-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 8px; }
    .detail-item { padding: 8px 0; border-bottom: 1px solid #f0f0f0; }
    .detail-item .label { font-size: 0.7rem; color: #888; text-transform: uppercase; }
    .detail-item .value { font-weight: 600; font-size: 0.9rem; }
    @media (max-width: 768px) { .detail-grid { grid-template-columns: 1fr; } }
</style>

<h2 style="display:flex;align-items:center;gap:10px;margin-bottom:20px;">
    <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="#002FA7" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
    Fiches élèves
</h2>

<div class="search-bar">
    <input type="text" id="searchFiche" placeholder="🔍 Rechercher par nom ou prénom..." onkeyup="loadFiches()">
</div>

<div id="fichesList"><p style="color:#888;text-align:center;padding:30px;">Chargement...</p></div>

<!-- Modal détail fiche -->
<div class="modal" id="ficheModal">
    <div class="modal-content">
        <div class="modal-header">
            <h3 id="ficheModalTitre"></h3>
            <button class="close-modal" onclick="closeModal()">✕</button>
        </div>
        <div id="ficheDetail"></div>
    </div>
</div>

<script>
    async function loadFiches() {
        var search = document.getElementById('searchFiche').value.toLowerCase();
        var r = await fetch('/vie-scolaire/api/fiches-eleves');
        var fiches = await r.json();
        
        if (search) {
            fiches = fiches.filter(function(f) {
                return (f.nom || '').toLowerCase().includes(search) || (f.prenom || '').toLowerCase().includes(search);
            });
        }
        
        document.getElementById('fichesList').innerHTML = fiches.length ? fiches.map(function(f) {
            return '<div class="fiche-card" onclick="openFiche(' + f.id + ')">' +
                '<div class="header"><strong>' + f.nom + ' ' + f.prenom + '</strong>' +
                '<span class="badge badge-info">' + (f.classe_actuelle || 'N/A') + '</span></div>' +
                '<small>N° Matricule: ' + (f.numero_matricule || '-') + ' | Né(e): ' + (f.date_naissance || '-') + '</small>' +
                '<br><small>🚑 Allergie: ' + (f.allergie == 1 ? '⚠️ OUI' : '✅ NON') + ' | Asthme: ' + (f.asthme == 1 ? '⚠️ OUI' : '✅ NON') + '</small>' +
                '</div>';
        }).join('') : '<p style="color:#888;text-align:center;padding:30px;">Aucune fiche trouvée</p>';
    }

    async function openFiche(id) {
        var r = await fetch('/vie-scolaire/api/fiches-eleves/' + id);
        var f = await r.json();
        
        document.getElementById('ficheModalTitre').textContent = '📋 ' + f.nom + ' ' + f.prenom;
        
        var html = '<h4 style="color:#002FA7;">📋 Informations élève</h4><div class="detail-grid">';
        html += '<div class="detail-item"><div class="label">Classe</div><div class="value">' + (f.classe_actuelle || '-') + '</div></div>';
        html += '<div class="detail-item"><div class="label">Matricule</div><div class="value">' + (f.numero_matricule || '-') + '</div></div>';
        html += '<div class="detail-item"><div class="label">Date naissance</div><div class="value">' + (f.date_naissance || '-') + '</div></div>';
        html += '<div class="detail-item"><div class="label">Lieu naissance</div><div class="value">' + (f.lieu_naissance || '-') + '</div></div>';
        html += '<div class="detail-item"><div class="label">Adresse</div><div class="value">' + (f.adresse || '-') + '</div></div>';
        html += '<div class="detail-item"><div class="label">École précédente</div><div class="value">' + (f.ecole_precedente || '-') + '</div></div>';
        html += '</div>';
        
        html += '<h4 style="color:#002FA7;margin-top:16px;">👨 Père</h4><div class="detail-grid">';
        html += '<div class="detail-item"><div class="label">Nom</div><div class="value">' + (f.pere_nom || '-') + '</div></div>';
        html += '<div class="detail-item"><div class="label">Prénom</div><div class="value">' + (f.pere_prenom || '-') + '</div></div>';
        html += '<div class="detail-item"><div class="label">Profession</div><div class="value">' + (f.pere_profession || '-') + '</div></div>';
        html += '<div class="detail-item"><div class="label">Téléphone</div><div class="value">' + (f.pere_telephone || '-') + '</div></div>';
        html += '</div>';
        
        html += '<h4 style="color:#002FA7;margin-top:16px;">👩 Mère</h4><div class="detail-grid">';
        html += '<div class="detail-item"><div class="label">Nom</div><div class="value">' + (f.mere_nom || '-') + '</div></div>';
        html += '<div class="detail-item"><div class="label">Prénom</div><div class="value">' + (f.mere_prenom || '-') + '</div></div>';
        html += '<div class="detail-item"><div class="label">Profession</div><div class="value">' + (f.mere_profession || '-') + '</div></div>';
        html += '<div class="detail-item"><div class="label">Téléphone</div><div class="value">' + (f.mere_telephone || '-') + '</div></div>';
        html += '</div>';
        
        html += '<h4 style="color:#002FA7;margin-top:16px;">🏥 Médical</h4><div class="detail-grid">';
        html += '<div class="detail-item"><div class="label">Allergie</div><div class="value">' + (f.allergie == 1 ? '⚠️ OUI - ' + (f.allergie_detail || '') : '✅ NON') + '</div></div>';
        html += '<div class="detail-item"><div class="label">Asthme</div><div class="value">' + (f.asthme == 1 ? '⚠️ OUI' : '✅ NON') + '</div></div>';
        html += '<div class="detail-item"><div class="label">Diabète</div><div class="value">' + (f.diabete == 1 ? '⚠️ OUI' : '✅ NON') + '</div></div>';
        html += '<div class="detail-item"><div class="label">Convulsion</div><div class="value">' + (f.convulsion == 1 ? '⚠️ OUI' : '✅ NON') + '</div></div>';
        html += '<div class="detail-item"><div class="label">Autres maladies</div><div class="value">' + (f.autres_maladies || '-') + '</div></div>';
        html += '<div class="detail-item"><div class="label">Mesure crise</div><div class="value">' + (f.mesure_crise || '-') + '</div></div>';
        html += '</div>';
        
        html += '<h4 style="color:#002FA7;margin-top:16px;">🆘 Urgences</h4><div class="detail-grid">';
        html += '<div class="detail-item"><div class="label">Contact 1</div><div class="value">' + (f.contact1_nom || '-') + ' - ' + (f.contact1_telephone || '-') + '</div></div>';
        html += '<div class="detail-item"><div class="label">Contact 2</div><div class="value">' + (f.contact2_nom || '-') + ' - ' + (f.contact2_telephone || '-') + '</div></div>';
        html += '</div>';
        
        document.getElementById('ficheDetail').innerHTML = html;
        document.getElementById('ficheModal').classList.add('active');
    }

    function closeModal() { document.getElementById('ficheModal').classList.remove('active'); }
    document.getElementById('ficheModal').addEventListener('click', function(e) { if (e.target === this) closeModal(); });

    loadFiches();
</script>

<%- include('../../partials/footer-vs') %>