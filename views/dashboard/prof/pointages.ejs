<%- include('../../partials/header-prof') %>

<h2 style="display:flex;align-items:center;gap:10px;margin-bottom:20px;">
    <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="#002FA7" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
    Mes pointages
</h2>

<div class="search-bar" style="margin-bottom:16px;">
    <input type="month" id="pointageMois" onchange="loadPointages()" class="form-control" style="width:200px;">
</div>

<div class="table-container">
    <table class="data-table">
        <thead><tr><th>Date</th><th>Arrivée</th><th>Départ</th><th>Statut</th><th>Contrat</th><th>Min retard</th><th>Commentaire</th></tr></thead>
        <tbody id="pointagesBody"><tr><td colspan="7">Chargement...</td></tr></tbody>
    </table>
</div>

<hr style="margin:24px 0;">

<h3>Cumul du mois</h3>
<div class="stats-grid" style="margin-bottom:16px;">
    <div class="stat-card"><div class="stat-info"><span class="stat-value" id="joursPointes">0</span><span class="stat-label">Jours pointés</span></div></div>
    <div class="stat-card"><div class="stat-info"><span class="stat-value text-success" id="joursPresents">0</span><span class="stat-label">Présent</span></div></div>
    <div class="stat-card"><div class="stat-info"><span class="stat-value text-warning" id="joursRetard">0</span><span class="stat-label">Retard</span></div></div>
    <div class="stat-card"><div class="stat-info"><span class="stat-value text-danger" id="joursAbsents">0</span><span class="stat-label">Absent</span></div></div>
    <div class="stat-card"><div class="stat-info"><span class="stat-value" id="totalMinRetard">0</span><span class="stat-label">Min retard</span></div></div>
</div>

<div id="avertissementsZone"></div>

<script>
    var moisActuel = new Date().toISOString().substring(0, 7);
    document.getElementById('pointageMois').value = moisActuel;

    async function loadPointages() {
        var mois = document.getElementById('pointageMois').value;
        var r = await fetch('/prof/api/pointages?mois=' + mois);
        var pointages = await r.json();
        document.getElementById('pointagesBody').innerHTML = pointages.length ? pointages.map(function(p) {
            var badgeClass = p.statut === 'present' || p.statut === 'sortie' ? 'badge-success' : p.statut === 'retard' ? 'badge-warning' : 'badge-danger';
            return '<tr><td>' + p.date_pointage + '</td><td>' + (p.heure_arrivee || '--:--') + '</td><td>' + (p.heure_depart || '--:--') + '</td><td><span class="badge ' + badgeClass + '">' + p.statut + '</span></td><td>' + (p.type_contrat || '-') + '</td><td>' + (p.minutes_retard || 0) + '</td><td>' + (p.commentaire || '-') + '</td></tr>';
        }).join('') : '<tr><td colspan="7">Aucun pointage</td></tr>';

        // Cumul
        var rc = await fetch('/prof/api/cumul-pointages?mois=' + mois);
        var cumul = await rc.json();
        document.getElementById('joursPointes').textContent = cumul.jours_pointes || 0;
        document.getElementById('joursPresents').textContent = cumul.jours_presents || 0;
        document.getElementById('joursRetard').textContent = cumul.jours_retard || 0;
        document.getElementById('joursAbsents').textContent = cumul.jours_absents || 0;
        document.getElementById('totalMinRetard').textContent = (cumul.total_minutes_retard || 0) + ' min';

        // Avertissements
        var ra = await fetch('/prof/api/avertissements?mois=' + mois);
        var avertissements = await ra.json();
        document.getElementById('avertissementsZone').innerHTML = avertissements.length ? avertissements.map(function(a) {
            return '<div style="background:#fff3cd;border:1px solid #ffc107;border-radius:10px;padding:14px;margin-bottom:8px;">⚠️ ' + a.message_avertissement + '</div>';
        }).join('') : '';
    }

    loadPointages();
</script>

<%- include('../../partials/footer-prof') %>