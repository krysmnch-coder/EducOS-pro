<%- include('../../partials/header-prof') %>

<style>
    .edt-grid { display: grid; grid-template-columns: 100px repeat(6, 1fr); gap: 2px; background: #e0e0e0; border-radius: 12px; overflow-x: auto; font-size: 0.75rem; min-width: 700px; }
    .edt-cell { background: white; padding: 6px; min-height: 60px; }
    .edt-header { background: #002FA7; color: white; font-weight: 700; text-align: center; padding: 10px 4px; font-size: 0.78rem; }
    .edt-time { background: #f8f9fa; font-weight: 600; text-align: center; display: flex; align-items: center; justify-content: center; color: #555; font-size: 0.7rem; flex-direction: column; }
    .edt-cours { background: #f0f4ff; border-left: 3px solid #002FA7; padding: 5px 6px; border-radius: 4px; margin: 2px 0; font-size: 0.68rem; }
    .edt-cours.mon-cours { background: #e8f5e9; border-left: 3px solid #27ae60; }
    .empty-cell { display: flex; align-items: center; justify-content: center; color: #ccc; font-size: 0.65rem; }
    .search-bar { display: flex; gap: 10px; margin-bottom: 16px; flex-wrap: wrap; }
    .search-bar select { padding: 10px 12px; border: 2px solid #e0e0e0; border-radius: 8px; font-size: 0.88rem; font-family: 'Inter', sans-serif; }
    .badge { padding: 2px 8px; border-radius: 10px; font-size: 0.65rem; font-weight: 600; }
    .badge-mine { background: #d4edda; color: #155724; }
    @media (max-width: 768px) { .edt-grid { font-size: 0.6rem; grid-template-columns: 60px repeat(6, 1fr); min-width: 500px; } }
</style>

<h2 style="display:flex;align-items:center;gap:10px;margin-bottom:20px;">
    <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="#002FA7" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
    Mon Emploi du temps
    <span class="badge badge-mine">Lecture seule</span>
</h2>

<div class="search-bar">
    <select id="filtreClasseEDT" onchange="loadEDT()"><option value="">Toutes mes classes</option></select>
    <select id="filtreJourEDT" onchange="loadEDT()">
        <option value="">Tous les jours</option><option>Lundi</option><option>Mardi</option><option>Mercredi</option><option>Jeudi</option><option>Vendredi</option><option>Samedi</option>
    </select>
</div>

<div style="overflow-x:auto;">
    <div class="edt-grid" id="edtGrid"><div style="padding:40px;text-align:center;grid-column:1/-1;color:#888;">Chargement...</div></div>
</div>

<div style="margin-top:16px;display:flex;align-items:center;gap:16px;font-size:0.8rem;color:#888;">
    <div style="display:flex;align-items:center;gap:6px;"><div style="width:16px;height:16px;background:#e8f5e9;border-left:3px solid #27ae60;border-radius:2px;"></div> Mes cours</div>
    <div style="display:flex;align-items:center;gap:6px;"><div style="width:16px;height:16px;background:#f0f4ff;border-left:3px solid #002FA7;border-radius:2px;"></div> Autres cours</div>
</div>

<script>
    async function loadEDT() {
        var classe = document.getElementById('filtreClasseEDT').value;
        var jour = document.getElementById('filtreJourEDT').value;
        var r = await fetch('/prof/api/edt?classe=' + encodeURIComponent(classe) + '&jour=' + encodeURIComponent(jour));
        var edt = await r.json();
        
        var jours = ['Lundi','Mardi','Mercredi','Jeudi','Vendredi','Samedi'];
        var plages = [
            {d:'07:00',f:'08:00'},{d:'08:00',f:'09:00'},{d:'09:00',f:'10:00'},
            {d:'10:00',f:'11:00'},{d:'11:00',f:'12:00'},{d:'12:00',f:'13:00'},
            {d:'13:00',f:'14:00'},{d:'14:00',f:'15:00'},{d:'15:00',f:'16:00'},
            {d:'16:00',f:'17:00'},{d:'17:00',f:'18:00'}
        ];
        
        var html = '<div class="edt-header">Heure</div>';
        jours.forEach(function(j) { html += '<div class="edt-header">' + j + '</div>'; });
        
        plages.forEach(function(p) {
            html += '<div class="edt-time"><span>' + p.d + '</span><span>' + p.f + '</span></div>';
            jours.forEach(function(j) {
                var cours = edt.filter(function(e) { return e.jour === j && e.heure_debut >= p.d + ':00' && e.heure_debut < p.f + ':00'; });
                html += '<div class="edt-cell">';
                if (cours.length > 0) {
                    cours.forEach(function(c) {
                        var isMine = true;
                        var classeStyle = isMine ? 'mon-cours' : '';
                        html += '<div class="edt-cours ' + classeStyle + '"><strong>' + c.matiere + '</strong> ' + (c.classe||'') + '<br><small>' + (c.salle||'') + ' ' + (c.civilite||'M.') + ' ' + (c.prof_nom||'') + '</small></div>';
                    });
                } else {
                    html += '<div class="empty-cell">-</div>';
                }
                html += '</div>';
            });
        });
        
        document.getElementById('edtGrid').innerHTML = html;
    }

    fetch('/prof/api/classes').then(function(r) { return r.json(); }).then(function(c) {
        document.getElementById('filtreClasseEDT').innerHTML = '<option value="">Toutes mes classes</option>' + c.map(function(x) { return '<option value="' + x.classe + '">' + x.classe + '</option>'; }).join('');
    });

    loadEDT();
</script>

<%- include('../../partials/footer-prof') %>