<%- include('../../partials/header-prof') %>

<style>
    .btn { padding: 8px 14px; border: none; border-radius: 8px; cursor: pointer; font-size: 0.8rem; font-weight: 600; font-family: 'Inter', sans-serif; }
    .btn-primary { background: #002FA7; color: white; }
    .note-input { width: 65px; padding: 6px 8px; border: 1px solid #ddd; border-radius: 6px; text-align: center; font-size: 0.85rem; font-family: 'Inter', sans-serif; }
    .note-input:focus { border-color: #002FA7; outline: none; }
    .note-input-exam { width: 70px; padding: 6px 8px; border: 2px solid #002FA7; border-radius: 6px; text-align: center; font-size: 0.85rem; font-family: 'Inter', sans-serif; background: #f8f9ff; }
    .form-control { padding: 8px 12px; border: 2px solid #e0e0e0; border-radius: 8px; font-size: 0.85rem; font-family: 'Inter', sans-serif; }
    .search-bar { display: flex; gap: 10px; margin-bottom: 16px; flex-wrap: wrap; align-items: center; }
    .moyenne-cell { font-weight: 700; }
    .total-cell { font-weight: 700; color: #f39c12; }
    .badge { padding: 4px 10px; border-radius: 20px; font-size: 0.72rem; font-weight: 600; }
    .badge-info { background: #d1ecf1; color: #0c5460; }
    .badge-success { background: #d4edda; color: #155724; }
    .badge-danger { background: #f8d7da; color: #721c24; }
    .coef-badge { display: inline-block; background: #f0f4ff; color: #002FA7; padding: 2px 8px; border-radius: 10px; font-size: 0.7rem; font-weight: 700; }
    .formula-info { background: #f0f4ff; border-radius: 10px; padding: 10px 16px; font-size: 0.8rem; color: #002FA7; margin-bottom: 16px; display: flex; align-items: center; gap: 8px; flex-wrap: wrap; }
    .rang-badge { display: inline-flex; align-items: center; justify-content: center; width: 32px; height: 32px; border-radius: 50%; font-weight: 700; font-size: 0.85rem; color: white; }
    .rang-1 { background: #f39c12; }
    .rang-2 { background: #95a5a6; }
    .rang-3 { background: #cd7f32; }
    .rang-other { background: #e0e0e0; color: #666; }
    .toast { position: fixed; top: 20px; right: 20px; padding: 14px 20px; border-radius: 10px; color: white; font-weight: 600; z-index: 3000; display: none; }
    .toast.success { background: #27ae60; }
</style>

<h2 style="display:flex;align-items:center;gap:10px;margin-bottom:20px;">
    <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="#002FA7" stroke-width="2"><path d="M9 11l3 3L22 4"/><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/></svg>
    Grille de notes - <span id="matiereProf"></span>
</h2>

<div class="search-bar">
    <select id="filtreClasse" class="form-control" onchange="loadNotes()" style="width:180px;"></select>
    <select id="filtreTrimestre" class="form-control" onchange="loadNotes()" style="width:150px;">
        <option value="1">Trimestre 1</option><option value="2">Trimestre 2</option><option value="3">Trimestre 3</option>
    </select>
    <label style="display:flex;align-items:center;gap:6px;font-size:0.85rem;font-weight:600;">
        Coef Examen:
        <select id="coefExamen" class="form-control" onchange="loadNotes()" style="width:70px;padding:6px 8px;">
            <option value="1">1</option><option value="2" selected>2</option><option value="3">3</option><option value="4">4</option><option value="5">5</option>
        </select>
    </label>
</div>

<div class="formula-info">
    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#002FA7" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="16" x2="12" y2="12"/><line x1="12" y1="8" x2="12.01" y2="8"/></svg>
    <span>Formule : <strong>((NJ1 + NJ2) ÷ 2 + Examen sur <span id="noteMaxLabel">40</span>) ÷ (<span id="diviseur">3</span>)</strong></span>
</div>

<div style="overflow-x:auto;">
    <table class="data-table">
        <thead>
            <tr>
                <th>Élève</th>
                <th>NJ1 <span class="coef-badge">/20</span></th>
                <th>NJ2 <span class="coef-badge">/20</span></th>
                <th>Moy NJ <span class="coef-badge">/20</span></th>
                <th>Examen <span class="coef-badge" id="examHeader">/40</span></th>
                <th>Total</th>
                <th>Moyenne <span class="coef-badge">/20</span></th>
                <th>Appréciation</th>
                <th>Rang</th>
            </tr>
        </thead>
        <tbody id="notesBody">
            <tr><td colspan="9" style="text-align:center;padding:30px;">Sélectionnez une classe</td></tr>
        </tbody>
    </table>
</div>

<div style="display:flex;gap:10px;margin-top:16px;">
    <button class="btn btn-primary" onclick="exporterNotes()">📥 Exporter CSV</button>
    <button class="btn btn-primary" onclick="window.print()">🖨️ Imprimer</button>
</div>

<div class="toast" id="toast"></div>

<script>
    var currentNotes = [];

    function getAppreciation(moyenne) {
        if (moyenne >= 18) return 'Excellent';
        if (moyenne >= 16) return 'Très bien';
        if (moyenne >= 14) return 'Bien';
        if (moyenne >= 12) return 'Assez bien';
        if (moyenne >= 10) return 'Passable';
        if (moyenne >= 8) return 'Insuffisant';
        return 'Faible';
    }

    function getRangBadge(rang) {
        if (rang === 1) return 'rang-1';
        if (rang === 2) return 'rang-2';
        if (rang === 3) return 'rang-3';
        return 'rang-other';
    }

    function getNoteMax(coef) { return coef * 20; }
    function getDiviseur(coef) { return coef + 1; }

    async function loadProfil() {
        var r = await fetch('/prof/api/profil');
        var p = await r.json();
        document.getElementById('matiereProf').textContent = p.matiere_principale || '';
    }

    async function loadNotes() {
        var classe = document.getElementById('filtreClasse').value;
        var trimestre = document.getElementById('filtreTrimestre').value;
        var coef = parseInt(document.getElementById('coefExamen').value) || 2;
        var noteMax = getNoteMax(coef);
        var diviseur = getDiviseur(coef);

        document.getElementById('noteMaxLabel').textContent = noteMax;
        document.getElementById('diviseur').textContent = diviseur;
        document.getElementById('examHeader').textContent = '/' + noteMax;

        if (!classe) {
            document.getElementById('notesBody').innerHTML = '<tr><td colspan="9">Sélectionnez une classe</td></tr>';
            return;
        }

        var r = await fetch('/prof/api/notes?classe=' + encodeURIComponent(classe) + '&trimestre=' + trimestre);
        var notes = await r.json();

        if (!notes.length) {
            document.getElementById('notesBody').innerHTML = '<tr><td colspan="9">Aucun élève dans cette classe</td></tr>';
            currentNotes = [];
            return;
        }

        notes.forEach(function(e) {
            e.moyenneFinale = (e.moyenneNJ + e.examen) / diviseur;
        });

        notes.sort(function(a, b) { return b.moyenneFinale - a.moyenneFinale; });
        notes.forEach(function(e, i) { e.rang = i + 1; });
        currentNotes = notes;

        document.getElementById('notesBody').innerHTML = notes.map(function(e) {
            var app = getAppreciation(e.moyenneFinale);
            return '<tr>' +
                '<td><strong>' + e.nom + ' ' + e.prenom + '</strong></td>' +
                '<td><input type="number" class="note-input" value="' + e.nj1 + '" onchange="saveNote(' + e.eleve_id + ',\'NJ1\',this.value)" min="0" max="20" step="0.25"></td>' +
                '<td><input type="number" class="note-input" value="' + e.nj2 + '" onchange="saveNote(' + e.eleve_id + ',\'NJ2\',this.value)" min="0" max="20" step="0.25"></td>' +
                '<td class="moyenne-cell">' + e.moyenneNJ.toFixed(2) + '</td>' +
                '<td><input type="number" class="note-input-exam" value="' + e.examen + '" onchange="saveNote(' + e.eleve_id + ',\'Examen\',this.value)" min="0" max="' + noteMax + '" step="0.5"></td>' +
                '<td class="total-cell">' + e.total.toFixed(2) + '</td>' +
                '<td class="moyenne-cell" style="color:#002FA7;font-size:1.1em;">' + e.moyenneFinale.toFixed(2) + '/20</td>' +
                '<td><span class="badge ' + (e.moyenneFinale >= 10 ? 'badge-success' : 'badge-danger') + '">' + app + '</span></td>' +
                '<td><span class="rang-badge ' + getRangBadge(e.rang) + '">' + e.rang + '</span></td>' +
                '</tr>';
        }).join('');
    }

    async function saveNote(eleveId, type, note) {
        var classe = document.getElementById('filtreClasse').value;
        var trimestre = document.getElementById('filtreTrimestre').value;
        var coef = parseInt(document.getElementById('coefExamen').value) || 2;

        await fetch('/prof/api/notes', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
                eleve_id: eleveId,
                classe: classe,
                type_evaluation: type,
                note: parseFloat(note) || 0,
                coefficient: type === 'Examen' ? coef : 1,
                trimestre: trimestre
            })
        });

        loadNotes();
        var t = document.getElementById('toast');
        t.textContent = 'Note enregistrée ✓';
        t.className = 'toast success';
        t.style.display = 'block';
        setTimeout(function() { t.style.display = 'none'; }, 1500);
    }

    function exporterNotes() {
        if (!currentNotes.length) return;
        var coef = parseInt(document.getElementById('coefExamen').value) || 2;
        var csv = 'Élève;NJ1/20;NJ2/20;Moy NJ;Examen/' + getNoteMax(coef) + ';Total;Moyenne/20;Appréciation;Rang\n';
        currentNotes.forEach(function(e) {
            csv += e.nom + ' ' + e.prenom + ';' + e.nj1 + ';' + e.nj2 + ';' + e.moyenneNJ.toFixed(2) + ';' + e.examen + ';' + e.total.toFixed(2) + ';' + e.moyenneFinale.toFixed(2) + ';' + getAppreciation(e.moyenneFinale) + ';' + e.rang + '\n';
        });
        var blob = new Blob(['\uFEFF' + csv], { type: 'text/csv;charset=utf-8;' });
        var link = document.createElement('a');
        link.href = URL.createObjectURL(blob);
        link.download = 'notes.csv';
        link.click();
    }

    async function loadClasses() {
        var r = await fetch('/prof/api/classes');
        var c = await r.json();
        document.getElementById('filtreClasse').innerHTML = '<option value="">Choisir une classe</option>' + c.map(function(x) { return '<option value="' + x.classe + '">' + x.classe + '</option>'; }).join('');
    }

    loadProfil();
    loadClasses();
</script>

<%- include('../../partials/footer-prof') %>