<%- include('../partials/header-admin') %>

<div class="stats-grid">
    <div class="stat-card">
        <div class="stat-icon" style="background:#eef2ff;">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#002FA7" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
        </div>
        <div class="stat-info"><span class="stat-value" id="totalUsers">...</span><span class="stat-label">Utilisateurs</span></div>
    </div>
    <div class="stat-card">
        <div class="stat-icon" style="background:#f0fdf4;">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#27ae60" stroke-width="2"><path d="M22 10v6M2 10l10-5 10 5-10 5z"/><path d="M6 12v5c0 2 4 3 6 3s6-1 6-3v-5"/></svg>
        </div>
        <div class="stat-info"><span class="stat-value" id="totalEleves">...</span><span class="stat-label">Élèves</span></div>
    </div>
    <div class="stat-card">
        <div class="stat-icon" style="background:#fff7ed;">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#f39c12" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="2"/><line x1="3" y1="9" x2="21" y2="9"/><line x1="9" y1="21" x2="9" y2="9"/></svg>
        </div>
        <div class="stat-info"><span class="stat-value" id="totalProfs">...</span><span class="stat-label">Professeurs</span></div>
    </div>
    <div class="stat-card">
        <div class="stat-icon" style="background:#fff0f0;">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#e74c3c" stroke-width="2"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
        </div>
        <div class="stat-info"><span class="stat-value" id="totalAdmins">...</span><span class="stat-label">Administrateurs</span></div>
    </div>
</div>

<div class="section">
    <h2 style="display:flex;align-items:center;gap:8px;">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#002FA7" stroke-width="2"><polyline points="4 17 10 11 4 5"/><line x1="12" y1="19" x2="20" y2="19"/></svg>
        Accès rapide
    </h2>
    <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(180px,1fr));gap:16px;margin-top:16px;">
        <a href="/dashboard/admin/utilisateurs" class="action-card" style="text-decoration:none;color:inherit;">
            <div style="display:flex;align-items:center;gap:12px;">
                <div style="width:48px;height:48px;border-radius:12px;background:#eef2ff;display:flex;align-items:center;justify-content:center;">
                    <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#002FA7" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
                </div>
                <div><strong>Utilisateurs</strong><p style="font-size:0.8rem;color:#888;">Gérer les comptes</p></div>
            </div>
        </a>
        <a href="/dashboard/admin/etablissement" class="action-card" style="text-decoration:none;color:inherit;">
            <div style="display:flex;align-items:center;gap:12px;">
                <div style="width:48px;height:48px;border-radius:12px;background:#f0fdf4;display:flex;align-items:center;justify-content:center;">
                    <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#27ae60" stroke-width="2"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
                </div>
                <div><strong>Établissement</strong><p style="font-size:0.8rem;color:#888;">Infos école</p></div>
            </div>
        </a>
        <a href="/dashboard/admin/paiements" class="action-card" style="text-decoration:none;color:inherit;">
            <div style="display:flex;align-items:center;gap:12px;">
                <div style="width:48px;height:48px;border-radius:12px;background:#fff7ed;display:flex;align-items:center;justify-content:center;">
                    <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#f39c12" stroke-width="2"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>
                </div>
                <div><strong>Paiements</strong><p style="font-size:0.8rem;color:#888;">Finances</p></div>
            </div>
        </a>
        <a href="/dashboard/admin/messages" class="action-card" style="text-decoration:none;color:inherit;">
            <div style="display:flex;align-items:center;gap:12px;">
                <div style="width:48px;height:48px;border-radius:12px;background:#f0f4ff;display:flex;align-items:center;justify-content:center;">
                    <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#6366f1" stroke-width="2"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
                </div>
                <div><strong>Messages</strong><p style="font-size:0.8rem;color:#888;">Communication</p></div>
            </div>
        </a>
    </div>
</div>

<script>
    fetch('/admin/api/stats').then(r => r.json()).then(s => {
        document.getElementById('totalUsers').textContent = s.totalUsers || 0;
        document.getElementById('totalEleves').textContent = s.totalEleves || 0;
        document.getElementById('totalProfs').textContent = s.totalProfs || 0;
        document.getElementById('totalAdmins').textContent = s.totalAdmins || 0;
    });
</script>

<%- include('../partials/footer-admin') %>