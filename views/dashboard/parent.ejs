<!-- TAB: MESSAGES -->
<div class="tab-content" id="tab-messages">
    <div class="section">
        <h3><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#002FA7" stroke-width="2"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg> Messages</h3>
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:20px;">
            <div>
                <h4>Envoyer</h4>
                <form onsubmit="return false;">
                    <div class="form-group"><select id="msgDest" class="form-control" onchange="toggleDest()"><option value="all">Tout le monde</option><option value="role">Par rôle</option></select></div>
                    <div class="form-group" id="msgRoleGrp" style="display:none;"><select id="msgRole" class="form-control"><option value="admin">Admin</option><option value="vie_scolaire">Vie Scolaire</option><option value="prof">Professeur</option></select></div>
                    <div class="form-group"><input type="text" id="msgSujet" class="form-control" placeholder="Sujet" required></div>
                    <div class="form-group"><textarea id="msgContenu" class="form-control" rows="3" placeholder="Message" required></textarea></div>
                    <div class="form-group"><label class="file-upload-label" for="msgFichier">📎 Fichier</label><input type="file" id="msgFichier" style="display:none;" onchange="showFileName()"></div>
                    <div id="fileName" style="font-size:0.8rem;color:#27ae60;"></div>
                    <button class="btn btn-primary" onclick="sendMessage()">Envoyer</button>
                </form>
            </div>
            <div><h4>Reçus</h4><div id="messagesList"></div></div>
        </div>
    </div>
</div>

<div class="toast" id="toast"></div>

<script>
    var fraisSelectionne = null;
    var mobileMoneyChoisi = null;

    function showTab(tab) {
        document.querySelectorAll('.tab-content').forEach(function(t) { t.classList.remove('active'); });
        document.querySelectorAll('.sidebar .nav-item').forEach(function(n) { n.classList.remove('active'); });
        document.getElementById('tab-' + tab).classList.add('active');
        event.target.classList.add('active');
        loadTabData(tab);
        if (window.innerWidth <= 768) toggleSidebar();
    }

    function loadTabData(tab) {
        var nom = localStorage.getItem('enfantNom');
        var prenom = localStorage.getItem('enfantPrenom');
        var classe = localStorage.getItem('enfantClasse');
        if (!nom) return;
        
        if (tab === 'notes') { document.getElementById('notesEnfantNom').textContent = nom + ' ' + prenom; loadNotes(); }
        else if (tab === 'edt') { document.getElementById('edtEnfantNom').textContent = classe; loadEDT(); }
        else if (tab === 'ressources') { document.getElementById('ressourcesEnfantNom').textContent = classe; loadRessources(); }
        else if (tab === 'absences') { document.getElementById('absencesEnfantNom').textContent = nom + ' ' + prenom; loadAbsences(); }
        else if (tab === 'sanctions') { document.getElementById('sanctionsEnfantNom').textContent = nom + ' ' + prenom; loadSanctions(); }
        else if (tab === 'messages') { loadMessages(); }
        else if (tab === 'paiement') { loadFrais(); }
    }

    async function loadNotes() {
    var nom = localStorage.getItem('enfantNom');
    var prenom = localStorage.getItem('enfantPrenom');
    if (!nom) return;
    document.getElementById('notesEnfantNom').textContent = nom + ' ' + prenom;
    
    var r = await fetch('/parent/api/notes?eleve_nom=' + encodeURIComponent(nom) + '&eleve_prenom=' + encodeURIComponent(prenom));
    var data = await r.json();
    
    var html = '';
    
    // Moyenne générale
    html += '<div style="background:#f0f4ff;border-radius:12px;padding:16px;margin-bottom:20px;text-align:center;">';
    html += '<div style="font-size:0.8rem;color:#888;">Moyenne Générale</div>';
    html += '<div style="font-size:2.5rem;font-weight:700;color:#002FA7;">' + data.moyenneGenerale.toFixed(2) + '/20</div>';
    html += '</div>';
    
    // Tableau des notes par matière
    if (data.matieres && data.matieres.length > 0) {
        html += '<div style="overflow-x:auto;"><table class="data-table">';
        html += '<thead><tr><th>Matière</th><th>Professeur</th><th>NJ1 /20</th><th>NJ2 /20</th><th>Moy NJ /20</th><th>Examen /20</th><th>Coef</th><th>Total</th><th>Moyenne /20</th><th>Appréciation</th></tr></thead>';
        html += '<tbody>';
        
        data.matieres.forEach(function(m) {
            var appreciation = getAppreciation(m.moyenne);
            html += '<tr>';
            html += '<td><strong>' + m.matiere + '</strong></td>';
            html += '<td>' + m.prof_nom + ' ' + m.prof_prenom + '</td>';
            html += '<td>' + m.nj1.toFixed(2) + '</td>';
            html += '<td>' + m.nj2.toFixed(2) + '</td>';
            html += '<td><strong>' + m.moyenneNJ.toFixed(2) + '</strong></td>';
            html += '<td>' + m.examen.toFixed(2) + '</td>';
            html += '<td><span class="badge badge-info">×' + m.coef + '</span></td>';
            html += '<td>' + m.total.toFixed(2) + '</td>';
            html += '<td><strong style="color:#002FA7;font-size:1.1em;">' + m.moyenne.toFixed(2) + '</strong></td>';
            html += '<td><span class="badge ' + (m.moyenne >= 10 ? 'badge-success' : 'badge-danger') + '">' + appreciation + '</span></td>';
            html += '</tr>';
        });
        
        html += '</tbody></table></div>';
    } else {
        html += '<p style="color:#888;text-align:center;padding:20px;">Aucune note disponible pour cet élève</p>';
    }
    
    document.getElementById('notesContent').innerHTML = html;
}

function getAppreciation(moyenne) {
    if (moyenne >= 18) return 'Excellent';
    if (moyenne >= 16) return 'Très bien';
    if (moyenne >= 14) return 'Bien';
    if (moyenne >= 12) return 'Assez bien';
    if (moyenne >= 10) return 'Passable';
    if (moyenne >= 8) return 'Insuffisant';
    if (moyenne >= 5) return 'Faible';
    return 'Très faible';
}

function getAppreciationBadge(moyenne) {
    if (moyenne >= 16) return 'badge-success';
    if (moyenne >= 10) return 'badge-info';
    return 'badge-danger';
}

