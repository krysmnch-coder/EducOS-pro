    async function openMsg(id) {
        var r = await fetch('/parent/api/messages');
        var msgs = await r.json();
        var m = msgs.find(function(x) { return x.id === id; });
        if (m) {
            document.getElementById('modalMessageSujet').textContent = m.sujet;
            document.getElementById('modalMessageContenu').textContent = m.contenu;
            document.getElementById('messageModal').classList.add('active');
        }
    }
    async function sendMessage() {
        var formData = new FormData();
        formData.append('sujet', document.getElementById('msgSujet').value);
        formData.append('contenu', document.getElementById('msgContenu').value);
        var type = document.getElementById('msgDest').value;
        if (type==='role') formData.append('destinataire_role', document.getElementById('msgRole').value);
        else formData.append('destinataire_role', 'all');
        var f = document.getElementById('msgFichier').files[0];
        if (f) formData.append('fichier', f);
        var r = await fetch('/parent/api/messages', { method: 'POST', body: formData });
        var j = await r.json();
        showToast(j.message, 'success');
        loadMessages();
    }
    function showToast(msg, type) {
        var t = document.getElementById('toast');
        t.textContent = msg; t.className = 'toast ' + type; t.style.display = 'block';
        setTimeout(function() { t.style.display = 'none'; }, 3000);
    }
