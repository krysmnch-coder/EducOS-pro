        document.getElementById('ficheDateNaissance').value = fiche.date_naissance || '';
        document.getElementById('ficheLieu').value = fiche.lieu_naissance || '';
        document.getElementById('ficheAdresse').value = fiche.adresse || '';
        document.getElementById('ficheEcolePrecedente').value = fiche.ecole_precedente || '';
        document.getElementById('ficheAnneeInscription').value = fiche.annee_inscription || '';
        document.getElementById('ficheReinscription').checked = fiche.reinscription == 1;
        document.getElementById('fichePereNom').value = fiche.pere_nom || '';
        document.getElementById('fichePerePrenom').value = fiche.pere_prenom || '';
        document.getElementById('fichePereProfession').value = fiche.pere_profession || '';
        document.getElementById('fichePereLieuTravail').value = fiche.pere_lieu_travail || '';
        document.getElementById('fichePereEmail').value = fiche.pere_email || '';
        document.getElementById('fichePereTelephone').value = fiche.pere_telephone || '';
        document.getElementById('ficheMereNom').value = fiche.mere_nom || '';
        document.getElementById('ficheMerePrenom').value = fiche.mere_prenom || '';
        document.getElementById('ficheMereProfession').value = fiche.mere_profession || '';
        document.getElementById('ficheMereLieuTravail').value = fiche.mere_lieu_travail || '';
        document.getElementById('ficheMereEmail').value = fiche.mere_email || '';
        document.getElementById('ficheMereTelephone').value = fiche.mere_telephone || '';
        document.getElementById('ficheAllergie').value = fiche.allergie || 0;
        document.getElementById('allergieDetail').value = fiche.allergie_detail || '';
        document.getElementById('allergieDetail').style.display = fiche.allergie == 1 ? 'block' : 'none';
        document.getElementById('ficheAsthme').value = fiche.asthme || 0;
        document.getElementById('ficheDiabete').value = fiche.diabete || 0;
        document.getElementById('ficheConvulsion').value = fiche.convulsion || 0;
        document.getElementById('ficheAutresMaladies').value = fiche.autres_maladies || '';
        document.getElementById('ficheMesureCrise').value = fiche.mesure_crise || '';
        document.getElementById('ficheAntecedent').value = fiche.antecedent_personnel || '';
        document.getElementById('ficheContact1Nom').value = fiche.contact1_nom || '';
        document.getElementById('ficheContact1Tel').value = fiche.contact1_telephone || '';
        document.getElementById('ficheContact2Nom').value = fiche.contact2_nom || '';
        document.getElementById('ficheContact2Tel').value = fiche.contact2_telephone || '';
    } else {
        document.getElementById('ficheId').value = '';
        // Vider les autres champs
        ['ficheMatricule','ficheDateNaissance','ficheLieu','ficheAdresse','ficheEcolePrecedente',
         'ficheAnneeInscription','fichePereNom','fichePerePrenom','fichePereProfession','fichePereLieuTravail',
         'fichePereEmail','fichePereTelephone','ficheMereNom','ficheMerePrenom','ficheMereProfession',
         'ficheMereLieuTravail','ficheMereEmail','ficheMereTelephone','ficheAutresMaladies',
         'ficheMesureCrise','ficheAntecedent','ficheContact1Nom','ficheContact1Tel','ficheContact2Nom',
         'ficheContact2Tel'].forEach(function(id) { document.getElementById(id).value = ''; });
        document.getElementById('ficheReinscription').checked = false;
    }
}

async function saveFicheEleve() {
    var data = {
        fiche_id: document.getElementById('ficheId').value || null,
        nom: document.getElementById('ficheNom').value,
        prenom: document.getElementById('fichePrenom').value,
        date_naissance: document.getElementById('ficheDateNaissance').value,
        lieu_naissance: document.getElementById('ficheLieu').value,
        adresse: document.getElementById('ficheAdresse').value,
        classe_actuelle: document.getElementById('ficheClasse').value,
        numero_matricule: document.getElementById('ficheMatricule').value,
        ecole_precedente: document.getElementById('ficheEcolePrecedente').value,
        annee_inscription: document.getElementById('ficheAnneeInscription').value,
        reinscription: document.getElementById('ficheReinscription').checked ? 1 : 0,
        pere_nom: document.getElementById('fichePereNom').value,
        pere_prenom: document.getElementById('fichePerePrenom').value,
        pere_profession: document.getElementById('fichePereProfession').value,
        pere_lieu_travail: document.getElementById('fichePereLieuTravail').value,
        pere_email: document.getElementById('fichePereEmail').value,
        pere_telephone: document.getElementById('fichePereTelephone').value,
        mere_nom: document.getElementById('ficheMereNom').value,
        mere_prenom: document.getElementById('ficheMerePrenom').value,
        mere_profession: document.getElementById('ficheMereProfession').value,
        mere_lieu_travail: document.getElementById('ficheMereLieuTravail').value,
        mere_email: document.getElementById('ficheMereEmail').value,
        mere_telephone: document.getElementById('ficheMereTelephone').value,
        allergie: parseInt(document.getElementById('ficheAllergie').value) || 0,
        allergie_detail: document.getElementById('allergieDetail').value,
        asthme: parseInt(document.getElementById('ficheAsthme').value) || 0,
        diabete: parseInt(document.getElementById('ficheDiabete').value) || 0,
        convulsion: parseInt(document.getElementById('ficheConvulsion').value) || 0,
        autres_maladies: document.getElementById('ficheAutresMaladies').value,
        mesure_crise: document.getElementById('ficheMesureCrise').value,
        contact1_nom: document.getElementById('ficheContact1Nom').value,
        contact1_telephone: document.getElementById('ficheContact1Tel').value,
        contact2_nom: document.getElementById('ficheContact2Nom').value,
        contact2_telephone: document.getElementById('ficheContact2Tel').value,
        antecedent_personnel: document.getElementById('ficheAntecedent').value
    };
    
    if (!data.nom || !data.prenom) {
        showToast('Nom et prénom obligatoires', 'error');
        return;
    }
    
    var r = await fetch('/parent/api/fiche-eleve', { method:'POST', headers:{'Content-Type':'application/json'}, body:JSON.stringify(data) });
    var j = await r.json();
    showToast(j.message || j.error, r.ok ? 'success' : 'error');
    if (r.ok && j.fiche_id) document.getElementById('ficheId').value = j.fiche_id;
}

// Appeler au chargement
loadEnfantsForFiche();
</script>

