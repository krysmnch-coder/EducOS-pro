async function chargerFiche() {
    var index = document.getElementById('ficheEnfant').value;
    if (index === '') return;
    var r = await fetch('/parent/api/enfants');
    var enfants = await r.json();
    var enfant = enfants[parseInt(index)];
    if (!enfant) return;
    
    // Remplir les champs de base
    document.getElementById('ficheNom').value = enfant.nom;
    document.getElementById('fichePrenom').value = enfant.prenom;
    document.getElementById('ficheClasse').value = enfant.classe || '';
    
    // Chercher une fiche existante
    var rFiche = await fetch('/parent/api/fiche-eleve?nom=' + encodeURIComponent(enfant.nom) + '&prenom=' + encodeURIComponent(enfant.prenom));
