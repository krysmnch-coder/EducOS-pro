    function selectFrais(index, montant) {
        fraisSelectionne = index;
        document.querySelectorAll('.paiement-card').forEach(function(c) { c.classList.remove('selected'); });
        document.getElementById('frais-' + index).classList.add('selected');
        document.getElementById('paiementSection').style.display = 'block';
        document.getElementById('paiementMontant').value = montant;
    }

    function selectMobileMoney(type) {
        mobileMoneyChoisi = type;
        document.querySelectorAll('.mobile-money-logo').forEach(function(m) { m.classList.remove('selected'); });
        document.getElementById('mm-' + type).classList.add('selected');
        document.getElementById('paiementForm').style.display = 'block';
    }

    async function effectuerPaiement() {
        if (!mobileMoneyChoisi) return showToast('Choisissez un mode de paiement', 'error');
        var tel = document.getElementById('paiementTel').value;
        if (!tel) return showToast('Numéro de téléphone requis', 'error');
        var data = {
            frais_index: fraisSelectionne,
            montant: document.getElementById('paiementMontant').value,
            mode: mobileMoneyChoisi,
            telephone: tel
        };
        var r = await fetch('/parent/api/payer', { method: 'POST', headers: {'Content-Type':'application/json'}, body: JSON.stringify(data) });
        var j = await r.json();
        showToast(j.message || j.error, r.ok ? 'success' : 'error');
        if (r.ok) { document.getElementById('paiementSection').style.display = 'none'; loadFrais(); }
    }

