    async function loadMessages() {
        var r = await fetch('/parent/api/messages');
        var msgs = await r.json();
        document.getElementById('messagesList').innerHTML = msgs.length ? msgs.map(function(m) {
            return '<div class="msg-item ' + (m.lu?'':'non-lu') + '" onclick="openMsg(' + m.id + ')"><strong>' + m.sujet + '</strong><br><small>' + m.exp_nom + ' ' + m.exp_prenom + '</small></div>';
        }).join('') : '<p style="color:#888;">Aucun message</p>';
