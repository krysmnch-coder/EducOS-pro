<%- include('../partials/header-parent') %>

<style>
    .ressource-card { background: #f8f9fa; border-radius: 10px; padding: 12px; margin-bottom: 8px; }
.modal { display: none; position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0,0,0,0.5); z-index: 2000; align-items: center; justify-content: center; padding: 20px; }
.modal.active { display: flex; }
.modal-content { background: white; border-radius: 16px; padding: 24px; width: 100%; max-width: 500px; max-height: 80vh; overflow-y: auto; }
.modal-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px; }
.close-modal { background: none; border: none; cursor: pointer; padding: 4px; }
.close-modal svg { width: 20px; height: 20px; stroke: #666; }
.file-upload-label { display: inline-flex; align-items: center; gap: 6px; padding: 8px 16px; background: #f0f4ff; border: 2px dashed #002FA7; border-radius: 8px; cursor: pointer; font-size: 0.85rem; color: #002FA7; font-weight: 500; }
.file-upload-label svg { width: 16px; height: 16px; stroke: #002FA7; }
    .section { background: white; border-radius: 14px; padding: 20px; margin-bottom: 20px; box-shadow: 0 1px 6px rgba(0,0,0,0.04); }
    .section h3 { font-size: 1rem; font-weight: 700; margin-bottom: 16px; display: flex; align-items: center; gap: 8px; }
    .note-card { background: #f8f9fa; border-radius: 10px; padding: 12px; text-align: center; }
    .note-card .note-value { font-size: 1.5rem; font-weight: 700; color: #002FA7; }
    .notes-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(140px, 1fr)); gap: 10px; }
    .badge { padding: 4px 10px; border-radius: 20px; font-size: 0.72rem; font-weight: 600; }
    .badge-info { background: #d1ecf1; color: #0c5460; }
    .badge-success { background: #d4edda; color: #155724; }
    .badge-danger { background: #f8d7da; color: #721c24; }
    .badge-warning { background: #fff3cd; color: #856404; }
    .edt-grid { display: grid; grid-template-columns: 100px repeat(6, 1fr); gap: 2px; background: #e0e0e0; border-radius: 12px; overflow-x: auto; font-size: 0.75rem; min-width: 700px; }
    .edt-cell { background: white; padding: 6px; min-height: 60px; }
    .edt-header { background: #002FA7; color: white; font-weight: 700; text-align: center; padding: 10px 4px; font-size: 0.78rem; }
    .edt-time { background: #f8f9fa; font-weight: 600; text-align: center; display: flex; align-items: center; justify-content: center; color: #555; font-size: 0.7rem; flex-direction: column; }
    .edt-cours { background: #f0f4ff; border-left: 3px solid #002FA7; padding: 5px 6px; border-radius: 4px; margin: 2px 0; font-size: 0.68rem; }
    .ressource-card { background: #f8f9fa; border-radius: 10px; padding: 12px; margin-bottom: 8px; }
    .btn { padding: 8px 16px; border: none; border-radius: 8px; cursor: pointer; font-size: 0.85rem; font-weight: 600; font-family: 'Inter', sans-serif; }
    .btn-primary { background: #002FA7; color: white; }
    .btn-success { background: #27ae60; color: white; }
    .form-group { margin-bottom: 14px; }
    .form-group label { display: block; margin-bottom: 5px; font-weight: 600; font-size: 0.85rem; }
    .form-control { width: 100%; padding: 10px 12px; border: 2px solid #e0e0e0; border-radius: 8px; font-size: 0.88rem; font-family: 'Inter', sans-serif; }
    .form-control:focus { border-color: #002FA7; outline: none; }
    .form-row { display: flex; gap: 12px; }
    .form-row .form-group { flex: 1; }
    .paiement-card { border: 2px solid #e0e0e0; border-radius: 12px; padding: 16px; margin-bottom: 12px; cursor: pointer; transition: all 0.2s; }
    .paiement-card:hover { border-color: #002FA7; }
    .paiement-card.selected { border-color: #27ae60; background: #f0fdf4; }
    .mobile-money-logos { display: flex; gap: 16px; justify-content: center; margin: 16px 0; }
    .mobile-money-logo { text-align: center; cursor: pointer; padding: 12px; border: 2px solid #e0e0e0; border-radius: 12px; transition: all 0.2s; }
    .mobile-money-logo:hover { border-color: #002FA7; }
    .mobile-money-logo.selected { border-color: #27ae60; background: #f0fdf4; }
    .msg-item { padding: 12px 14px; border: 1px solid #e8e8e8; border-radius: 10px; margin-bottom: 8px; cursor: pointer; }
    .msg-item.non-lu { border-left: 3px solid #002FA7; background: #f8f9ff; }
    textarea.form-control { resize: vertical; min-height: 80px; }
    .file-upload-label { display: inline-flex; align-items: center; gap: 6px; padding: 8px 16px; background: #f0f4ff; border: 2px dashed #002FA7; border-radius: 8px; cursor: pointer; font-size: 0.85rem; color: #002FA7; }
    .toast { position: fixed; top: 20px; right: 20px; padding: 14px 20px; border-radius: 10px; color: white; font-weight: 600; z-index: 3000; display: none; }
    .toast.success { background: #27ae60; }
    .toast.error { background: #e74c3c; }
    @media (max-width: 768px) { .edt-grid { font-size: 0.6rem; grid-template-columns: 60px repeat(6, 1fr); min-width: 500px; } .form-row { flex-direction: column; } }
</style>

<!-- TAB: NOTES -->
