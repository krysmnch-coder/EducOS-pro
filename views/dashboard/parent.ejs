    async function loadEDT() {
        var r = await fetch('/parent/api/edt?classe=' + encodeURIComponent(localStorage.getItem('enfantClasse')));
        var edt = await r.json();
        var jours = ['Lundi','Mardi','Mercredi','Jeudi','Vendredi','Samedi'];
        var plages = [{d:'07:00',f:'08:00'},{d:'08:00',f:'09:00'},{d:'09:00',f:'10:00'},{d:'10:00',f:'11:00'},{d:'11:00',f:'12:00'},{d:'12:00',f:'13:00'},{d:'13:00',f:'14:00'},{d:'14:00',f:'15:00'},{d:'15:00',f:'16:00'},{d:'16:00',f:'17:00'},{d:'17:00',f:'18:00'}];
        var html = '<div style="overflow-x:auto;"><div class="edt-grid"><div class="edt-header">Heure</div>';
        jours.forEach(function(j) { html += '<div class="edt-header">' + j + '</div>'; });
        plages.forEach(function(p) {
            html += '<div class="edt-time"><span>' + p.d + '</span><span>' + p.f + '</span></div>';
            jours.forEach(function(j) {
                var cours = edt.filter(function(e) { return e.jour === j && e.heure_debut >= p.d + ':00' && e.heure_debut < p.f + ':00'; });
                html += '<div class="edt-cell">';
                if (cours.length > 0) cours.forEach(function(c) { html += '<div class="edt-cours"><strong>' + c.matiere + '</strong><br><small>' + (c.salle||'') + ' ' + (c.prof_nom||'') + '</small></div>'; });
                else html += '<div style="display:flex;align-items:center;justify-content:center;color:#ccc;height:100%;">-</div>';
                html += '</div>';
            });
        });
        html += '</div></div>';
        document.getElementById('edtContent').innerHTML = edt.length ? html : '<p style="color:#888;">Aucun cours</p>';
    }

    async function loadRessources() {
    var classe = localStorage.getItem('enfantClasse');
    if (!classe) return;
    document.getElementById('ressourcesEnfantNom').textContent = classe;
    
    var r = await fetch('/parent/api/ressources?classe=' + encodeURIComponent(classe));
    var ressources = await r.json();
    document.getElementById('ressourcesContent').innerHTML = ressources.length ? ressources.map(function(rs) {
        var isExercice = rs.type === 'exercice';
        var dateLimiteDepassee = rs.date_limite && new Date(rs.date_limite) < new Date();
        return '<div class="ressource-card">' +
            '<div style="display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:10px;">' +
            '<div><strong>' + rs.titre + '</strong> <span class="badge badge-info">' + rs.type + '</span>' +
            '<br><small>Par: ' + (rs.prof_nom || '') + ' ' + (rs.prof_prenom || '') + ' | ' + (rs.matiere || '') + '</small>' +
            (rs.date_limite ? '<br><small style="color:' + (dateLimiteDepassee ? '#e74c3c' : '#f39c12') + ';">⏰ Limite: ' + rs.date_limite + '</small>' : '') + '</div>' +
            '<div style="display:flex;gap:6px;">' +
            (rs.fichier ? '<a href="/uploads/' + rs.fichier + '" target="_blank" class="btn btn-sm btn-primary"><svg viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/></svg> Télécharger</a>' : '') +
            (isExercice ? '<button class="btn btn-sm btn-success" onclick="openRendreDevoir(' + rs.id + ', \'' + rs.titre.replace(/'/g, "\\'") + '\')"><svg viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2"><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg> Rendre</button>' : '') +
            '</div></div></div>';
    }).join('') : '<p style="color:#888;">Aucune ressource</p>';
}

function openRendreDevoir(id, titre) {
    document.getElementById('rendreRessourceId').value = id;
    document.getElementById('rendreDevoirTitre').textContent = titre;
    document.getElementById('rendreFichier').value = '';
    document.getElementById('rendreFileName').textContent = '';
    document.getElementById('rendreDevoirModal').classList.add('active');
}

async function renvoyerDevoir(e) {
    e.preventDefault();
    var formData = new FormData();
    formData.append('ressource_id', document.getElementById('rendreRessourceId').value);
    formData.append('enfant_nom', localStorage.getItem('enfantNom') || '');
    formData.append('enfant_prenom', localStorage.getItem('enfantPrenom') || '');
    var fichier = document.getElementById('rendreFichier').files[0];
    if (fichier) formData.append('fichier', fichier);
    
    var r = await fetch('/parent/api/rendre-devoir', { method: 'POST', body: formData });
    var j = await r.json();
    showToast(j.message || j.error, r.ok ? 'success' : 'error');
    if (r.ok) { closeModal('rendreDevoirModal'); loadRessources(); }
}

