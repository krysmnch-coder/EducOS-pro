    <div class="table-container"><table class="data-table"><thead><tr><th>Date</th><th>Élève</th><th>Type</th><th>Motif</th><th>Gravité</th><th>Act.</th></tr></thead><tbody id="sanctionsBody"></tbody></table></div>
</div>

