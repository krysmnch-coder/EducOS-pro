<div class="form-row"><div class="form-group"><label>Type</label><select id="absType" class="form-control"><option value="absence">Absence</option><option value="retard">Retard</option></select></div><div class="form-group"><label>Date</label><input type="date" id="absDate" class="form-control" required></div></div>
<div class="form-row"><div class="form-group"><label>Motif</label><input type="text" id="absMotif" class="form-control"></div><div class="form-group"><label>Durée (min)</label><input type="number" id="absDuree" class="form-control" value="0"></div></div>
<div class="form-group"><label><input type="checkbox" id="absJustifie"> Justifié</label></div>
<button class="btn btn-primary" style="width:100%;">Enregistrer</button></form></div></div>

<div class="modal" id="edtModal"><div class="modal-content"><div class="modal-header"><h3>Ajouter cours</h3><button class="close-modal" onclick="closeModal('edtModal')">✕</button></div>
<form onsubmit="saveEDT(event)"><input type="hidden" id="edtId">
<div class="form-row"><div class="form-group"><label>Classe</label><input type="text" id="edtClasse" class="form-control" required></div><div class="form-group"><label>Jour</label><select id="edtJour" class="form-control"><option>Lundi</option><option>Mardi</option><option>Mercredi</option><option>Jeudi</option><option>Vendredi</option><option>Samedi</option></select></div></div>
<div class="form-row"><div class="form-group"><label>Début</label><input type="time" id="edtDebut" class="form-control" required></div><div class="form-group"><label>Fin</label><input type="time" id="edtFin" class="form-control" required></div></div>
<div class="form-row"><div class="form-group"><label>Matière</label><input type="text" id="edtMatiere" class="form-control" required></div><div class="form-group"><label>Salle</label><input type="text" id="edtSalle" class="form-control"></div></div>
<div class="form-group"><label>Professeur</label><select id="edtProfId" class="form-control"></select></div>
<button class="btn btn-primary" style="width:100%;">Enregistrer</button></form></div></div>

<div class="modal" id="sanctionModal"><div class="modal-content"><div class="modal-header"><h3>Sanction</h3><button class="close-modal" onclick="closeModal('sanctionModal')">✕</button></div>
<form onsubmit="saveSanction(event)"><div class="form-group"><label>Élève</label><select id="sancEleveId" class="form-control" required></select></div>
<div class="form-row"><div class="form-group"><label>Type</label><select id="sancType" class="form-control"><option value="avertissement">Avertissement</option><option value="blame">Blâme</option><option value="retenue">Retenue</option><option value="exclusion_temporaire">Exclusion temp.</option></select></div><div class="form-group"><label>Gravité</label><select id="sancGravite" class="form-control"><option value="legere">Légère</option><option value="moyenne">Moyenne</option><option value="grave">Grave</option><option value="tres_grave">Très grave</option></select></div></div>
<div class="form-group"><label>Motif</label><input type="text" id="sancMotif" class="form-control" required></div>
<div class="form-row"><div class="form-group"><label>Durée</label><input type="text" id="sancDuree" class="form-control"></div><div class="form-group"><label><input type="checkbox" id="sancNotifie"> Parents notifiés</label></div></div>
<button class="btn btn-primary" style="width:100%;">Enregistrer</button></form></div></div>

<div class="toast" id="toast"></div>

<script>
function showTab(t) {
    document.querySelectorAll('.tab-content').forEach(c => c.classList.remove('active'));
    document.querySelectorAll('.tab').forEach(b => b.classList.remove('active'));
    document.getElementById('tab-'+t).classList.add('active');
    event.target.classList.add('active');
    if(t==='edt') loadEDT();
    if(t==='pointage') { loadPointages(); loadCumul(); }
    if(t==='messages') { loadMessagesVS(); loadUsersForMsgVS(); }
}

async function loadStats() {
    const r = await fetch('/vie-scolaire/api/stats');
    const s = await r.json();
    document.getElementById('absAujourdhui').textContent = s.absencesAujourdhui||0;
    document.getElementById('retAujourdhui').textContent = s.retardsAujourdhui||0;
    document.getElementById('profsPresents').textContent = s.profsPresents||0;
    document.getElementById('sanctionsMois').textContent = s.sanctionsMois||0;
}

// Absences
async function loadAbsences(p=1) {
    const params = new URLSearchParams({page:p, type:document.getElementById('filtreTypeAbsence').value, search:document.getElementById('searchAbsence').value, justifie:document.getElementById('filtreJustifie').value});
    const r = await fetch('/vie-scolaire/api/absences?'+params);
    const d = await r.json();
    document.getElementById('absencesBody').innerHTML = d.absences?.length ? d.absences.map(a => `<tr><td>${a.date_absence}</td><td>${a.nom} ${a.prenom}</td><td>${a.type}</td><td>${a.motif}</td><td>${a.justifie?'✅':'❌'}</td><td><button class="btn btn-sm btn-danger" onclick="deleteAbsence(${a.id})">🗑️</button></td></tr>`).join('') : '<tr><td colspan="6">Aucune</td></tr>';
    let pag = ''; for(let i=1; i<=d.pagination.totalPages; i++) pag += `<button class="${i===p?'active':''}" onclick="loadAbsences(${i})">${i}</button>`;
    document.getElementById('paginationAbsences').innerHTML = pag;
}
async function saveAbsence(e) {
    e.preventDefault();
    const data = {eleve_id:document.getElementById('absEleveId').value, date_absence:document.getElementById('absDate').value, type:document.getElementById('absType').value, motif:document.getElementById('absMotif').value, justifie:document.getElementById('absJustifie').checked?1:0, duree_minutes:document.getElementById('absDuree').value};
    const r = await fetch('/vie-scolaire/api/absences', {method:'POST', headers:{'Content-Type':'application/json'}, body:JSON.stringify(data)});
    const j = await r.json();
    showToast(j.message||j.error, r.ok?'success':'error');
    if(r.ok) { closeModal('absenceModal'); loadAbsences(); loadStats(); }
}
async function deleteAbsence(id) { if(!confirm('Supprimer ?')) return; await fetch(`/vie-scolaire/api/absences/${id}`, {method:'DELETE'}); loadAbsences(); loadStats(); }

// EDT
async function loadEDT() {
    const classe = document.getElementById('filtreClasseEDT').value, jour = document.getElementById('filtreJourEDT').value;
    const r = await fetch(`/vie-scolaire/api/edt?classe=${classe}&jour=${jour}`);
    const edt = await r.json();
    const jours = ['Lundi','Mardi','Mercredi','Jeudi','Vendredi','Samedi'];
    const plages = [{d:'07:00',f:'08:00'},{d:'08:00',f:'09:00'},{d:'09:00',f:'10:00'},{d:'10:00',f:'11:00'},{d:'11:00',f:'12:00'},{d:'12:00',f:'13:00'},{d:'13:00',f:'14:00'},{d:'14:00',f:'15:00'},{d:'15:00',f:'16:00'},{d:'16:00',f:'17:00'},{d:'17:00',f:'18:00'}];
    let html = '<div class="edt-header">Heure</div>';
    jours.forEach(j => html += `<div class="edt-header">${j}</div>`);
    plages.forEach(p => {
        html += `<div class="edt-time"><span>${p.d}</span><span>${p.f}</span></div>`;
        jours.forEach(j => {
            const cours = edt.filter(e => e.jour===j && e.heure_debut >= p.d+':00' && e.heure_debut < p.f+':00');
            html += `<div class="edt-cell">${cours.map(c => `<div class="edt-cours"><strong>${c.matiere}</strong> ${c.classe||''}<br><small>${c.salle||''} ${c.prof_nom||''}</small><span class="delete-cours" onclick="event.stopPropagation();deleteEDT(${c.id})">✕</span></div>`).join('')}<button class="edt-add-btn" onclick="event.stopPropagation();quickAddEDT('${j}','${p.d}','${classe||''}')">+</button></div>`;
        });
    });
    document.getElementById('edtGrid').innerHTML = html;
}
function quickAddEDT(jour, debut, classe) {
    document.getElementById('edtClasse').value = classe||'';
    document.getElementById('edtJour').value = jour;
    document.getElementById('edtDebut').value = debut+':00';
    document.getElementById('edtFin').value = (parseInt(debut)+1).toString().padStart(2,'0')+':00';
    openModal('edtModal');
}
async function saveEDT(e) {
    e.preventDefault();
    const data = {classe:document.getElementById('edtClasse').value, jour:document.getElementById('edtJour').value, heure_debut:document.getElementById('edtDebut').value, heure_fin:document.getElementById('edtFin').value, matiere:document.getElementById('edtMatiere').value, prof_id:document.getElementById('edtProfId').value||null, salle:document.getElementById('edtSalle').value};
    const r = await fetch('/vie-scolaire/api/edt', {method:'POST', headers:{'Content-Type':'application/json'}, body:JSON.stringify(data)});
    const j = await r.json();
    showToast(j.message||j.error, r.ok?'success':'error');
    if(r.ok) { closeModal('edtModal'); loadEDT(); }
}
async function deleteEDT(id) { if(!confirm('Supprimer ?')) return; await fetch(`/vie-scolaire/api/edt/${id}`, {method:'DELETE'}); loadEDT(); }

// Pointage
async function loadPointages() {
    const date = document.getElementById('pointageDate').value || new Date().toISOString().split('T')[0];
    document.getElementById('datePointage').textContent = new Date(date).toLocaleDateString('fr-FR', {weekday:'long', day:'numeric', month:'long'});
    const r = await fetch(`/vie-scolaire/api/pointages?date=${date}`);
    const d = await r.json();
    let html = (d.pointages||[]).map(p => `
        <div class="pointage-row ${p.statut}">
            <div style="flex:1;"><strong>${p.nom} ${p.prenom}</strong></div>
            <select onchange="updateContrat(${p.prof_id},this.value,'${date}')" style="width:130px;"><option value="plein_temps" ${p.type_contrat==='plein_temps'?'selected':''}>Plein temps</option><option value="charge_cours" ${p.type_contrat==='charge_cours'?'selected':''}>Chargé cours</option></select>
            <select onchange="updateStatut(${p.prof_id},this.value,'${date}')" style="width:110px;"><option value="present" ${p.statut==='present'||p.statut==='sortie'?'selected':''}>Présent</option><option value="retard" ${p.statut==='retard'?'selected':''}>Retard</option><option value="absent" ${p.statut==='absent'?'selected':''}>Absent</option></select>
            <input type="time" value="${p.heure_arrivee||''}" onchange="updateArrivee(${p.prof_id},this.value,'${date}')" placeholder="Arrivée">
            <input type="time" value="${p.heure_depart||''}" onchange="updateDepart(${p.prof_id},this.value,'${date}')" placeholder="Départ">
            <span class="badge badge-${p.statut==='present'||p.statut==='sortie'?'success':p.statut==='retard'?'warning':'danger'}">${p.statut}</span>
        </div>`).join('');
    html += '<h4 style="margin-top:16px;">Non pointés</h4>';
    html += (d.nonPointes||[]).map(np => `<div class="pointage-row absent"><div style="flex:1;"><strong>${np.nom} ${np.prenom}</strong></div><select onchange="updateContrat(${np.id},this.value,'${date}')" style="width:130px;"><option value="plein_temps">Plein temps</option><option value="charge_cours">Chargé cours</option></select><select onchange="updateStatut(${np.id},this.value,'${date}')" style="width:110px;"><option value="absent" selected>Absent</option><option value="present">Présent</option><option value="retard">Retard</option></select><input type="time" onchange="updateArrivee(${np.id},this.value,'${date}')" placeholder="Arrivée"><input type="time" onchange="updateDepart(${np.id},this.value,'${date}')" placeholder="Départ"><span class="badge badge-danger">absent</span></div>`).join('');
    document.getElementById('pointageList').innerHTML = html;
}
async function updateContrat(pid, c, d) { await fetch('/vie-scolaire/api/pointer-arrivee', {method:'POST', headers:{'Content-Type':'application/json'}, body:JSON.stringify({prof_id:pid, type_contrat:c, date:d})}); loadPointages(); loadCumul(); }
async function updateStatut(pid, s, d) { await fetch('/vie-scolaire/api/pointer-arrivee', {method:'POST', headers:{'Content-Type':'application/json'}, body:JSON.stringify({prof_id:pid, statut:s, date:d})}); loadPointages(); loadStats(); loadCumul(); }
async function updateArrivee(pid, h, d) { await fetch('/vie-scolaire/api/pointer-arrivee', {method:'POST', headers:{'Content-Type':'application/json'}, body:JSON.stringify({prof_id:pid, heure_arrivee:h||null, date:d})}); loadPointages(); loadStats(); loadCumul(); }
async function updateDepart(pid, h, d) { await fetch('/vie-scolaire/api/pointer-depart', {method:'POST', headers:{'Content-Type':'application/json'}, body:JSON.stringify({prof_id:pid, heure_depart:h||null, date:d})}); loadPointages(); loadCumul(); }
async function loadCumul() {
    const mois = document.getElementById('cumulMois').value || new Date().toISOString().substring(0,7);
    const r = await fetch(`/vie-scolaire/api/cumul-pointages?mois=${mois}`);
    const rows = await r.json();
    document.getElementById('cumulBody').innerHTML = rows.length ? rows.map(r => {
        const isPT = r.type_contrat === 'plein_temps';
        return `<tr><td>${r.nom} ${r.prenom}</td><td><span class="badge badge-${isPT?'info':'warning'}">${isPT?'Plein temps':'Chargé cours'}</span></td><td>${r.jours_pointes||0}</td><td>${r.jours_presents||0}</td><td>${r.jours_retard||0}</td><td>${r.jours_absents||0}</td><td><strong>${isPT ? (r.jours_presents||0)+' jours' : Number(r.total_heures||0).toFixed(1)+' h'}</strong></td></tr>`;
    }).join('') : '<tr><td colspan="7">Aucune</td></tr>';
}

// Sanctions
async function loadSanctions() {
    const r = await fetch('/vie-scolaire/api/sanctions');
    const d = await r.json();
    document.getElementById('sanctionsBody').innerHTML = d.sanctions?.length ? d.sanctions.map(s => `<tr><td>${s.date_sanction}</td><td>${s.nom} ${s.prenom}</td><td>${s.type_sanction}</td><td>${s.motif}</td><td><span class="badge" style="background:${s.gravite==='tres_grave'||s.gravite==='grave'?'#e74c3c':'#f39c12'};color:white;">${s.gravite}</span></td><td><button class="btn btn-sm btn-danger" onclick="deleteSanction(${s.id})">🗑️</button></td></tr>`).join('') : '<tr><td colspan="6">Aucune</td></tr>';
}
async function saveSanction(e) {
    e.preventDefault();
    const data = {eleve_id:document.getElementById('sancEleveId').value, type_sanction:document.getElementById('sancType').value, motif:document.getElementById('sancMotif').value, gravite:document.getElementById('sancGravite').value, duree:document.getElementById('sancDuree').value, notifie_parent:document.getElementById('sancNotifie').checked?1:0};
    const r = await fetch('/vie-scolaire/api/sanctions', {method:'POST', headers:{'Content-Type':'application/json'}, body:JSON.stringify(data)});
    const j = await r.json();
    showToast(j.message||j.error, r.ok?'success':'error');
    if(r.ok) { closeModal('sanctionModal'); loadSanctions(); loadStats(); }
}
async function deleteSanction(id) { if(!confirm('Supprimer ?')) return; await fetch(`/vie-scolaire/api/sanctions/${id}`, {method:'DELETE'}); loadSanctions(); loadStats(); }

// Messages VS
async function loadMessagesVS() {
    const r = await fetch('/vie-scolaire/api/messages');
    const msgs = await r.json();
    document.getElementById('messagesListVS').innerHTML = msgs.length ? msgs.map(m => `<div class="message-item ${m.lu?'':'non-lu'}"><strong>${m.sujet}</strong><br><small>De: ${m.exp_nom} ${m.exp_prenom} • ${new Date(m.created_at).toLocaleString('fr-FR')}</small></div>`).join('') : '<p>Aucun</p>';
}
async function loadUsersForMsgVS() {
    const r = await fetch('/vie-scolaire/api/eleves');
    const u = await r.json();
    document.getElementById('msgUserIdVS').innerHTML = u.map(x => `<option value="${x.id}">${x.nom} ${x.prenom}</option>`).join('');
}
function toggleDestVS() {
    const t = document.getElementById('msgDestVS').value;
    document.getElementById('msgRoleGrpVS').style.display = t==='role'?'block':'none';
    document.getElementById('msgUserGrpVS').style.display = t==='user'?'block':'none';
}
async function sendMsgVS(e) {
    e.preventDefault();
    const t = document.getElementById('msgDestVS').value;
    const data = {sujet:document.getElementById('msgSujetVS').value, contenu:document.getElementById('msgContenuVS').value};
    if(t==='role') data.destinataire_role = document.getElementById('msgRoleVS').value;
    else if(t==='user') data.destinataire_id = document.getElementById('msgUserIdVS').value;
    else data.destinataire_role = 'all';
    const r = await fetch('/vie-scolaire/api/messages', {method:'POST', headers:{'Content-Type':'application/json'}, body:JSON.stringify(data)});
    const j = await r.json();
    showToast(j.message||j.error, r.ok?'success':'error');
    if(r.ok) { document.getElementById('msgFormVS').reset(); loadMessagesVS(); }
}

// Helpers
function openModal(id) { document.getElementById(id).classList.add('active'); }
function closeModal(id) { document.getElementById(id).classList.remove('active'); }
function showToast(msg, type) { const t = document.getElementById('toast'); t.textContent = msg; t.className = `toast ${type}`; t.style.display = 'block'; setTimeout(() => t.style.display = 'none', 3000); }

// Init
loadStats(); loadAbsences(); loadSanctions();
document.getElementById('pointageDate').value = document.getElementById('absDate').value = new Date().toISOString().split('T')[0];
document.getElementById('cumulMois').value = new Date().toISOString().substring(0,7);
fetch('/vie-scolaire/api/eleves').then(r=>r.json()).then(e => { const o = e.map(x=>`<option value="${x.id}">${x.nom} ${x.prenom}</option>`).join(''); document.getElementById('absEleveId').innerHTML = o; document.getElementById('sancEleveId').innerHTML = o; });
fetch('/vie-scolaire/api/profs').then(r=>r.json()).then(p => { document.getElementById('edtProfId').innerHTML = '<option value="">Aucun</option>' + p.map(x=>`<option value="${x.id}">${x.nom} ${x.prenom}</option>`).join(''); });
fetch('/vie-scolaire/api/classes').then(r=>r.json()).then(c => { document.getElementById('filtreClasseEDT').innerHTML = '<option value="">Toutes</option>' + c.map(x=>`<option>${x.classe}</option>`).join(''); });
</script>

