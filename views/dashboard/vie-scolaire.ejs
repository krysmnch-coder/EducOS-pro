<%- include('../partials/header-vs') %>

<style>
    .tabs { display: flex; gap: 4px; margin-bottom: 20px; flex-wrap: wrap; background: #f5f5f5; padding: 4px; border-radius: 12px; }
    .tab { padding: 10px 15px; border: none; background: transparent; cursor: pointer; border-radius: 10px; font-weight: 600; font-size: 0.8rem; transition: all 0.2s; font-family: 'Inter', sans-serif; white-space: nowrap; display: flex; align-items: center; gap: 6px; color: #444; }
    .tab svg { stroke: #444; }
    .tab.active { background: #002FA7; color: white; }
    .tab.active svg { stroke: white; }
    .tab:hover:not(.active) { background: #e0e0e0; }
    .tab-content { display: none; }
    .tab-content.active { display: block; }
    .edt-grid { display: grid; grid-template-columns: 100px repeat(6, 1fr); gap: 2px; background: #e0e0e0; border-radius: 12px; overflow-x: auto; font-size: 0.75rem; min-width: 700px; }
    .edt-cell { background: white; padding: 6px; min-height: 60px; position: relative; }
    .edt-header { background: #002FA7; color: white; font-weight: 700; text-align: center; padding: 10px 4px; font-size: 0.78rem; }
    .edt-time { background: #f8f9fa; font-weight: 600; text-align: center; display: flex; align-items: center; justify-content: center; color: #555; font-size: 0.7rem; flex-direction: column; }
    .edt-cours { background: #f0f4ff; border-left: 3px solid #002FA7; padding: 5px 6px; border-radius: 4px; margin: 2px 0; font-size: 0.68rem; position: relative; }
    .edt-cours .delete-cours { position: absolute; top: 2px; right: 4px; cursor: pointer; color: #e74c3c; font-weight: 700; font-size: 14px; display: none; z-index: 5; }
    .edt-cours:hover .delete-cours { display: block; }
    .edt-add-btn { position: absolute; bottom: 2px; right: 2px; background: #27ae60; color: white; border: none; border-radius: 50%; width: 20px; height: 20px; font-size: 14px; cursor: pointer; display: flex; align-items: center; justify-content: center; opacity: 0; transition: opacity 0.2s; }
    .edt-cell:hover .edt-add-btn { opacity: 1; }
    .pointage-row { display: flex; align-items: center; gap: 10px; padding: 10px 14px; border: 1px solid #e8e8e8; border-radius: 10px; margin-bottom: 6px; flex-wrap: wrap; }
    .pointage-row.present { border-left: 4px solid #27ae60; }
    .pointage-row.absent { border-left: 4px solid #e74c3c; }
    .pointage-row.retard { border-left: 4px solid #f39c12; }
    .pointage-row select, .pointage-row input[type="time"] { padding: 6px 8px; border: 1px solid #ddd; border-radius: 6px; font-size: 0.8rem; width: 120px; }
    .messages-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; }
    .message-card { background: white; border-radius: 14px; padding: 20px; box-shadow: 0 1px 6px rgba(0,0,0,0.04); }
    .message-item { padding: 12px 14px; border: 1px solid #e8e8e8; border-radius: 10px; margin-bottom: 8px; }
    .message-item.non-lu { border-left: 3px solid #002FA7; background: #f8f9ff; }
    .btn { padding: 8px 16px; border: none; border-radius: 8px; cursor: pointer; font-size: 0.85rem; font-weight: 600; font-family: 'Inter', sans-serif; }
    .btn-primary { background: #002FA7; color: white; }
    .btn-danger { background: #e74c3c; color: white; }
    .btn-sm { padding: 5px 10px; font-size: 0.73rem; }
    .modal { display: none; position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0,0,0,0.5); z-index: 2000; align-items: center; justify-content: center; padding: 20px; }
    .modal.active { display: flex; }
    .modal-content { background: white; border-radius: 16px; padding: 24px; width: 100%; max-width: 500px; max-height: 80vh; overflow-y: auto; }
    .modal-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px; }
    .close-modal { background: none; border: none; font-size: 1.4rem; cursor: pointer; }
    .form-group { margin-bottom: 14px; }
    .form-group label { display: block; margin-bottom: 5px; font-weight: 600; font-size: 0.85rem; }
    .form-control { width: 100%; padding: 9px 12px; border: 2px solid #e0e0e0; border-radius: 8px; font-size: 0.88rem; }
    .form-row { display: flex; gap: 12px; }
    .form-row .form-group { flex: 1; }
    .badge { padding: 4px 10px; border-radius: 20px; font-size: 0.72rem; font-weight: 600; }
    .badge-success { background: #d4edda; color: #155724; }
    .badge-danger { background: #f8d7da; color: #721c24; }
    .badge-warning { background: #fff3cd; color: #856404; }
    .badge-info { background: #d1ecf1; color: #0c5460; }
    .pagination { display: flex; gap: 6px; justify-content: center; margin-top: 16px; }
    .pagination button { padding: 7px 12px; border: 1px solid #e0e0e0; background: white; border-radius: 6px; cursor: pointer; }
    .pagination button.active { background: #002FA7; color: white; border-color: #002FA7; }
    .toast { position: fixed; top: 20px; right: 20px; padding: 14px 20px; border-radius: 10px; color: white; font-weight: 600; z-index: 3000; display: none; }
    .toast.success { background: #27ae60; }
    .toast.error { background: #e74c3c; }
    .search-bar { display: flex; gap: 10px; margin-bottom: 16px; flex-wrap: wrap; }
    .search-bar input, .search-bar select { padding: 9px 12px; border: 2px solid #e0e0e0; border-radius: 8px; font-size: 0.88rem; }
    .search-bar input { flex: 1; min-width: 180px; }
    @media (max-width: 768px) {
        .edt-grid { font-size: 0.6rem; grid-template-columns: 60px repeat(6, 1fr); min-width: 500px; }
        .messages-grid { grid-template-columns: 1fr; }
    }
</style>

<div class="stats-grid">
    <div class="stat-card"><div class="stat-icon" style="background:#fee;"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#e74c3c" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="4.93" y1="4.93" x2="19.07" y2="19.07"/></svg></div><div class="stat-info"><span class="stat-value" id="absAujourdhui">0</span><span class="stat-label">Absences</span></div></div>
    <div class="stat-card"><div class="stat-icon" style="background:#fff3cd;"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#f39c12" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg></div><div class="stat-info"><span class="stat-value" id="retAujourdhui">0</span><span class="stat-label">Retards</span></div></div>
    <div class="stat-card"><div class="stat-icon" style="background:#d4edda;"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#27ae60" stroke-width="2"><path d="M16 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="8.5" cy="7" r="4"/></svg></div><div class="stat-info"><span class="stat-value" id="profsPresents">0</span><span class="stat-label">Profs présents</span></div></div>
    <div class="stat-card"><div class="stat-icon" style="background:#f8d7da;"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#e74c3c" stroke-width="2"><polygon points="7.86 2 16.14 2 22 7.86 22 16.14 16.14 22 7.86 22 2 16.14 2 7.86 7.86 2"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg></div><div class="stat-info"><span class="stat-value" id="sanctionsMois">0</span><span class="stat-label">Sanctions</span></div></div>
</div>

