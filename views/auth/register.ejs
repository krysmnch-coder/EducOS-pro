<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link rel="stylesheet" href="/css/style.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <style>
        :root {
            --bleu-klein: #002FA7;
            --noir: #1a1a1a;
            --gris: #666666;
            --gris-clair: #999999;
            --gris-tres-clair: #e0e0e0;
            --gris-background: #f8f9fa;
            --blanc: #ffffff;
            --rouge: #e74c3c;
            --rouge-clair: #fee;
            --vert: #27ae60;
            --vert-clair: #efe;
            --border-radius: 12px;
            --border-radius-sm: 8px;
            --shadow: 0 4px 24px rgba(0,0,0,0.08);
            --transition: all 0.3s ease;
        }

        * { margin: 0; padding: 0; box-sizing: border-box; }

        body {
            font-family: 'Inter', 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background-color: #f0f2f5;
            color: var(--noir);
            line-height: 1.5;
        }

        .auth-wrapper {
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 20px;
        }

        .auth-container {
            background: var(--blanc);
            border-radius: 20px;
            box-shadow: var(--shadow);
            width: 100%;
            max-width: 500px;
            padding: 40px;
        }

        .auth-logo {
            text-align: center;
            margin-bottom: 24px;
        }

        .auth-logo h1 {
            font-size: 2rem;
            font-weight: 700;
            color: var(--bleu-klein);
        }

        .auth-logo h1 span {
            font-weight: 300;
            color: var(--gris-clair);
        }

        .auth-form-container h2 {
            font-size: 1.4rem;
            font-weight: 700;
            margin-bottom: 4px;
            text-align: center;
        }

        .subtitle {
            color: var(--gris);
            margin-bottom: 20px;
            font-size: 0.85rem;
            text-align: center;
        }

        .alert {
            display: flex;
            align-items: center;
            gap: 8px;
            padding: 10px 12px;
            border-radius: var(--border-radius-sm);
            margin-bottom: 16px;
            font-size: 0.82rem;
            font-weight: 500;
        }

        .alert-danger { background-color: var(--rouge-clair); color: var(--rouge); border: 1px solid #fcc; }

        .form-group {
            margin-bottom: 14px;
        }

        .form-group label {
            display: block;
            margin-bottom: 5px;
            font-weight: 600;
            font-size: 0.82rem;
            color: #333;
        }

        .form-control {
            width: 100%;
            padding: 10px 14px;
            border: 2px solid var(--gris-tres-clair);
            border-radius: var(--border-radius-sm);
            font-size: 0.88rem;
            font-family: 'Inter', sans-serif;
            background: var(--gris-background);
            transition: var(--transition);
            outline: none;
        }

        .form-control:focus {
            border-color: var(--bleu-klein);
            background: var(--blanc);
            box-shadow: 0 0 0 3px rgba(0,47,167,0.1);
        }

        select.form-control {
            appearance: none;
            background-image: url("data:image/svg+xml;charset=UTF-8,%3csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='none' stroke='%23999999' stroke-width='2'%3e%3cpolyline points='6 9 12 15 18 9'%3e%3c/polyline%3e%3c/svg%3e");
            background-repeat: no-repeat;
            background-position: right 12px center;
            background-size: 16px;
            padding-right: 36px;
            cursor: pointer;
        }

        .form-row {
            display: flex;
            gap: 10px;
        }

        .form-row .form-group {
            flex: 1;
        }

        .dynamic-fields {
            background: var(--gris-background);
            border-radius: var(--border-radius-sm);
            padding: 14px;
            margin-top: 6px;
            border: 1px dashed #d0d0d0;
        }

        .help-text {
            font-size: 0.72rem;
            color: var(--gris-clair);
            margin-top: 4px;
        }

        .btn {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
            padding: 12px 24px;
            border: none;
            border-radius: var(--border-radius-sm);
            font-size: 0.9rem;
            font-weight: 600;
            cursor: pointer;
            transition: var(--transition);
            font-family: 'Inter', sans-serif;
            width: 100%;
        }

        .btn-primary {
            background-color: var(--bleu-klein);
            color: var(--blanc);
        }

        .btn-primary:hover {
            background-color: #003fd6;
            box-shadow: 0 4px 16px rgba(0,47,167,0.2);
        }

        .btn-add-child {
            background: none;
            border: 1px dashed var(--bleu-klein);
            color: var(--bleu-klein);
            padding: 6px 14px;
            border-radius: 6px;
            cursor: pointer;
            font-size: 0.8rem;
            font-weight: 600;
            font-family: 'Inter', sans-serif;
            margin-top: 8px;
        }

        .auth-link {
            text-align: center;
            margin-top: 20px;
            color: var(--gris);
            font-size: 0.85rem;
        }

        .auth-link a {
            color: var(--bleu-klein);
            text-decoration: none;
            font-weight: 700;
        }

        .auth-link a:hover {
            text-decoration: underline;
        }

        @media (max-width: 500px) {
            .auth-container { padding: 24px 18px; }
            .form-row { flex-direction: column; gap: 0; }
        }
    </style>
</head>
<body>
    <div class="auth-wrapper">
        <div class="auth-container">
            <div class="auth-logo">
                <h1>EducOS<span>-pro</span></h1>
            </div>

            <div class="auth-form-container">
                <h2>Inscription</h2>
                <p class="subtitle">Créez votre compte</p>

                <% if (locals.error) { %>
                    <div class="alert alert-danger">
                        <span>⚠️ <%= error %></span>
                    </div>
                <% } %>

                <form action="/auth/register" method="POST" id="registerForm">
                    <div class="form-row">
                        <div class="form-group">
                            <label for="nom">Nom *</label>
                            <input type="text" id="nom" name="nom" class="form-control" required placeholder="Dupont">
                        </div>
                        <div class="form-group">
                            <label for="prenom">Prénom *</label>
                            <input type="text" id="prenom" name="prenom" class="form-control" required placeholder="Jean">
                        </div>
                    </div>

                    <div class="form-group">
                        <label for="email">Email *</label>
                        <input type="email" id="email" name="email" class="form-control" required placeholder="votre@email.com">
                    </div>

                    <div class="form-group">
                        <label for="role">Rôle *</label>
                        <select id="role" name="role" class="form-control" required onchange="showDynamicFields()">
                            <option value="">Choisissez votre profil</option>
                            <option value="admin">👑 Administrateur</option>
                            <option value="vie_scolaire">📋 Vie Scolaire</option>
                            <option value="prof">👨‍🏫 Professeur</option>
                            <option value="parent">👪 Parent</option>
                            <option value="eleve">🎓 Élève</option>
                        </select>
                    </div>

                    <!-- Champs école -->
                    <div id="ecoleFields" style="display:none;">
                        <div class="form-group">
                            <label for="nom_ecole">Nom de l'école *</label>
                            <input type="text" id="nom_ecole" name="nom_ecole" class="form-control" placeholder="Ex: JeanDupont (sans Collège/Lycée)">
                        </div>
                        <div class="form-group" id="codeField" style="display:none;">
                            <label for="code_etablissement">Code établissement *</label>
                            <input type="text" id="code_etablissement" name="code_etablissement" class="form-control" placeholder="ETAB_XXXXX" readonly>
                            <div class="help-text">Code généré automatiquement à partir du nom de l'école</div>
                        </div>
                    </div>

                    <!-- Champs dynamiques -->
                    <div id="dynamicFields" style="display:none;"></div>

                    <div class="form-group">
                        <label for="password">Mot de passe *</label>
                        <input type="password" id="password" name="password" class="form-control" required placeholder="Minimum 8 caractères" minlength="8">
                    </div>

                    <div class="form-group">
                        <label for="confirm_password">Confirmer le mot de passe *</label>
                        <input type="password" id="confirm_password" name="confirm_password" class="form-control" required placeholder="Répétez le mot de passe" minlength="8">
                    </div>

                    <button type="submit" class="btn btn-primary">Créer mon compte</button>
                </form>

                <p class="auth-link">Déjà un compte ? <a href="/auth/login">Se connecter</a></p>
            </div>
        </div>
    </div>

    <script>
        function showDynamicFields() {
            var role = document.getElementById('role').value;
            var container = document.getElementById('dynamicFields');
            var ecoleFields = document.getElementById('ecoleFields');
            var codeField = document.getElementById('codeField');
            var nomEcole = document.getElementById('nom_ecole');
            var html = '';

            // Afficher les champs école
            ecoleFields.style.display = 'block';

            if (role === 'admin') {
                codeField.style.display = 'none';
                nomEcole.required = true;
                container.style.display = 'none';
            } else if (role === 'prof') {
                codeField.style.display = 'block';
                document.getElementById('code_etablissement').required = true;
                nomEcole.required = true;
                html = '<div class="dynamic-fields">' +
                    '<div class="form-group"><label>Matière principale *</label>' +
                    '<select id="matiere_principale" name="matiere_principale" class="form-control" required>' +
                    '<option value="">Choisissez</option>' +
                    '<option>Mathématiques</option><option>Français</option><option>Histoire-Géographie</option>' +
                    '<option>SVT</option><option>Physique-Chimie</option><option>Anglais</option>' +
                    '<option>Espagnol</option><option>Allemand</option><option>Philosophie</option>' +
                    '<option>EPS</option><option>Arts Plastiques</option><option>Musique</option>' +
                    '<option>Informatique</option><option>Économie</option><option>Autre</option>' +
                    '</select></div>' +
                    '<div class="form-group"><label>Classes assignées</label>' +
                    '<input type="text" name="classes_assignees" class="form-control" placeholder="ex: 6ème A, 5ème B"></div>' +
                    '</div>';
                container.style.display = 'block';
            } else if (role === 'eleve') {
                codeField.style.display = 'block';
                document.getElementById('code_etablissement').required = true;
                nomEcole.required = true;
                html = '<div class="dynamic-fields">' +
                    '<div class="form-group"><label>Classe *</label>' +
                    '<select name="classe_eleve" class="form-control" required>' +
                    '<option value="">Choisissez</option>' +
                    '<option>6ème A</option><option>6ème B</option><option>5ème A</option><option>5ème B</option>' +
                    '<option>4ème A</option><option>4ème B</option><option>3ème A</option><option>3ème B</option>' +
                    '<option>2nde A</option><option>2nde B</option><option>1ère A</option><option>1ère B</option>' +
                    '<option>Tle A</option><option>Tle B</option>' +
                    '</select></div>' +
                    '<div class="form-group"><label>Date de naissance</label>' +
                    '<input type="date" name="date_naissance" class="form-control"></div>' +
                    '</div>';
                container.style.display = 'block';
            } else if (role === 'parent') {
                codeField.style.display = 'block';
                document.getElementById('code_etablissement').required = true;
                nomEcole.required = true;
                html = '<div class="dynamic-fields">' +
                    '<label style="font-weight:600;font-size:0.82rem;margin-bottom:8px;display:block;">Enfant(s)</label>' +
                    '<div id="childrenContainer">' +
                    '<div class="form-row" style="margin-bottom:8px;">' +
                    '<input type="text" name="enfant_nom[]" class="form-control" placeholder="Nom" required>' +
                    '<input type="text" name="enfant_prenom[]" class="form-control" placeholder="Prénom" required>' +
                    '<select name="enfant_classe[]" class="form-control" required>' +
                    '<option value="">Classe</option>' +
                    '<option>6ème A</option><option>6ème B</option><option>5ème A</option><option>5ème B</option>' +
                    '<option>4ème A</option><option>4ème B</option><option>3ème A</option><option>3ème B</option>' +
                    '<option>2nde A</option><option>2nde B</option><option>1ère A</option><option>1ère B</option>' +
                    '<option>Tle A</option><option>Tle B</option>' +
                    '</select></div></div>' +
                    '<button type="button" class="btn-add-child" onclick="addChild()">+ Ajouter un autre enfant</button>' +
                    '</div>';
                container.style.display = 'block';
            } else if (role === 'vie_scolaire') {
                codeField.style.display = 'block';
                document.getElementById('code_etablissement').required = true;
                nomEcole.required = true;
                container.style.display = 'none';
            } else {
                container.style.display = 'none';
            }

            container.innerHTML = html;

            // Auto-générer le code établissement
            if (nomEcole) {
                nomEcole.onkeyup = function() {
                    var nom = this.value.toLowerCase().replace(/[^a-z0-9]/g, '').substring(0, 10);
                    document.getElementById('code_etablissement').value = nom ? 'ETAB_' + nom.toUpperCase() : '';
                };
            }
        }

        function addChild() {
            var container = document.getElementById('childrenContainer');
            var row = document.createElement('div');
            row.className = 'form-row';
            row.style.marginBottom = '8px';
            row.innerHTML = `
                <input type="text" name="enfant_nom[]" class="form-control" placeholder="Nom" required>
                <input type="text" name="enfant_prenom[]" class="form-control" placeholder="Prénom" required>
                <select name="enfant_classe[]" class="form-control" required>
                    <option value="">Classe</option>
                    <option>6ème A</option><option>6ème B</option><option>5ème A</option><option>5ème B</option>
                    <option>4ème A</option><option>4ème B</option><option>3ème A</option><option>3ème B</option>
                    <option>2nde A</option><option>2nde B</option><option>1ère A</option><option>1ère B</option>
                    <option>Tle A</option><option>Tle B</option>
                </select>
                <button type="button" onclick="this.parentElement.remove()" style="background:none;border:none;color:#e74c3c;cursor:pointer;font-size:1.2rem;">✕</button>
            `;
            container.appendChild(row);
        }

        document.getElementById('registerForm').addEventListener('submit', function(e) {
            var p1 = document.getElementById('password').value;
            var p2 = document.getElementById('confirm_password').value;
            if (p1 !== p2) {
                e.preventDefault();
                alert('❌ Les mots de passe ne correspondent pas !');
            }
            if (p1.length < 8) {
                e.preventDefault();
                alert('❌ Le mot de passe doit contenir au moins 8 caractères !');
            }
        });
    </script>
</body>
</html>