<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link rel="stylesheet" href="/css/style.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <style>
        :root {
            --bleu-klein: #002FA7;
            --noir: #1a1a1a;
            --gris: #666666;
            --gris-clair: #999999;
            --gris-tres-clair: #e0e0e0;
            --gris-background: #f8f9fa;
            --blanc: #ffffff;
            --rouge: #e74c3c;
            --vert: #27ae60;
            --border-radius: 14px;
            --border-radius-sm: 8px;
            --shadow-lg: 0 8px 40px rgba(0, 0, 0, 0.1);
        }
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body {
            font-family: 'Inter', sans-serif;
            background-color: var(--blanc);
            color: var(--noir);
            line-height: 1.5;
        }
        .theme-toggle { position: fixed; top: 16px; right: 16px; z-index: 1000; }
        .toggle-switch {
            display: flex; align-items: center; gap: 6px;
            background: var(--gris-background); padding: 5px 10px;
            border-radius: 30px; border: 1.5px solid var(--gris-tres-clair);
            cursor: pointer; user-select: none;
        }
        .toggle-icon { width: 16px; height: 16px; display: flex; align-items: center; justify-content: center; }
        .toggle-icon svg { width: 100%; height: 100%; }
        .sun-icon { color: #f59e0b; } .moon-icon { color: #6366f1; }
        .toggle-label { font-size: 0.7rem; font-weight: 600; color: var(--gris); white-space: nowrap; }
        .auth-wrapper {
            min-height: 100vh; display: flex; align-items: center; justify-content: center;
            background-color: var(--blanc);
            background-image: radial-gradient(circle at 15% 25%, rgba(0,47,167,0.02) 0%, transparent 50%),
                              radial-gradient(circle at 85% 75%, rgba(0,47,167,0.02) 0%, transparent 50%);
            padding: 16px;
        }
        .auth-container {
            background: var(--blanc); border-radius: 20px; box-shadow: var(--shadow-lg);
            width: 100%; max-width: 900px; min-height: 500px; overflow: hidden;
            display: flex; border: 1px solid var(--gris-tres-clair);
        }
        .auth-left {
            flex: 0.9; position: relative; display: flex; align-items: center; justify-content: center;
            overflow: hidden; padding: 30px 25px; background: var(--bleu-klein);
        }
        .auth-left::before {
            content: ''; position: absolute; width: 200px; height: 200px;
            background: rgba(255,255,255,0.06); border-radius: 50%; top: -60px; right: -60px;
        }
        .auth-left::after {
            content: ''; position: absolute; width: 150px; height: 150px;
            background: rgba(255,255,255,0.04); border-radius: 50%; bottom: -40px; left: -40px;
        }
        .auth-left-content {
            position: relative; z-index: 2; text-align: center; color: var(--blanc);
            background: rgba(255,255,255,0.08); backdrop-filter: blur(12px);
            border-radius: 18px; padding: 30px 22px;
            border: 1px solid rgba(255,255,255,0.18);
            box-shadow: 0 4px 24px rgba(0,0,0,0.08); width: 100%; max-width: 280px;
        }
        .logo-container { margin-bottom: 14px; }
        .logo-icon {
            width: 45px; height: 45px; color: white;
            filter: drop-shadow(0 3px 8px rgba(0,0,0,0.15));
            animation: float 3s ease-in-out infinite;
        }
        @keyframes float { 0%,100%{transform:translateY(0)} 50%{transform:translateY(-6px)} }
        .auth-left-content h1 { font-size: 2rem; font-weight: 700; margin-bottom: 4px; letter-spacing: -0.5px; }
        .text-highlight { color: #8ab4ff; font-weight: 300; }
        .tagline { font-size: 0.85rem; opacity: 0.85; margin-bottom: 22px; line-height: 1.5; }
        .features { display: flex; flex-direction: column; gap: 8px; }
        .feature-item {
            display: flex; align-items: center; gap: 10px; padding: 8px 12px;
            background: rgba(255,255,255,0.06); border-radius: 10px;
            border: 1px solid rgba(255,255,255,0.1); cursor: default;
        }
        .feature-item svg { width: 16px; height: 16px; flex-shrink: 0; opacity: 0.9; }
        .feature-item span { font-size: 0.78rem; font-weight: 500; opacity: 0.9; }
        .auth-right {
            flex: 1.2; display: flex; align-items: center; justify-content: center;
            padding: 25px 30px; background: var(--blanc);
        }
        .auth-form-container { width: 100%; max-width: 420px; }
        .auth-form-container h2 { color: var(--noir); font-size: 1.5rem; font-weight: 700; margin-bottom: 2px; }
        .subtitle { color: var(--gris); margin-bottom: 18px; font-size: 0.82rem; }
        .alert {
            display: flex; align-items: center; gap: 8px; padding: 10px 12px;
            border-radius: var(--border-radius-sm); margin-bottom: 14px;
            font-size: 0.8rem; font-weight: 500;
        }
        .alert-danger { background-color: #fee; color: var(--rouge); border: 1px solid #fcc; }
        .alert-success { background-color: #efe; color: var(--vert); border: 1px solid #cfc; }
        .social-buttons { display: flex; flex-direction: column; gap: 8px; margin-bottom: 4px; }
        .btn-social {
            width: 100%; padding: 10px 16px; border-radius: var(--border-radius-sm);
            font-weight: 500; font-size: 0.82rem; display: flex; align-items: center;
            justify-content: center; gap: 10px; border: 1.5px solid var(--gris-tres-clair);
            background: var(--blanc); color: var(--noir); cursor: pointer;
            text-decoration: none; font-family: 'Inter', sans-serif;
        }
        .btn-social:hover { transform: translateY(-1px); }
        .btn-google:hover { border-color: #4285F4; background: #fafbff; }
        .btn-facebook:hover { border-color: #1877F2; background: #f5f7ff; }
        .social-icon { width: 18px; height: 18px; flex-shrink: 0; }
        .btn-social span { color: #333; font-weight: 500; }
        .separator { display: flex; align-items: center; text-align: center; margin: 14px 0; }
        .separator::before, .separator::after { content: ''; flex: 1; border-bottom: 1px solid var(--gris-tres-clair); }
        .separator span { padding: 0 12px; font-size: 0.75rem; color: var(--gris); }
        .auth-form { display: flex; flex-direction: column; gap: 10px; }
        .form-group { display: flex; flex-direction: column; gap: 5px; }
        .form-group label { color: #333; font-weight: 600; font-size: 0.78rem; }
        .form-control {
            width: 100%; padding: 10px 12px; border: 1.5px solid var(--gris-tres-clair);
            border-radius: var(--border-radius-sm); font-size: 0.85rem;
            font-family: 'Inter', sans-serif; color: var(--noir);
            background: var(--gris-background); outline: none;
        }
        .form-control:focus { border-color: var(--bleu-klein); background: var(--blanc); }
        select.form-control {
            appearance: none;
            background-image: url("data:image/svg+xml;charset=UTF-8,%3csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='none' stroke='%23999999' stroke-width='2'%3e%3cpolyline points='6 9 12 15 18 9'%3e%3c/polyline%3e%3c/svg%3e");
            background-repeat: no-repeat; background-position: right 10px center;
            background-size: 16px; padding-right: 32px; cursor: pointer;
        }
        .form-row { display: flex; gap: 10px; }
        .form-row .form-group { flex: 1; }
        .btn {
            display: inline-flex; align-items: center; justify-content: center; gap: 8px;
            padding: 11px 22px; border: none; border-radius: var(--border-radius-sm);
            font-size: 0.88rem; font-weight: 600; cursor: pointer;
            font-family: 'Inter', sans-serif; text-decoration: none;
        }
        .btn-primary { background-color: var(--bleu-klein); color: var(--blanc); }
        .btn-primary:hover { background-color: #003fd6; }
        .btn-block { width: 100%; }
        .auth-link { text-align: center; margin-top: 16px; color: var(--gris); font-size: 0.8rem; }
        .auth-link a { color: var(--bleu-klein); text-decoration: none; font-weight: 700; }
        .auth-link a:hover { text-decoration: underline; }
        .dynamic-fields { background: var(--gris-background); border-radius: var(--border-radius-sm); padding: 12px; margin-top: 4px; border: 1px dashed var(--gris-tres-clair); }
        .child-row { display: flex; gap: 8px; margin-bottom: 8px; align-items: center; }
        .child-row .form-control { flex: 1; }
        .btn-add-child { background: none; border: 1px dashed var(--bleu-klein); color: var(--bleu-klein); padding: 6px 12px; border-radius: 6px; cursor: pointer; font-size: 0.75rem; font-weight: 600; font-family: 'Inter', sans-serif; margin-top: 6px; }
        .btn-remove-child { background: none; border: none; color: var(--rouge); cursor: pointer; font-size: 1.2rem; padding: 0 4px; }
        .etab-info { font-size: 0.72rem; margin-top: 4px; }
        .etab-info.ok { color: var(--vert); }
        .etab-info.blocked { color: var(--rouge); }
        .etab-info.full { color: #f39c12; }
        body.dark-mode { background-color: #121212; }
        body.dark-mode .auth-wrapper { background-color: #121212; background-image: none; }
        body.dark-mode .auth-container { background-color: #1e1e1e; border-color: #333; }
        body.dark-mode .auth-right { background-color: #1e1e1e; }
        body.dark-mode .auth-form-container h2 { color: #f0f0f0; }
        body.dark-mode .subtitle { color: #aaa; }
        body.dark-mode .form-control { background-color: #2a2a2a; color: #e0e0e0; border-color: #444; }
        body.dark-mode .form-group label { color: #bbb; }
        body.dark-mode .dynamic-fields { background: #2a2a2a; border-color: #444; }
        body.dark-mode .btn-social { background-color: #2a2a2a; border-color: #444; }
        body.dark-mode .btn-social span { color: #ccc; }
        body.dark-mode .toggle-switch { background: #2a2a2a; border-color: #444; }
        body.dark-mode .toggle-label { color: #aaa; }
        @media (max-width: 768px) {
            .auth-container { flex-direction: column; max-width: 450px; }
            .auth-left { padding: 22px 18px; }
            .auth-left-content { padding: 22px 18px; max-width: 100%; }
            .auth-left-content h1 { font-size: 1.6rem; }
            .auth-right { padding: 20px 18px; }
            .form-row { flex-direction: column; gap: 0; }
        }
    </style>
</head>
<body>
    <div class="theme-toggle">
        <div class="toggle-switch" onclick="toggleDarkMode()">
            <div class="toggle-icon sun-icon" id="sunIcon">
                <svg viewBox="0 0 24 24" fill="currentColor"><circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3" stroke="currentColor" stroke-width="2" stroke-linecap="round"/><line x1="12" y1="21" x2="12" y2="23" stroke="currentColor" stroke-width="2" stroke-linecap="round"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64" stroke="currentColor" stroke-width="2" stroke-linecap="round"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78" stroke="currentColor" stroke-width="2" stroke-linecap="round"/><line x1="1" y1="12" x2="3" y2="12" stroke="currentColor" stroke-width="2" stroke-linecap="round"/><line x1="21" y1="12" x2="23" y2="12" stroke="currentColor" stroke-width="2" stroke-linecap="round"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36" stroke="currentColor" stroke-width="2" stroke-linecap="round"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
            </div>
            <div class="toggle-icon moon-icon" id="moonIcon" style="display:none;">
                <svg viewBox="0 0 24 24" fill="currentColor"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
            </div>
            <span class="toggle-label" id="toggleLabel">Sombre</span>
        </div>
    </div>

    <div class="auth-wrapper">
        <div class="auth-container">
            <div class="auth-left">
                <div class="auth-left-content">
                    <div class="logo-container">
                        <svg class="logo-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 10v6M2 10l10-5 10 5-10 5z"/><path d="M6 12v5c0 2 4 3 6 3s6-1 6-3v-5"/></svg>
                    </div>
                    <h1>EducOS<span class="text-highlight">-pro</span></h1>
                    <p class="tagline">Rejoignez la communauté<br>éducative</p>
                    <div class="features">
                        <div class="feature-item">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M16 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="8.5" cy="7" r="4"/><line x1="20" y1="8" x2="20" y2="14"/><line x1="23" y1="11" x2="17" y2="11"/></svg>
                            <span>5 profils disponibles</span>
                        </div>
                        <div class="feature-item">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
                            <span>Inscription sécurisée</span>
                        </div>
                        <div class="feature-item">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>
                            <span>Gratuit et rapide</span>
                        </div>
                    </div>
                </div>
            </div>

            <div class="auth-right">
                <div class="auth-form-container">
                    <h2>Inscription</h2>
                    <p class="subtitle">Créez votre compte EducOS-pro</p>

                    <% if (locals.error) { %>
                        <div class="alert alert-danger">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
                            <span><%= error %></span>
                        </div>
                    <% } %>
                    <% if (locals.success) { %>
                        <div class="alert alert-success">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
                            <span><%= success %></span>
                        </div>
                    <% } %>

                    <div class="social-buttons">
                        <a href="/auth/google" class="btn-social btn-google">
                            <svg class="social-icon" viewBox="0 0 24 24"><path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 0 1-2.2 3.32v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.1z"/><path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/><path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"/><path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/></svg>
                            <span>S'inscrire avec Google</span>
                        </a>
                        <a href="/auth/facebook" class="btn-social btn-facebook">
                            <svg class="social-icon" viewBox="0 0 24 24"><path fill="#1877F2" d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
                            <span>S'inscrire avec Facebook</span>
                        </a>
                    </div>

                    <div class="separator"><span>ou</span></div>

                    <form action="/auth/register" method="POST" class="auth-form" id="registerForm">
                        <!-- CHOIX ÉTABLISSEMENT -->
                        <div class="form-group">
                            <label for="etablissement_code">🏫 Établissement *</label>
                            <select id="etablissement_code" name="etablissement_code" class="form-control" required onchange="checkEtablissement()">
                                <option value="">Choisissez votre établissement</option>
                            </select>
                            <div class="etab-info" id="etabInfo"></div>
                        </div>

                        <div class="form-row">
                            <div class="form-group">
                                <label for="nom">Nom *</label>
                                <input type="text" id="nom" name="nom" class="form-control" required placeholder="Dupont">
                            </div>
                            <div class="form-group">
                                <label for="prenom">Prénom *</label>
                                <input type="text" id="prenom" name="prenom" class="form-control" required placeholder="Jean">
                            </div>
                        </div>

                        <div class="form-group">
                            <label for="email">Email *</label>
                            <input type="email" id="email" name="email" class="form-control" required placeholder="votre@email.com">
                        </div>

                        <div class="form-group">
                            <label for="role">Rôle *</label>
                            <select id="role" name="role" class="form-control" required onchange="showDynamicFields()">
                                <option value="">Choisissez votre profil</option>
                                <option value="admin">👑 Administrateur</option>
                                <option value="vie_scolaire">📋 Responsable Vie Scolaire</option>
                                <option value="prof">👨‍🏫 Professeur</option>
                                <option value="parent">👪 Parent</option>
                                <option value="eleve">🎓 Élève</option>
                            </select>
                        </div>

                        <div id="dynamicFields" style="display:none;"></div>

                        <div class="form-group">
                            <label for="password">Mot de passe *</label>
                            <input type="password" id="password" name="password" class="form-control" required placeholder="Min. 8 caractères" minlength="8">
                        </div>

                        <div class="form-group">
                            <label for="confirm_password">Confirmer le mot de passe *</label>
                            <input type="password" id="confirm_password" name="confirm_password" class="form-control" required placeholder="Répétez le mot de passe" minlength="8">
                        </div>

                        <button type="submit" class="btn btn-primary btn-block">
                            <span>Créer mon compte</span>
                            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
                        </button>
                    </form>
                    <p class="auth-link">Déjà un compte ? <a href="/auth/login">Se connecter</a></p>
                </div>
            </div>
        </div>
    </div>

    <script>
        function toggleDarkMode() {
            document.body.classList.toggle('dark-mode');
            var isDark = document.body.classList.contains('dark-mode');
            localStorage.setItem('darkMode', isDark);
            document.getElementById('sunIcon').style.display = isDark ? 'none' : 'flex';
            document.getElementById('moonIcon').style.display = isDark ? 'flex' : 'none';
            document.getElementById('toggleLabel').textContent = isDark ? 'Clair' : 'Sombre';
        }
        window.addEventListener('DOMContentLoaded', function() {
            if (localStorage.getItem('darkMode') === 'true') {
                document.body.classList.add('dark-mode');
                document.getElementById('sunIcon').style.display = 'none';
                document.getElementById('moonIcon').style.display = 'flex';
                document.getElementById('toggleLabel').textContent = 'Clair';
            }
            loadEtablissements();
        });

        // Charger la liste des établissements (sauf pour admin)
async function loadEtablissements() {
    try {
        var r = await fetch('/api/etablissements');
        var etabs = await r.json();
        var sel = document.getElementById('etablissement_code');
        sel.innerHTML = '<option value="">Choisissez votre établissement</option>';
        etabs.forEach(function(e) {
            sel.innerHTML += '<option value="' + e.code + '">' + e.nom + '</option>';
        });
    } catch(e) {
        console.error('Erreur chargement établissements:', e);
    }
}

        // Vérifier si l'établissement accepte les inscriptions
        var etablissementsData = {};
        async function checkEtablissement() {
            var code = document.getElementById('etablissement_code').value;
            var info = document.getElementById('etabInfo');
            if (!code) { info.innerHTML = ''; return; }
            
            try {
                var r = await fetch('/api/check-etablissement/' + code);
                var data = await r.json();
                etablissementsData[code] = data;
                
                if (data.allow_registration == 0) {
                    info.innerHTML = '⛔ Cet établissement n\'accepte pas les inscriptions actuellement.';
                    info.className = 'etab-info blocked';
                    document.getElementById('etablissement_code').value = '';
                    setTimeout(function() { alert('⛔ Les inscriptions sont désactivées pour cet établissement.\nVeuillez en choisir un autre.'); }, 500);
                } else if (data.max_users && data.current_users >= data.max_users) {
                    info.innerHTML = '⚠️ Cet établissement a atteint sa limite d\'utilisateurs (' + data.max_users + ').';
                    info.className = 'etab-info full';
                    document.getElementById('etablissement_code').value = '';
                    setTimeout(function() { alert('⚠️ Nombre maximum d\'utilisateurs atteint pour cet établissement.\nVeuillez en choisir un autre.'); }, 500);
                } else {
                    info.innerHTML = '✅ Établissement disponible - ' + data.current_users + '/' + (data.max_users||'?') + ' utilisateurs';
                    info.className = 'etab-info ok';
                }
            } catch(e) {
                console.error('Erreur vérification:', e);
            }
        }

        function showDynamicFields() {
    var role = document.getElementById('role').value;
    var container = document.getElementById('dynamicFields');
    var etabField = document.getElementById('etablissement_code');
    var etabInfo = document.getElementById('etabInfo');
    var html = '';
    
    // ========== ADMIN : Créer son établissement ==========
    if (role === 'admin') {
        // L'admin n'a pas besoin de choisir un établissement existant
        etabField.innerHTML = '<option value="__new__">🏫 Créer mon établissement</option>';
        etabField.disabled = false;
        etabInfo.innerHTML = '✅ Vous allez créer votre établissement en tant qu\'administrateur.';
        etabInfo.className = 'etab-info ok';
        
        html = '<div class="dynamic-fields">' +
            '<div class="form-group">' +
            '<label>🏫 Nom de l\'établissement *</label>' +
            '<input type="text" name="etablissement_nom" class="form-control" required placeholder="Ex: Collège Jean Dupont">' +
            '</div>' +
            '<div class="form-group">' +
            '<label>📧 Email de l\'établissement</label>' +
            '<input type="email" name="etablissement_email" class="form-control" placeholder="contact@ecole.com">' +
            '</div>' +
            '<div class="form-group">' +
            '<label>📞 Téléphone</label>' +
            '<input type="text" name="etablissement_telephone" class="form-control" placeholder="+261 ...">' +
            '</div>' +
            '<div class="form-group">' +
            '<label>📍 Adresse</label>' +
            '<input type="text" name="etablissement_adresse" class="form-control" placeholder="Adresse de l\'établissement">' +
            '</div>' +
            '<div class="form-group">' +
            '<label>👨‍💼 Directeur / Principal</label>' +
            '<input type="text" name="etablissement_directeur" class="form-control" placeholder="Nom du directeur">' +
            '</div>' +
            '</div>';
        container.style.display = 'block';
    }
    
    // ========== PROFESSEUR ==========
    else if (role === 'prof') {
        etabField.disabled = false;
        // Recharger la liste des établissements
        loadEtablissements();
        etabInfo.innerHTML = '';
        
        html = '<div class="dynamic-fields"><div class="form-group"><label>Matière principale *</label><select name="matiere_principale" class="form-control" required><option value="">Choisissez</option><option>Mathématiques</option><option>Français</option><option>Histoire-Géographie</option><option>SVT</option><option>Physique-Chimie</option><option>Anglais</option><option>Espagnol</option><option>Philosophie</option><option>EPS</option><option>Informatique</option></select></div><div class="form-group"><label>Classes assignées</label><input type="text" name="classes_assignees" class="form-control" placeholder="ex: 6ème A, 5ème B"></div></div>';
        container.style.display = 'block';
    }
    
    // ========== ÉLÈVE ==========
    else if (role === 'eleve') {
        etabField.disabled = false;
        loadEtablissements();
        etabInfo.innerHTML = '';
        
        html = '<div class="dynamic-fields"><div class="form-group"><label>Classe *</label><select name="classe_eleve" class="form-control" required><option value="">Choisissez</option><option>6ème A</option><option>6ème B</option><option>5ème A</option><option>5ème B</option><option>4ème A</option><option>4ème B</option><option>3ème A</option><option>3ème B</option><option>2nde A</option><option>2nde B</option><option>1ère A</option><option>1ère B</option><option>Tle A</option><option>Tle B</option></select></div><div class="form-group"><label>Date de naissance</label><input type="date" name="date_naissance" class="form-control"></div></div>';
        container.style.display = 'block';
    }
    
    // ========== PARENT ==========
    else if (role === 'parent') {
        etabField.disabled = false;
        loadEtablissements();
        etabInfo.innerHTML = '';
        
        html = '<div class="dynamic-fields"><label style="font-weight:600;font-size:0.78rem;margin-bottom:8px;display:block;">Enfant(s) inscrit(s)</label><div id="childrenContainer"><div class="child-row"><input type="text" name="enfant_nom[]" class="form-control" placeholder="Nom" required><input type="text" name="enfant_prenom[]" class="form-control" placeholder="Prénom" required><select name="enfant_classe[]" class="form-control" required><option value="">Classe</option><option>6ème A</option><option>6ème B</option><option>5ème A</option><option>5ème B</option><option>4ème A</option><option>4ème B</option><option>3ème A</option><option>3ème B</option><option>2nde A</option><option>2nde B</option><option>1ère A</option><option>1ère B</option><option>Tle A</option><option>Tle B</option></select></div></div><button type="button" class="btn-add-child" onclick="addChild()">+ Ajouter un autre enfant</button></div>';
        container.style.display = 'block';
    }
    
    // ========== VIE SCOLAIRE ==========
    else if (role === 'vie_scolaire') {
        etabField.disabled = false;
        loadEtablissements();
        etabInfo.innerHTML = '';
        container.style.display = 'none';
    }
    
    // ========== AUTRE ==========
    else {
        container.style.display = 'none';
        etabField.disabled = false;
        etabInfo.innerHTML = '';
    }
    
    container.innerHTML = html;
}

        function addChild() {
            var container = document.getElementById('childrenContainer');
            var row = document.createElement('div');
            row.className = 'child-row';
            row.innerHTML = '<input type="text" name="enfant_nom[]" class="form-control" placeholder="Nom" required><input type="text" name="enfant_prenom[]" class="form-control" placeholder="Prénom" required><select name="enfant_classe[]" class="form-control" required><option value="">Classe</option><option>6ème A</option><option>6ème B</option><option>5ème A</option><option>5ème B</option><option>4ème A</option><option>4ème B</option><option>3ème A</option><option>3ème B</option><option>2nde A</option><option>2nde B</option><option>1ère A</option><option>1ère B</option><option>Tle A</option><option>Tle B</option></select><button type="button" class="btn-remove-child" onclick="this.parentElement.remove()">✕</button>';
            container.appendChild(row);
        }

        document.getElementById('registerForm').addEventListener('submit', function(e) {
            var p1 = document.getElementById('password').value;
            var p2 = document.getElementById('confirm_password').value;
            if (p1 !== p2) { e.preventDefault(); alert('❌ Les mots de passe ne correspondent pas !'); }
            if (p1.length < 8) { e.preventDefault(); alert('❌ Minimum 8 caractères !'); }
            var etab = document.getElementById('etablissement_code').value;
            if (!etab) { e.preventDefault(); alert('❌ Veuillez choisir un établissement !'); }
        });
        document.getElementById('registerForm').addEventListener('submit', function(e) {
    var p1 = document.getElementById('password').value;
    var p2 = document.getElementById('confirm_password').value;
    if (p1 !== p2) { e.preventDefault(); alert('❌ Les mots de passe ne correspondent pas !'); return; }
    if (p1.length < 8) { e.preventDefault(); alert('❌ Minimum 8 caractères !'); return; }
    
    var role = document.getElementById('role').value;
    var etab = document.getElementById('etablissement_code').value;
    
    // L'admin crée son établissement, pas besoin de choisir
    if (role === 'admin') {
        var nomEtab = document.querySelector('[name="etablissement_nom"]');
        if (!nomEtab || !nomEtab.value) { e.preventDefault(); alert('❌ Veuillez entrer le nom de l\'établissement !'); return; }
    } else {
        if (!etab) { e.preventDefault(); alert('❌ Veuillez choisir un établissement !'); return; }
    }
});
    </script>
</body>
</html>