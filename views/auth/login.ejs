<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link rel="stylesheet" href="/css/style.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <style>
        :root {
            --bleu-klein: #002FA7;
            --noir: #1a1a1a;
            --gris: #666666;
            --gris-clair: #999999;
            --gris-tres-clair: #e0e0e0;
            --gris-background: #f8f9fa;
            --blanc: #ffffff;
            --rouge: #e74c3c;
            --rouge-clair: #fee;
            --vert: #27ae60;
            --vert-clair: #efe;
            --border-radius: 12px;
            --border-radius-sm: 8px;
            --shadow: 0 4px 24px rgba(0,0,0,0.08);
            --transition: all 0.3s ease;
        }

        * { margin: 0; padding: 0; box-sizing: border-box; }

        body {
            font-family: 'Inter', 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background-color: #f0f2f5;
            color: var(--noir);
            line-height: 1.5;
        }

        .auth-wrapper {
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 20px;
        }

        .auth-container {
            background: var(--blanc);
            border-radius: 20px;
            box-shadow: var(--shadow);
            width: 100%;
            max-width: 440px;
            padding: 40px;
        }

        .auth-logo {
            text-align: center;
            margin-bottom: 28px;
        }

        .auth-logo h1 {
            font-size: 2rem;
            font-weight: 700;
            color: var(--bleu-klein);
        }

        .auth-logo h1 span {
            font-weight: 300;
            color: var(--gris-clair);
        }

        .auth-form-container h2 {
            font-size: 1.4rem;
            font-weight: 700;
            margin-bottom: 4px;
            text-align: center;
        }

        .subtitle {
            color: var(--gris);
            margin-bottom: 20px;
            font-size: 0.85rem;
            text-align: center;
        }

        .alert {
            display: flex;
            align-items: center;
            gap: 8px;
            padding: 10px 12px;
            border-radius: var(--border-radius-sm);
            margin-bottom: 16px;
            font-size: 0.82rem;
            font-weight: 500;
        }
        .alert-danger { background-color: var(--rouge-clair); color: var(--rouge); border: 1px solid #fcc; }
        .alert-success { background-color: var(--vert-clair); color: var(--vert); border: 1px solid #cfc; }

        .social-buttons {
            display: flex;
            flex-direction: column;
            gap: 8px;
            margin-bottom: 6px;
        }

        .btn-social {
            width: 100%;
            padding: 11px 16px;
            border-radius: var(--border-radius-sm);
            font-weight: 500;
            font-size: 0.85rem;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 10px;
            border: 2px solid var(--gris-tres-clair);
            background: var(--blanc);
            color: var(--noir);
            cursor: pointer;
            transition: var(--transition);
            font-family: 'Inter', sans-serif;
            text-decoration: none;
        }

        .btn-social:hover {
            transform: translateY(-1px);
            box-shadow: 0 2px 8px rgba(0,0,0,0.06);
        }

        .btn-google:hover { border-color: #4285F4; background: #fafbff; }
        .btn-facebook:hover { border-color: #1877F2; background: #f5f7ff; }

        .social-icon { width: 18px; height: 18px; flex-shrink: 0; }
        .btn-social span { color: var(--gris-fonce); font-weight: 500; }

        .separator {
            display: flex;
            align-items: center;
            text-align: center;
            margin: 18px 0;
        }

        .separator::before, .separator::after {
            content: '';
            flex: 1;
            border-bottom: 1px solid var(--gris-tres-clair);
        }

        .separator span {
            padding: 0 14px;
            font-size: 0.78rem;
            color: var(--gris);
            font-weight: 500;
        }

        .form-group {
            margin-bottom: 14px;
        }

        .form-group label {
            display: block;
            margin-bottom: 5px;
            font-weight: 600;
            font-size: 0.82rem;
            color: #333;
        }

        .input-wrapper {
            position: relative;
            display: flex;
            align-items: center;
        }

        .input-icon {
            position: absolute;
            left: 12px;
            width: 16px;
            height: 16px;
            color: var(--gris-clair);
            pointer-events: none;
            z-index: 1;
        }

        .form-control {
            width: 100%;
            padding: 12px 14px 12px 38px;
            border: 2px solid var(--gris-tres-clair);
            border-radius: var(--border-radius-sm);
            font-size: 0.88rem;
            font-family: 'Inter', sans-serif;
            background: var(--gris-background);
            transition: var(--transition);
            outline: none;
        }

        .form-control:focus {
            border-color: var(--bleu-klein);
            background: var(--blanc);
            box-shadow: 0 0 0 3px rgba(0,47,167,0.1);
        }

        .form-control::placeholder {
            color: var(--gris-clair);
        }

        .toggle-password {
            position: absolute;
            right: 10px;
            background: none;
            border: none;
            cursor: pointer;
            padding: 4px;
            color: var(--gris-clair);
        }

        .toggle-password:hover { color: var(--gris); }

        .form-options {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-top: -4px;
            margin-bottom: 16px;
        }

        .remember-me {
            display: flex;
            align-items: center;
            gap: 6px;
            cursor: pointer;
            font-size: 0.82rem;
            color: var(--gris);
        }

        .forgot-password {
            font-size: 0.8rem;
            color: var(--bleu-klein);
            text-decoration: none;
            font-weight: 600;
        }

        .forgot-password:hover { text-decoration: underline; }

        .btn {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
            padding: 12px 24px;
            border: none;
            border-radius: var(--border-radius-sm);
            font-size: 0.9rem;
            font-weight: 600;
            cursor: pointer;
            transition: var(--transition);
            font-family: 'Inter', sans-serif;
            width: 100%;
        }

        .btn-primary {
            background-color: var(--bleu-klein);
            color: var(--blanc);
        }

        .btn-primary:hover {
            background-color: #003fd6;
            box-shadow: 0 4px 16px rgba(0,47,167,0.2);
        }

        .btn-arrow { width: 16px; height: 16px; transition: transform 0.3s ease; }

        .btn-primary:hover .btn-arrow { transform: translateX(4px); }

        .auth-link {
            text-align: center;
            margin-top: 20px;
            color: var(--gris);
            font-size: 0.85rem;
        }

        .auth-link a {
            color: var(--bleu-klein);
            text-decoration: none;
            font-weight: 700;
        }

        .auth-link a:hover { text-decoration: underline; }

        @media (max-width: 500px) {
            .auth-container { padding: 24px 18px; }
        }
    </style>
</head>
<body>
    <div class="auth-wrapper">
        <div class="auth-container">
            <div class="auth-logo">
                <h1>EducOS<span>-pro</span></h1>
            </div>

            <div class="auth-form-container">
                <h2>Connexion</h2>
                <p class="subtitle">Accédez à votre espace</p>

                <% if (locals.error) { %>
                    <div class="alert alert-danger"><span>⚠️ <%= error %></span></div>
                <% } %>
                <% if (locals.success) { %>
                    <div class="alert alert-success"><span>✅ <%= success %></span></div>
                <% } %>

                <!-- Réseaux sociaux -->
                <div class="social-buttons">
                    <a href="/auth/google" class="btn-social btn-google">
                        <svg class="social-icon" viewBox="0 0 24 24">
                            <path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 0 1-2.2 3.32v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.1z"/>
                            <path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/>
                            <path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"/>
                            <path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/>
                        </svg>
                        <span>Continuer avec Google</span>
                    </a>
                    <a href="/auth/facebook" class="btn-social btn-facebook">
                        <svg class="social-icon" viewBox="0 0 24 24">
                            <path fill="#1877F2" d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
                        </svg>
                        <span>Continuer avec Facebook</span>
                    </a>
                </div>

                <div class="separator"><span>ou</span></div>

                <!-- Formulaire connexion -->
                <form action="/auth/login" method="POST">
                    <div class="form-group">
                        <label for="email">Email</label>
                        <div class="input-wrapper">
                            <svg class="input-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
                            <input type="email" id="email" name="email" class="form-control" required placeholder="votre@email.com">
                        </div>
                    </div>

                    <div class="form-group">
                        <label for="password">Mot de passe</label>
                        <div class="input-wrapper">
                            <svg class="input-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
                            <input type="password" id="password" name="password" class="form-control" required placeholder="Votre mot de passe">
                            <button type="button" class="toggle-password" onclick="togglePassword()">
                                <svg id="eye-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="18" height="18"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
                            </button>
                        </div>
                    </div>

                    <div class="form-options">
                        <label class="remember-me">
                            <input type="checkbox" name="remember"> Se souvenir de moi
                        </label>
                        <a href="#" class="forgot-password">Mot de passe oublié ?</a>
                    </div>

                    <button type="submit" class="btn btn-primary">
                        <span>Se connecter</span>
                        <svg class="btn-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
                    </button>
                </form>

                <p class="auth-link">Pas encore de compte ? <a href="/auth/register">S'inscrire</a></p>
            </div>
        </div>
    </div>

    <script>
        function togglePassword() {
            var p = document.getElementById('password');
            var e = document.getElementById('eye-icon');
            if (p.type === 'password') {
                p.type = 'text';
                e.innerHTML = '<path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94"/><path d="M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19"/><path d="M14.12 14.12a3 3 0 1 1-4.24-4.24"/><line x1="1" y1="1" x2="23" y2="23"/>';
            } else {
                p.type = 'password';
                e.innerHTML = '<path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/>';
            }
        }
    </script>
</body>
</html>