<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="/css/dashboard.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <style>
        .nav-icon { stroke: #b0b0c0; stroke-width: 2; fill: none; transition: all 0.2s; }
        .nav-item:hover .nav-icon, .nav-item.active .nav-icon { stroke: white; }
        .notif-btn { position: relative; cursor: pointer; }
        .badge-notif { position: absolute; top: -6px; right: -6px; background: #e74c3c; color: white; border-radius: 50%; width: 20px; height: 20px; font-size: 0.65rem; display: none; align-items: center; justify-content: center; font-weight: 700; }
        .notif-dropdown { display: none; position: fixed; top: 60px; right: 16px; background: white; border-radius: 14px; box-shadow: 0 10px 40px rgba(0,0,0,0.15); width: 380px; max-height: 450px; overflow-y: auto; z-index: 200; }
        .notif-dropdown.active { display: block; }
        .notif-item { padding: 14px 16px; border-bottom: 1px solid #f0f0f0; cursor: pointer; }
        .notif-item:hover { background: #f8f9fa; }
        .notif-item.non-lu { background: #f0f4ff; border-left: 3px solid #002FA7; }
        .tab-content { display: none; }
        .tab-content.active { display: block; }

        /* BOUTON DISCUSSIONS */
        .discussions-btn-container { position: fixed; bottom: 20px; right: 16px; z-index: 1500; }
        .btn-discussions { width: 56px; height: 56px; border-radius: 50%; background: #002FA7; color: white; border: none; cursor: pointer; box-shadow: 0 4px 16px rgba(0,47,167,0.3); display: flex; align-items: center; justify-content: center; position: relative; }
        .btn-discussions .badge-chat { position: absolute; top: -4px; right: -4px; background: #e74c3c; color: white; border-radius: 50%; width: 22px; height: 22px; font-size: 0.65rem; display: flex; align-items: center; justify-content: center; font-weight: 700; }

        /* PANNEAU DISCUSSIONS */
        .discussions-panel { display: none; position: fixed; bottom: 90px; right: 16px; width: 350px; max-height: 420px; background: white; border-radius: 16px; box-shadow: 0 -4px 24px rgba(0,0,0,0.12); z-index: 1499; overflow-y: auto; }
        .discussions-panel.active { display: block; }
        .discussions-panel .panel-header { padding: 14px; font-weight: 700; border-bottom: 1px solid #f0f0f0; display: flex; justify-content: space-between; align-items: center; position: sticky; top: 0; background: white; border-radius: 16px 16px 0 0; }
        .discussion-item { display: flex; align-items: center; gap: 10px; padding: 12px 14px; cursor: pointer; border-bottom: 1px solid #f0f0f0; transition: all 0.2s; }
        .discussion-item:hover { background: #f8f9fa; }
        .discussion-item .disc-avatar { width: 40px; height: 40px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-weight: 700; color: white; font-size: 0.85rem; flex-shrink: 0; }
        .discussion-item .disc-info { flex: 1; min-width: 0; }
        .discussion-item .disc-name { font-weight: 600; font-size: 0.85rem; }
        .discussion-item .disc-last { font-size: 0.75rem; color: #888; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
        .discussion-item .disc-badge { background: #e74c3c; color: white; border-radius: 50%; min-width: 20px; height: 20px; font-size: 0.65rem; display: flex; align-items: center; justify-content: center; font-weight: 700; padding: 0 4px; }

        /* POPUPS CHAT */
        .popups-container { position: fixed; bottom: 20px; right: 85px; display: flex; gap: 12px; z-index: 1498; align-items: flex-end; flex-direction: row-reverse; }
        .chat-popup { width: 380px; height: 500px; background: white; border-radius: 16px 16px 0 0; box-shadow: 0 -4px 20px rgba(0,0,0,0.15); display: flex; flex-direction: column; overflow: hidden; transition: all 0.3s; }
        .chat-popup.minimized { height: 50px; }
        .chat-popup-header { background: #002FA7; color: white; padding: 12px 16px; display: flex; justify-content: space-between; align-items: center; cursor: pointer; flex-shrink: 0; }
        .chat-popup-header .btn-icon { background: none; border: none; color: white; cursor: pointer; padding: 4px; }
        .chat-popup-header .btn-icon svg { width: 16px; height: 16px; stroke: white; }
        .chat-popup-body { flex: 1; display: flex; flex-direction: column; overflow: hidden; }
        .chat-messages { flex: 1; overflow-y: auto; padding: 12px; background: #f8f9fa; }
        .chat-msg { margin-bottom: 8px; padding: 8px 12px; border-radius: 12px; max-width: 85%; word-wrap: break-word; }
        .chat-msg.moi { background: #002FA7; color: white; margin-left: auto; }
        .chat-msg.autre { background: #e0e0e0; color: #333; }
        .chat-msg img { max-width: 200px; border-radius: 8px; margin-top: 4px; cursor: pointer; }
        .chat-msg small { font-size: 0.6rem; opacity: 0.7; display: block; margin-top: 2px; }
        .chat-input-area { padding: 10px; border-top: 1px solid #e0e0e0; background: white; }
        .chat-input-row { display: flex; gap: 6px; align-items: center; }
        .chat-input-row input { flex: 1; padding: 8px 12px; border: 1px solid #e0e0e0; border-radius: 20px; font-size: 0.85rem; font-family: 'Inter', sans-serif; }
        .chat-input-row input:focus { border-color: #002FA7; outline: none; }
        .emoji-popup { display: none; flex-wrap: wrap; gap: 4px; padding: 8px; background: white; border: 1px solid #e0e0e0; border-radius: 8px; margin-bottom: 6px; max-height: 120px; overflow-y: auto; }
        .emoji-popup.active { display: flex; }
        .emoji-popup span { cursor: pointer; font-size: 1.2rem; padding: 2px; }

        @media (max-width: 768px) {
            .chat-popup { width: 100vw; height: 100vh; border-radius: 0; position: fixed; top: 0; left: 0; z-index: 2000; }
            .chat-popup.minimized { height: 50px; top: auto; bottom: 0; }
            .popups-container { right: 60px; bottom: 10px; gap: 6px; flex-direction: column-reverse; }
            .popups-container .chat-popup { width: 280px; height: 380px; border-radius: 16px 16px 0 0; position: relative; top: auto; left: auto; }
            .discussions-panel { width: 300px; right: 10px; bottom: 80px; }
            .btn-discussions { width: 48px; height: 48px; }
            .discussions-btn-container { right: 10px; bottom: 14px; }
        }
    </style>
</head>
<body>
    <div class="sidebar-overlay" id="sidebarOverlay" onclick="toggleSidebar()"></div>
    <div class="dashboard-container">
        <aside class="sidebar" id="sidebar">
            <div class="sidebar-header">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2"><path d="M22 10v6M2 10l10-5 10 5-10 5z"/><path d="M6 12v5c0 2 4 3 6 3s6-1 6-3v-5"/></svg>
                <h2>EducOS<span>-pro</span></h2>
            </div>
            <nav class="sidebar-nav">
                <div class="nav-section-title">ÉLÈVE</div>
                <a href="#" class="nav-item active" onclick="showTab('accueil')">
                    <svg viewBox="0 0 24 24" class="nav-icon" width="20" height="20"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/></svg>
                    <span>Tableau de bord</span>
                </a>
                <a href="#" class="nav-item" onclick="showTab('notes')">
                    <svg viewBox="0 0 24 24" class="nav-icon" width="20" height="20"><path d="M9 11l3 3L22 4"/></svg>
                    <span>Notes</span>
                </a>
                <a href="#" class="nav-item" onclick="showTab('edt')">
                    <svg viewBox="0 0 24 24" class="nav-icon" width="20" height="20"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/></svg>
                    <span>Emploi du temps</span>
                </a>
                <a href="#" class="nav-item" onclick="showTab('ressources')">
                    <svg viewBox="0 0 24 24" class="nav-icon" width="20" height="20"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/></svg>
                    <span>Ressources</span>
                </a>
                <a href="#" class="nav-item" onclick="showTab('absences')">
                    <svg viewBox="0 0 24 24" class="nav-icon" width="20" height="20"><circle cx="12" cy="12" r="10"/><line x1="4.93" y1="4.93" x2="19.07" y2="19.07"/></svg>
                    <span>Absences</span>
                </a>
                <a href="#" class="nav-item" onclick="showTab('sanctions')">
                    <svg viewBox="0 0 24 24" class="nav-icon" width="20" height="20"><polygon points="7.86 2 16.14 2 22 7.86 22 16.14 16.14 22 7.86 22 2 16.14 2 7.86 7.86 2"/></svg>
                    <span>Sanctions</span>
                </a>
                <div class="nav-section-title">SOCIAL</div>
                <a href="#" class="nav-item" onclick="showTab('amis')">
                    <svg viewBox="0 0 24 24" class="nav-icon" width="20" height="20"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/></svg>
                    <span>Amis</span>
                </a>
                <a href="#" class="nav-item" onclick="showTab('groupes')">
                    <svg viewBox="0 0 24 24" class="nav-icon" width="20" height="20"><path d="M17 21v-2a4 4 0 0 0-3-3.87"/><circle cx="12" cy="7" r="4"/></svg>
                    <span>Groupes</span>
                </a>
                <div class="nav-section-title">COMMUNICATION</div>
                <a href="#" class="nav-item" onclick="showTab('messages')">
                    <svg viewBox="0 0 24 24" class="nav-icon" width="20" height="20"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
                    <span>Messages</span>
                </a>
            </nav>
            <div class="sidebar-footer">
                <div class="user-info-sidebar">
                    <div class="user-avatar"><%= user.prenom.charAt(0) %><%= user.nom.charAt(0) %></div>
                    <div class="user-details"><span class="user-name"><%= user.prenom %> <%= user.nom %></span><span class="user-role">Élève</span></div>
                </div>
                <a href="/auth/logout" class="logout-btn">
                    <svg viewBox="0 0 24 24" fill="none" stroke="#ff6b6b" stroke-width="2" width="16" height="16"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
                    <span>Déconnexion</span>
                </a>
            </div>
        </aside>
        <main class="main-content">
            <header class="content-header">
                <div style="display:flex;align-items:center;gap:12px;">
                    <button class="menu-toggle" onclick="toggleSidebar()">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="24" height="24"><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
                    </button>
                    <h1><%= title %></h1>
                </div>
                <div style="display:flex;align-items:center;gap:12px;">
                    <div class="notif-btn" onclick="toggleNotifications()">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="22" height="22"><path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 0 1-3.46 0"/></svg>
                        <span class="badge-notif" id="badgeNotif">0</span>
                    </div>
                    <button onclick="toggleDarkMode()" class="toggle-btn-dashboard">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
                    </button>
                </div>
            </header>
            <div class="notif-dropdown" id="notifDropdown">
                <div style="padding:14px;font-weight:700;border-bottom:1px solid #f0f0f0;display:flex;justify-content:space-between;align-items:center;">
                    <span>🔔 Notifications</span>
                    <button onclick="viderNotifications()" style="background:none;border:none;color:#e74c3c;cursor:pointer;font-size:0.75rem;font-weight:600;">🗑️ Vider</button>
                </div>
                <div id="notifList" style="padding:20px;text-align:center;">Chargement...</div>
            </div>
            <div class="content-body">