<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="/css/dashboard.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <style>
        .nav-icon { stroke: #b0b0c0; stroke-width: 2; fill: none; transition: all 0.2s; }
        .nav-item:hover .nav-icon, .nav-item.active .nav-icon { stroke: white; }
        .notif-btn { position: relative; cursor: pointer; }
        .badge-notif { position: absolute; top: -6px; right: -6px; background: #e74c3c; color: white; border-radius: 50%; width: 20px; height: 20px; font-size: 0.65rem; display: none; align-items: center; justify-content: center; font-weight: 700; }
        .notif-dropdown { display: none; position: fixed; top: 60px; right: 16px; background: white; border-radius: 14px; box-shadow: 0 10px 40px rgba(0,0,0,0.15); width: 380px; max-height: 450px; overflow-y: auto; z-index: 200; }
        .notif-dropdown.active { display: block; }
        .notif-item { padding: 14px 16px; border-bottom: 1px solid #f0f0f0; cursor: pointer; }
        .notif-item:hover { background: #f8f9fa; }
        .notif-item.non-lu { background: #f0f4ff; border-left: 3px solid #002FA7; }
        .message-modal { display: none; position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0,0,0,0.5); z-index: 3000; align-items: center; justify-content: center; padding: 20px; }
        .message-modal.active { display: flex; }
        .message-modal-content { background: white; border-radius: 16px; padding: 24px; width: 100%; max-width: 550px; max-height: 80vh; overflow-y: auto; }
    </style>
</head>
<body>
    <div class="sidebar-overlay" id="sidebarOverlay" onclick="toggleSidebar()"></div>
    <div class="dashboard-container">
        <aside class="sidebar" id="sidebar">
            <div class="sidebar-header">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2"><path d="M22 10v6M2 10l10-5 10 5-10 5z"/><path d="M6 12v5c0 2 4 3 6 3s6-1 6-3v-5"/></svg>
                <h2>EducOS<span>-pro</span></h2>
            </div>
            <nav class="sidebar-nav">
                <div class="nav-section-title">ADMINISTRATION</div>
                <a href="/dashboard/admin" class="nav-item active">
                    <svg viewBox="0 0 24 24" class="nav-icon" width="20" height="20"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/></svg>
                    <span>Tableau de bord</span>
                </a>
                <a href="/dashboard/admin/utilisateurs" class="nav-item">
                    <svg viewBox="0 0 24 24" class="nav-icon" width="20" height="20"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
                    <span>Utilisateurs</span>
                </a>
                <a href="/dashboard/admin/etablissement" class="nav-item">
                    <svg viewBox="0 0 24 24" class="nav-icon" width="20" height="20"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
                    <span>Établissement</span>
                </a>
                <div class="nav-section-title">FINANCES</div>
                <a href="/dashboard/admin/paiements" class="nav-item">
                    <svg viewBox="0 0 24 24" class="nav-icon" width="20" height="20"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>
                    <span>Paiements</span>
                </a>
                <div class="nav-section-title">COMMUNICATION</div>
                <a href="/dashboard/admin/messages" class="nav-item">
                    <svg viewBox="0 0 24 24" class="nav-icon" width="20" height="20"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
                    <span>Messages</span>
                </a>
                <div class="nav-section-title">SYSTÈME</div>
                <a href="/dashboard/admin/parametres" class="nav-item">
                    <svg viewBox="0 0 24 24" class="nav-icon" width="20" height="20"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1 0 2.83 2 2 0 0 1-2.83 0l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-2 2 2 2 0 0 1-2-2v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83 0 2 2 0 0 1 0-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1-2-2 2 2 0 0 1 2-2h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 0-2.83 2 2 0 0 1 2.83 0l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 2-2 2 2 0 0 1 2 2v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 0 2 2 0 0 1 0 2.83l-.06.06A1.65 1.65 0 0 0 19.4 9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 2 2 2 2 0 0 1-2 2h-.09a1.65 1.65 0 0 0-1.51 1z"/></svg>
                    <span>Paramètres</span>
                </a>
            </nav>
            <div class="sidebar-footer">
                <div class="user-info-sidebar">
                    <div class="user-avatar"><%= user.prenom.charAt(0) %><%= user.nom.charAt(0) %></div>
                    <div class="user-details"><span class="user-name"><%= user.prenom %> <%= user.nom %></span><span class="user-role">Admin</span></div>
                </div>
                <a href="/auth/logout" class="logout-btn">
                    <svg viewBox="0 0 24 24" fill="none" stroke="#ff6b6b" stroke-width="2" width="16" height="16"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
                    <span>Déconnexion</span>
                </a>
            </div>
        </aside>
        <main class="main-content">
            <header class="content-header">
                <div style="display:flex;align-items:center;gap:12px;">
                    <button class="menu-toggle" onclick="toggleSidebar()">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="24" height="24"><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
                    </button>
                    <h1><%= title %></h1>
                </div>
                <div style="display:flex;align-items:center;gap:12px;">
                    <div class="notif-btn" onclick="toggleNotifications()">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="22" height="22"><path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 0 1-3.46 0"/></svg>
                        <span class="badge-notif" id="badgeNotif">0</span>
                    </div>
                    <button onclick="toggleDarkMode()" class="toggle-btn-dashboard">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
                    </button>
                </div>
            </header>
            <div class="notif-dropdown" id="notifDropdown">
                <div style="padding:14px;font-weight:700;border-bottom:1px solid #f0f0f0;display:flex;justify-content:space-between;align-items:center;">
    <span> Notifications</span>
    <button onclick="viderNotifications()" style="background:none;border:none;color:#e74c3c;cursor:pointer;font-size:0.75rem;font-weight:600;"> Vider</button>
</div>
                </div>
                <div id="notifList" style="padding:20px;text-align:center;color:#888;">Chargement...</div>
            </div>
            <div class="message-modal" id="messageModal">
                <div class="message-modal-content">
                    <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:16px;">
                        <h3 id="modalMessageSujet"></h3>
                        <button onclick="closeMessageModal()" style="background:none;border:none;font-size:1.5rem;cursor:pointer;color:#666;">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="24" height="24"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
                        </button>
                    </div>
                    <p style="color:#888;font-size:0.85rem;" id="modalMessageFrom"></p>
                    <div style="margin:16px 0;padding:20px;background:#f8f9fa;border-radius:10px;line-height:1.6;" id="modalMessageContenu"></div>
                    <div style="display:flex;justify-content:space-between;align-items:center;">
                        <p style="font-size:0.75rem;color:#999;margin:0;" id="modalMessageDate"></p>
                        <a href="#" id="modalMessageFichier" style="display:none;font-size:0.85rem;color:#002FA7;text-decoration:none;" download>
                            <svg viewBox="0 0 24 24" fill="none" stroke="#002FA7" stroke-width="2" width="16" height="16" style="vertical-align:middle;margin-right:4px;"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
                            Télécharger le fichier
                        </a>
                    </div>
                </div>
            </div>
            <div class="content-body">