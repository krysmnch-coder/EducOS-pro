<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="/css/dashboard.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <style>
        .nav-icon { stroke: #b0b0c0; stroke-width: 2; fill: none; transition: all 0.2s; }
        .nav-item:hover .nav-icon, .nav-item.active .nav-icon { stroke: white; }
        .notif-btn { position: relative; cursor: pointer; }
        .badge-notif { position: absolute; top: -6px; right: -6px; background: #e74c3c; color: white; border-radius: 50%; width: 20px; height: 20px; font-size: 0.65rem; display: none; align-items: center; justify-content: center; font-weight: 700; }
        .notif-dropdown { display: none; position: fixed; top: 60px; right: 16px; background: white; border-radius: 14px; box-shadow: 0 10px 40px rgba(0,0,0,0.15); width: 380px; max-height: 450px; overflow-y: auto; z-index: 200; }
        .notif-dropdown.active { display: block; }
        .notif-item { padding: 14px 16px; border-bottom: 1px solid #f0f0f0; cursor: pointer; }
        .notif-item:hover { background: #f8f9fa; }
        .notif-item.non-lu { background: #f0f4ff; border-left: 3px solid #002FA7; }
        .message-modal { display: none; position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0,0,0,0.5); z-index: 3000; align-items: center; justify-content: center; padding: 20px; }
        .message-modal.active { display: flex; }
        .message-modal-content { background: white; border-radius: 16px; padding: 24px; width: 100%; max-width: 550px; max-height: 80vh; overflow-y: auto; }
        .enfant-mini { display: flex; align-items: center; gap: 8px; padding: 6px 10px; border-radius: 8px; cursor: pointer; margin-bottom: 2px; transition: all 0.2s; }
        .enfant-mini:hover { background: rgba(255,255,255,0.1); }
        .enfant-mini.active { background: rgba(255,255,255,0.2); }
        .enfant-mini .enfant-dot { width: 7px; height: 7px; border-radius: 50%; background: #4a7dff; flex-shrink: 0; }
        .enfant-mini.active .enfant-dot { background: #27ae60; }
        .enfant-mini span { font-size: 0.72rem; color: #bbb; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
        .enfant-mini.active span { color: white; }
        .tab-content { display: none; }
        .tab-content.active { display: block; }
        .tabs { display: flex; gap: 4px; margin-bottom: 20px; flex-wrap: wrap; background: #f5f5f5; padding: 4px; border-radius: 12px; }
        .tab { padding: 10px 16px; border: none; background: transparent; cursor: pointer; border-radius: 10px; font-weight: 600; font-size: 0.82rem; font-family: 'Inter', sans-serif; white-space: nowrap; display: flex; align-items: center; gap: 6px; color: #444; }
        .tab svg { stroke: #444; }
        .tab.active { background: #002FA7; color: white; }
        .tab.active svg { stroke: white; }
        .tab:hover:not(.active) { background: #e0e0e0; }
    </style>
</head>
<body>
    <div class="sidebar-overlay" id="sidebarOverlay" onclick="toggleSidebar()"></div>
    <div class="dashboard-container">
        <aside class="sidebar" id="sidebar">
            <div class="sidebar-header">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2"><path d="M22 10v6M2 10l10-5 10 5-10 5z"/><path d="M6 12v5c0 2 4 3 6 3s6-1 6-3v-5"/></svg>
                <h2>EducOS<span>-pro</span></h2>
            </div>
            <nav class="sidebar-nav">
                <div class="nav-section-title">ENFANTS</div>
                <div id="enfantsSidebar" style="padding:0 8px;margin-bottom:8px;"></div>
                <div class="nav-section-title">SCOLARITÉ</div>
                <a href="#" class="nav-item active" onclick="showTab('notes')">
                    <svg viewBox="0 0 24 24" class="nav-icon" width="20" height="20"><path d="M9 11l3 3L22 4"/></svg>
                    <span>Notes</span>
                </a>
                <a href="#" class="nav-item" onclick="showTab('edt')">
                    <svg viewBox="0 0 24 24" class="nav-icon" width="20" height="20"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/></svg>
                    <span>Emploi du temps</span>
                </a>
                <a href="#" class="nav-item" onclick="showTab('ressources')">
                    <svg viewBox="0 0 24 24" class="nav-icon" width="20" height="20"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/></svg>
                    <span>Ressources</span>
                </a>
                <a href="#" class="nav-item" onclick="showTab('absences')">
                    <svg viewBox="0 0 24 24" class="nav-icon" width="20" height="20"><circle cx="12" cy="12" r="10"/><line x1="4.93" y1="4.93" x2="19.07" y2="19.07"/></svg>
                    <span>Absences</span>
                </a>
                <a href="#" class="nav-item" onclick="showTab('sanctions')">
                    <svg viewBox="0 0 24 24" class="nav-icon" width="20" height="20"><polygon points="7.86 2 16.14 2 22 7.86 22 16.14 16.14 22 7.86 22 2 16.14 2 7.86 7.86 2"/></svg>
                    <span>Sanctions</span>
                </a>
                <div class="nav-section-title">INSCRIPTION & PAIEMENT</div>
                <a href="#" class="nav-item" onclick="showTab('inscription')">
                    <svg viewBox="0 0 24 24" class="nav-icon" width="20" height="20"><path d="M16 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="8.5" cy="7" r="4"/><line x1="20" y1="8" x2="20" y2="14"/><line x1="23" y1="11" x2="17" y2="11"/></svg>
                    <span>Inscrire un enfant</span>
                </a>
                <a href="#" class="nav-item" onclick="showTab('paiement')">
                    <svg viewBox="0 0 24 24" class="nav-icon" width="20" height="20"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>
                    <span>Paiements</span>
                </a>
                <div class="nav-section-title">COMMUNICATION</div>
                <a href="#" class="nav-item" onclick="showTab('messages')">
                    <svg viewBox="0 0 24 24" class="nav-icon" width="20" height="20"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
                    <span>Messages</span>
                </a>
            </nav>
            <div class="sidebar-footer">
                <div class="user-info-sidebar">
                    <div class="user-avatar"><%= user.prenom.charAt(0) %><%= user.nom.charAt(0) %></div>
                    <div class="user-details"><span class="user-name"><%= user.prenom %> <%= user.nom %></span><span class="user-role">Parent</span></div>
                </div>
                <a href="/auth/logout" class="logout-btn">
                    <svg viewBox="0 0 24 24" fill="none" stroke="#ff6b6b" stroke-width="2" width="16" height="16"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
                    <span>Déconnexion</span>
                </a>
            </div>
        </aside>
        <main class="main-content">
            <header class="content-header">
                <div style="display:flex;align-items:center;gap:12px;">
                    <button class="menu-toggle" onclick="toggleSidebar()">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="24" height="24"><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
                    </button>
                    <h1><%= title %></h1>
                </div>
                <div style="display:flex;align-items:center;gap:12px;">
                    <div class="notif-btn" onclick="toggleNotifications()">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="22" height="22"><path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 0 1-3.46 0"/></svg>
                        <span class="badge-notif" id="badgeNotif">0</span>
                    </div>
                    <button onclick="toggleDarkMode()" class="toggle-btn-dashboard">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
                    </button>
                </div>
            </header>
            <div class="notif-dropdown" id="notifDropdown">
               <div style="padding:14px;font-weight:700;border-bottom:1px solid #f0f0f0;display:flex;justify-content:space-between;align-items:center;">
    <span> Notifications</span>
    <button onclick="viderNotifications()" style="background:none;border:none;color:#e74c3c;cursor:pointer;font-size:0.75rem;font-weight:600;"> Vider</button>
</div>
            </div>
            <div class="message-modal" id="messageModal">
                <div class="message-modal-content">
                    <div style="display:flex;justify-content:space-between;margin-bottom:16px;">
                        <h3 id="modalMessageSujet"></h3>
                        <button onclick="closeMessageModal()" style="background:none;border:none;font-size:1.5rem;cursor:pointer;">✕</button>
                    </div>
                    <p id="modalMessageFrom" style="color:#888;"></p>
                    <div id="modalMessageContenu" style="padding:20px;background:#f8f9fa;border-radius:10px;margin:12px 0;"></div>
                    <p id="modalMessageDate" style="color:#999;"></p>
                    <div id="modalMessageFichier"></div>
                </div>
            </div>
            <div class="content-body">