            </div>
        </main>
    </div>
    <script>
        function toggleDarkMode() {
            document.body.classList.toggle('dark-mode');
            localStorage.setItem('darkMode', document.body.classList.contains('dark-mode'));
        }
        if (localStorage.getItem('darkMode') === 'true') document.body.classList.add('dark-mode');
        
        function toggleSidebar() {
            document.getElementById('sidebar').classList.toggle('open');
            document.getElementById('sidebarOverlay').classList.toggle('active');
        }
        
        function goToMessagerie() {
            // Aller à l'onglet messages
            document.querySelectorAll('.tab-content').forEach(c => c.classList.remove('active'));
            document.querySelectorAll('.tab').forEach(b => b.classList.remove('active'));
            var msgTab = document.getElementById('tab-messages');
            if (msgTab) {
                msgTab.click();
            }
            if (window.innerWidth <= 768) toggleSidebar();
        }
        
        async function toggleNotifications() {
            var dd = document.getElementById('notifDropdown');
            dd.classList.toggle('active');
            if (dd.classList.contains('active')) loadNotifications();
        }
        async function loadNotifications() {
            try {
                var r = await fetch('/vie-scolaire/api/notifications');
                var notifs = await r.json();
                var html = '';
                if (!notifs.length) {
                    html = '<div style="padding:20px;">Aucune notification</div>';
                } else {
                    notifs.forEach(function(n) {
                        html += '<div class="notif-item ' + (n.lu ? '' : 'non-lu') + '" onclick="openNotificationMessage(' + n.id + ', ' + (n.message_id||0) + ')">';
                        html += '<div style="font-weight:600;">' + (n.titre||'') + '</div>';
                        html += '<div style="font-size:0.78rem;color:#666;">' + (n.message||'').substring(0,80) + '</div>';
                        html += '<div style="font-size:0.7rem;color:#999;">' + new Date(n.created_at).toLocaleString('fr-FR') + '</div>';
                        html += '</div>';
                    });
                }
                document.getElementById('notifList').innerHTML = html;
                var badge = document.getElementById('badgeNotif');
                var nonLues = notifs.filter(function(n) { return !n.lu; }).length;
                badge.textContent = nonLues;
                badge.style.display = nonLues > 0 ? 'flex' : 'none';
            } catch(e) {}
        }
        async function openNotificationMessage(notifId, messageId) {
            await fetch('/vie-scolaire/api/notifications/' + notifId + '/read', { method: 'PUT' });
            document.getElementById('notifDropdown').classList.remove('active');
            if (messageId && messageId > 0) {
                try {
                    var r = await fetch('/vie-scolaire/api/messages/' + messageId);
                    var msg = await r.json();
                    document.getElementById('modalMessageSujet').textContent = msg.sujet || '';
                    document.getElementById('modalMessageFrom').textContent = 'De: ' + (msg.exp_nom||'') + ' ' + (msg.exp_prenom||'');
                    document.getElementById('modalMessageContenu').textContent = msg.contenu || '';
                    document.getElementById('modalMessageDate').textContent = new Date(msg.created_at).toLocaleString('fr-FR');
                    if (msg.fichier) {
                        document.getElementById('modalMessageFichier').href = '/uploads/' + msg.fichier;
                        document.getElementById('modalMessageFichier').style.display = 'inline-block';
                    } else {
                        document.getElementById('modalMessageFichier').style.display = 'none';
                    }
                } catch(e) {}
            }
            document.getElementById('messageModal').classList.add('active');
            loadNotifications();
        }
        function closeMessageModal() { document.getElementById('messageModal').classList.remove('active'); }
        document.addEventListener('click', function(e) {
            if (!e.target.closest('.notif-btn') && !e.target.closest('#notifDropdown')) {
                document.getElementById('notifDropdown').classList.remove('active');
            }
        });
    </script>
</body>
</html>