# Fichier généré par Gemini Code Assist
# Ce fichier permet d'exclure les fichiers et dossiers non nécessaires du contrôle de version.

# Dépendances
/node_modules

# Fichiers d'environnement
# Le fichier .env contient des secrets (clés d'API, secrets de session) et ne doit JAMAIS être versionné.
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Fichiers de log
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Base de données locale
