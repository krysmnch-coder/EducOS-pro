<!DOCTYPE html>
<html lang="fr">
<head>
  <%- include('partials/head') %>
</head>
<body>
  <div class="page-shell container-xl py-4">
    <%- include('partials/header') %>

    <main class="page-main">
      <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="h2 fw-bold">Mon Profil</h1>
      </div>
      
      <%- include('partials/messages') %>
      
      <div class="card shadow-sm border-0">
        <div class="card-body p-4 p-md-5">
          <div class="row g-5">
            <!-- Colonne de l'avatar -->
            <div class="col-md-4 text-center">
              <form action="/profile/avatar" method="POST" enctype="multipart/form-data" id="avatarForm">
                <div class="profile-avatar-wrapper">
                  <img src="<%= user.avatar_url || '/img/user.png' %>" alt="Votre avatar" class="profile-avatar">
                  <label for="avatarUpload" class="upload-label" title="Changer d'avatar">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M23 19a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4l2-3h6l2 3h4a2 2 0 0 1 2 2z"></path><circle cx="12" cy="13" r="4"></circle></svg>
                  </label>
                  <input type="file" name="avatar" id="avatarUpload" accept="image/png, image/jpeg, image/gif">
                </div>
              </form>
              <h2 class="h4 fw-bold mt-3"><%= user.name %></h2>
              <p><span class="badge bg-primary bg-opacity-25 text-primary-emphasis rounded-pill fs-6"><%= user.role %></span></p>
              <p class="text-muted small mt-3">Membre depuis le <%= new Date(user.created_at).toLocaleDateString('fr-FR', { day: 'numeric', month: 'long', year: 'numeric' }) %></p>
            </div>

            <!-- Colonne des informations -->
            <div class="col-md-8">
              <h3 class="h5 fw-bold mb-4">Informations du compte</h3>
              <form action="/profile/update" method="POST">
                <div class="mb-3">
                  <label for="name" class="form-label">Nom complet</label>
                  <input type="text" class="form-control" id="name" name="name" value="<%= user.name %>" required>
                </div>
                <div class="mb-3">
                  <label for="email" class="form-label">Adresse e-mail</label>
                  <input type="email" class="form-control" id="email" name="email" value="<%= user.email %>" readonly disabled>
                  <div class="form-text">L'adresse e-mail ne peut pas être modifiée.</div>
                </div>
                <div class="mb-4">
                  <label for="phone_number" class="form-label">Numéro de téléphone</label>
                  <input type="tel" class="form-control" id="phone_number" name="phone_number" value="<%= user.phone_number || '' %>" placeholder="Ajouter un numéro de téléphone">
                </div>
                
                <!-- Affichage des champs spécifiques au rôle (non modifiables ici) -->
                <% if (user.role === 'professeur' && user.subject) { %>
                  <div class="mb-3">
                    <label class="form-label">Matière enseignée</label>
                    <input type="text" class="form-control" value="<%= user.subject %>" readonly disabled>
                  </div>
                <% } %>

                <button type="submit" class="btn btn-primary">Enregistrer les modifications</button>
              </form>
            </div>
          </div>
        </div>
      </div>
    </main>
  </div>

  <script src="/js/theme.js"></script>
  <script>
    document.getElementById('avatarUpload')?.addEventListener('change', () => {
      if (document.getElementById('avatarUpload').files.length > 0) {
        document.getElementById('avatarForm').submit();
      }
    });
  </script>
  <%- include('partials/footer') %>
</body>
</html>