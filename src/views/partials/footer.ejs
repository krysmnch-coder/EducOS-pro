<!-- Socket.IO Client Library -->
<script src="/socket.io/socket.io.js"></script>

<!-- Bootstrap JS Bundle (nécessaire pour les dropdowns, modales, etc.) -->
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js" integrity="sha384-C6RzsynM9kWDrMNeT87bh95OGNyZPhcTNXj1NW7RuBCsyN/o0jlpcV8Qyq46cDfL" crossorigin="anonymous"></script>

<!-- Feather Icons (utilisé pour les icônes de la navbar) -->
<script src="https://cdn.jsdelivr.net/npm/feather-icons/dist/feather.min.js"></script>
<script>
  // Initialise les icônes Feather sur la page
  feather.replace();
</script>

<!-- Logique de chat partagée (utilisée par le widget et la page de chat) -->
<script src="/js/chat-logic.js"></script>

<!-- Script du widget de chat (ne s'exécute pas sur la page de chat elle-même) -->
<% if (currentPath !== '/chat') { %>
  <script src="/js/chat-widget.js"></script>
<% } %>

<!-- NOUVEAU: Script pour les améliorations de l'interface (scroll navbar, etc.) -->
<script src="/js/ui-enhancements.js"></script>