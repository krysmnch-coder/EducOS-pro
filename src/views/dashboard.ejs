<%- include('partials/head') %>
<%- include('partials/navbar') %>

<div class="container page-shell py-4">
    <div class="themed-container">

        <%- include('partials/messages') %>

        <%# --- Section de bienvenue --- %>
        <div class="d-flex align-items-center mb-5">
            <div class="rounded-circle me-4 d-flex align-items-center justify-content-center bg-primary text-white" style="width: 80px; height: 80px; font-size: 2.5rem; font-weight: 500; background-image: url('<%= user.avatar_url %>'); background-size: cover; background-position: center;">
                <% if (!user.avatar_url) { %>
                    <%= user.name.charAt(0).toUpperCase() %>
                <% } %>
            </div>
            <div>
                <h1 class="h2 mb-0">Bonjour, <%= user.name %> !</h1>
                <% if (typeof parentData !== 'undefined' && parentData.selectedChild) { %>
                    <p class="lead text-muted mb-0">Vous consultez le profil de : <strong><%= parentData.selectedChild.name %></strong>.</p>
                <% } else { %>
                    <p class="lead text-muted mb-0">Ravi de vous revoir. Voici vos raccourcis.</p>
                <% } %>
            </div>
        </div>

        <%# --- Section de sélection de l'enfant pour les parents --- %>
        <% if (user.role === 'PARENT') { %>
            <div class="child-selector-wrapper card mb-5">
                <div class="card-body d-md-flex align-items-center justify-content-between">
                    <% if (typeof parentData !== 'undefined' && parentData.children && parentData.children.length > 0) { %>
                        <form action="/select-child" method="POST" class="d-flex align-items-center gap-3 flex-wrap">
                            <label for="childSelector" class="form-label mb-0 fw-bold">Suivre un enfant :</label>
                            <select name="childId" id="childSelector" class="form-select" style="min-width: 250px;" onchange="this.form.submit()">
                                <% parentData.children.forEach(child => { %>
                                    <option value="<%= child.id %>" <%= (parentData.selectedChild && parentData.selectedChild.id === child.id) ? 'selected' : '' %>>
                                        <%= child.name %>
                                    </option>
                                <% }); %>
                            </select>
                        </form>
                    <% } else { %>
                        <p class="text-muted mb-0">Aucun enfant n'est actuellement lié à votre compte. Vous pouvez en ajouter depuis l'administration de votre établissement.</p>
                    <% } %>
                </div>
            </div>
        <% } %>

        <%# --- Section des Raccourcis (Widgets) --- %>
        <% if (typeof widgets !== 'undefined' && widgets.length > 0) { %>
            <div class="row g-4">
                <% widgets.forEach(widget => { %>
                <div class="col-xl-3 col-md-6 mb-4">
                    <a href="<%= (user.role === 'PARENT' && (typeof parentData === 'undefined' || !parentData.selectedChild)) ? '#' : widget.link %>" class="text-decoration-none shortcut-link <%= (user.role === 'PARENT' && (typeof parentData === 'undefined' || !parentData.selectedChild)) ? 'disabled' : '' %>" data-shortcut-key="<%= widget.key %>">
                    <div class="card dashboard-stat h-100">
                        <div class="card-body text-center">
                        <div class="stat-icon mb-3">
                            <i data-feather="<%= widget.icon %>"></i>
                        </div>
                        <h5 class="card-title mb-2"><%= widget.title %></h5>
                        <p class="card-text text-muted small"><%= widget.description %></p>
                        </div>
                    </div>
                    </a>
                </div>
                <% }); %>
            </div>
        <% } else { %>
            <div class="text-center py-5">
                <p class="text-muted">Aucun raccourci n'est configuré pour votre rôle pour le moment.</p>
            </div>
        <% } %>
    </div>
</div>

<script>
    document.addEventListener('DOMContentLoaded', function() {
        if (typeof feather !== 'undefined') {
            feather.replace();
        }

        // Animation des raccourcis
        const socket = io(); // Connexion au namespace par défaut
        socket.on('shortcutHighlight', function(data) {
            if (data.shortcutKey) {
                const shortcut = document.querySelector(`.shortcut-link[data-shortcut-key="${data.shortcutKey}"]`);
                if (shortcut) {
                    const card = shortcut.querySelector('.dashboard-stat');
                    if (card) {
                        card.classList.add('is-pulsing');
                        // Retirer la classe après l'animation pour qu'elle puisse rejouer
                        setTimeout(() => { card.classList.remove('is-pulsing'); }, 1200); // Durée de l'animation
                    }
                }
            }
        });
    });
</script>

<%- include('partials/page-end-scripts') %>
<%- include('partials/footer') %>