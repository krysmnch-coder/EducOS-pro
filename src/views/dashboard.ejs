<%- include('partials/head') %>
<%- include('partials/navbar') %>

<div class="container page-shell py-4">
    <div class="themed-container">

        <%- include('partials/messages') %>

        <%# --- Section de bienvenue --- %>
        <div class="d-flex align-items-center mb-5">
            <% if (user.avatar_url) { %>
                <img src="<%= user.avatar_url %>" alt="Avatar" class="rounded-circle me-4" style="width: 80px; height: 80px; object-fit: cover; border: 3px solid var(--card-border-color);">
            <% } else { %>
                <div class="rounded-circle me-4 d-flex align-items-center justify-content-center bg-primary text-white" style="width: 80px; height: 80px; font-size: 2.5rem; font-weight: 500;">
                    <%= user.name.charAt(0).toUpperCase() %>
                </div>
            <% } %>
            <div>
                <h1 class="h2 mb-0">Bonjour, <%= user.name %> !</h1>
                <p class="lead text-muted mb-0">Ravi de vous revoir. Voici vos raccourcis.</p>
            </div>
        </div>

        <%# --- Section des Raccourcis (Widgets) --- %>
        <% if (typeof widgets !== 'undefined' && widgets.length > 0) { %>
            <div class="row">
                <% widgets.forEach(widget => { %>
                <div class="col-xl-3 col-md-6 mb-4">
                    <a href="<%= widget.link %>" class="text-decoration-none">
                    <div class="card dashboard-stat h-100">
                        <div class="card-body text-center">
                        <div class="stat-icon mb-3">
                            <i data-feather="<%= widget.icon %>"></i>
                        </div>
                        <h5 class="card-title mb-2"><%= widget.title %></h5>
                        <p class="card-text text-muted small"><%= widget.description %></p>
                        </div>
                    </div>
                    </a>
                </div>
                <% }); %>
            </div>
        <% } else { %>
            <div class="text-center py-5">
                <p class="text-muted">Aucun raccourci n'est configuré pour votre rôle pour le moment.</p>
            </div>
        <% } %>
    </div>
</div>

<script>
    document.addEventListener('DOMContentLoaded', function() {
        if (typeof feather !== 'undefined') {
            feather.replace();
        }
    });
</script>

<%- include('partials/page-end-scripts') %>
<%- include('partials/footer') %>