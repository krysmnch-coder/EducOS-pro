<%- include('partials/head') %>
<%- include('partials/navbar') %>

<div class="container page-shell py-4">
    <div class="themed-container">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h1 class="h3 mb-0"><%= title %></h1>
        </div>

        <%- include('partials/messages') %>

        <%# --- Section de bienvenue --- %>
        <div class="mb-5">
            <h2 class="mb-1">Bonjour, <%= user.name %> !</h2>
            <p class="lead text-muted">Voici les actions rapides disponibles pour votre rôle.</p>
        </div>

        <%# --- Section des Raccourcis (Widgets) --- %>
        <% if (typeof widgets !== 'undefined' && widgets.length > 0) { %>
            <h3 class="mb-4">Vos raccourcis</h3>
            <div class="row">
                <% widgets.forEach(widget => { %>
                <div class="col-xl-3 col-md-6 mb-4">
                    <a href="<%= widget.link %>" class="text-decoration-none">
                    <div class="card dashboard-stat h-100">
                        <div class="card-body text-center">
                        <div class="stat-icon mb-3">
                            <i data-feather="<%= widget.icon %>" width="36" height="36"></i>
                        </div>
                        <h5 class="card-title mb-2"><%= widget.title %></h5>
                        <p class="card-text text-muted small"><%= widget.description %></p>
                        </div>
                    </div>
                    </a>
                </div>
                <% }); %>
            </div>
        <% } else { %>
            <div class="text-center py-5">
                <p class="text-muted">Aucun raccourci n'est configuré pour votre rôle pour le moment.</p>
            </div>
        <% } %>
    </div>
</div>

<script>
    document.addEventListener('DOMContentLoaded', function() {
        if (typeof feather !== 'undefined') {
            feather.replace();
        }
    });
</script>

<%- include('partials/page-end-scripts') %>
<%- include('partials/footer') %>