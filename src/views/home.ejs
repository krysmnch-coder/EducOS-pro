<!DOCTYPE html>
<html lang="fr">
  <head>
    <%- include('partials/head', { title: 'Accueil | EducOS-pro', excludeMainCss: true }) %>
    
    <style>
      /* Reset et styles de base */
      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }

      html {
        scroll-behavior: smooth;
      }

      body {
        font-family: 'Inter', sans-serif;
        min-height: 100vh;
        transition: background-color 0.3s ease, color 0.3s ease;
      }

      /* Mode clair */
      html[data-theme="light"] body { /* Applique un voile semi-transparent sur l'image de fond */
        background-color: rgba(240, 242, 245, 0.8);
        color: #1a1a2e;
      }
      html[data-theme="light"] .bg-body-tertiary {
        background: rgba(255,255,255,0.2) !important; /* Rendre la navbar du home plus transparente */
        border: 1px solid rgba(0,0,0,0.05);
        box-shadow: 0 4px 20px rgba(0,0,0,0.05);
      }
      html[data-theme="light"] .nav-link {
        color: #4b5563 !important;
      }
      html[data-theme="light"] .nav-link:hover {
        color: #0d6efd !important;
      }
      html[data-theme="light"] .nav-link svg {
        color: #4b5563 !important;
      }
      html[data-theme="light"] .nav-link:hover svg {
        color: #0d6efd !important;
      }
      html[data-theme="light"] .nav-link .nav-text {
        color: #4b5563 !important;
      }
      html[data-theme="light"] .nav-link:hover .nav-text {
        color: #0d6efd !important;
      }
      html[data-theme="light"] .nav-divider {
        color: #d1d5db !important;
      }
      html[data-theme="light"] .nav-icon-btn {
        color: #4b5563 !important;
      }
      html[data-theme="light"] .nav-icon-btn:hover {
        color: #0d6efd !important;
        background-color: rgba(13, 110, 253, 0.08) !important;
      }
      html[data-theme="light"] .text-white-75 {
        color: rgba(0,0,0,0.75) !important;
      }
      html[data-theme="light"] .navbar-brand span {
        color: #1a1a2e !important;
      }
      html[data-theme="light"] .navbar-toggler svg {
        stroke: #1a1a2e !important;
      }
      html[data-theme="light"] .badge.bg-success {
        background: #198754 !important;
        color: white !important;
      }
      body[data-theme="light"] .btn-outline-light {
        border-color: rgba(0,0,0,0.2);
        color: #1a1a2e;
      }
      html[data-theme="light"] .btn-outline-light:hover {
        background: rgba(0,0,0,0.05);
        border-color: rgba(0,0,0,0.3);
      }
      html[data-theme="light"] h1, 
      html[data-theme="light"] h2, 
      html[data-theme="light"] h3,
      html[data-theme="light"] h4,
      html[data-theme="light"] h5 {
        color: #1a1a2e !important;
      }

      /* Mode sombre */
      html[data-theme="dark"] body { /* Applique un voile semi-transparent sur l'image de fond */
        background-color: rgba(10, 10, 26, 0.8);
        color: #ffffff;
      }
      html[data-theme="dark"] .bg-body-tertiary {
        background: rgba(17, 24, 39, 0.2) !important; /* Rendre la navbar du home plus transparente */
        border: 1px solid rgba(255,255,255,0.05);
      }
      html[data-theme="dark"] .text-white-75 {
        color: rgba(255,255,255,0.75) !important;
      }
      html[data-theme="dark"] .navbar-brand span {
        color: #ffffff !important;
      }
      html[data-theme="dark"] .nav-link {
        color: #e0e0e0 !important;
      }
      html[data-theme="dark"] .nav-link:hover {
        color: #ffffff !important;
      }
      html[data-theme="dark"] .nav-link svg {
        color: #e0e0e0 !important;
      }
      html[data-theme="dark"] .nav-link:hover svg {
        color: #ffffff !important;
      }
      html[data-theme="dark"] .nav-link .nav-text {
        color: #e0e0e0 !important;
      }
      html[data-theme="dark"] .nav-link:hover .nav-text {
        color: #ffffff !important;
      }
      html[data-theme="dark"] .nav-divider {
        color: #3d3d5c !important;
      }
      html[data-theme="dark"] .nav-icon-btn {
        color: #e0e0e0 !important;
      }
      html[data-theme="dark"] .nav-icon-btn:hover {
        color: #ffffff !important;
        background-color: rgba(13, 110, 253, 0.15) !important;
      }
      html[data-theme="dark"] .navbar-toggler svg {
        stroke: #e0e0e0 !important;
      }

      /* Navbar fixe */
      .navbar {
        position: fixed;
        top: 1rem;
        left: 50%;
        transform: translateX(-50%);
        width: calc(100% - 40px);
        max-width: 1400px;
        z-index: 1030;
      }
      /* Navbar */
      .nav-item-spaced {
        margin: 0 12px !important;
      }
      .nav-icon-btn {
        width: 44px;
        height: 44px;
        border-radius: 12px;
        transition: all 0.2s ease;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        background: transparent;
        border: none;
      }
      .nav-divider {
        font-size: 20px;
        font-weight: 300;
        padding: 0 8px;
        opacity: 0.5;
      }
      .navbar-toggler {
        border: none !important;
        padding: 8px !important;
      }
      .navbar-toggler:focus {
        box-shadow: none !important;
      }
      .navbar-toggler-icon {
        background-image: none !important;
        display: flex;
        align-items: center;
        justify-content: center;
      }
      .nav-link {
        transition: color 0.2s ease;
        text-decoration: none;
      }
      .nav-link .nav-text {
        font-size: 0.75rem;
      }
      .page-shell {
        max-width: 1400px;
        margin: 0 auto;
        padding: 0 20px 24px 20px; /* Le padding-top n'est plus nécessaire ici */
      }

      /* Boutons */
      .btn-success {
        border: none;
        padding: 12px 32px;
        font-weight: 600;
        transition: all 0.3s ease;
      }
      .btn-success:hover {
        transform: scale(1.02);
      }
      .btn-outline-light {
        padding: 12px 32px;
        font-weight: 600;
        transition: all 0.3s ease;
      }
      .btn-outline-light:hover {
        transform: scale(1.02);
      }

      /* Nouveaux styles pour la refonte */
      .hero-section {
        position: relative;
        overflow: hidden; /* S'assure que le carrousel ne dépasse pas */
        min-height: 100vh; /* Prend toute la hauteur de la fenêtre */
        padding-top: 100px; /* Ajoute un padding pour que le contenu ne soit pas sous la navbar */
        display: flex;
        align-items: center;
        justify-content: center;
        text-align: center;
      }
      .hero-carousel {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        z-index: 0;
      }
      .hero-carousel .carousel-inner,
      .hero-carousel .carousel-item {
        height: 100%;
      }
      .hero-carousel .carousel-item img {
        object-fit: cover;
        height: 100%;
        width: 100%;
      }
      /* Voile pour la lisibilité du texte */
      .hero-carousel::after {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background-color: rgba(10, 10, 26, 0.7); /* Voile sombre par défaut */
      }
      html[data-theme="light"] .hero-carousel::after {
        background-color: rgba(255, 255, 255, 0.5); /* Voile clair pour le thème light */
      }
      .hero-section > .container {
        position: relative;
        z-index: 1;
      }
      .hero-section .display-3 {
        font-weight: 800;
        letter-spacing: -1.5px;
      }
      .hero-section .lead {
        max-width: 700px;
        margin: 1.5rem auto 2.5rem auto;
      }
      html[data-theme="light"] .hero-section .lead {
        color: #4a5568 !important;
      }
      html[data-theme="dark"] .hero-section .lead {
        color: rgba(255,255,255,0.8) !important;
      }
      html[data-theme="dark"] .hero-section .display-3 {
        color: #ffffff !important;
      }

      .scroll-down-container {
        margin-top: 5rem; /* Espace sous les boutons, positionnement relatif */
        z-index: 2;
      }
      .scroll-down-link {
        color: white;
        text-decoration: none;
        animation: subtle-bounce 2.5s infinite; /* Animation plus moderne */
      }
      html[data-theme="light"] .scroll-down-link {
        color: #1a1a2e;
      }

      @keyframes subtle-bounce {
        0%, 100% {
          transform: translateY(0);
        }
        50% {
          transform: translateY(8px);
        }
      }

      .stats-section {
        padding: 2rem;
      }
      .stats-section .stat-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 10px 30px rgba(0,0,0,0.1);
      }
      .stats-section .stat-number {
        font-size: 2.5rem;
        font-weight: 700;
      }
      .stats-section .stat-label {
        font-size: 0.9rem;
        text-transform: uppercase;
        letter-spacing: 0.5px;
      }

      .feature-showcase {
        padding: 4rem 0;
      }
      .feature-item {
        margin-bottom: 6rem;
      }
      .feature-item:last-child {
        margin-bottom: 0;
      }
      .feature-image {
        border-radius: 16px;
        overflow: hidden;
        box-shadow: 0 15px 40px rgba(0,0,0,0.15);
      }
      html[data-theme="dark"] .feature-image {
         box-shadow: 0 15px 40px rgba(0,0,0,0.3);
      }
      .feature-text .feature-tag {
        display: inline-block;
        padding: 6px 16px;
        border-radius: 20px;
        font-size: 0.7rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 1px;
        margin-bottom: 1rem;
      }
      .feature-text h2 {
        font-weight: 700;
        margin-bottom: 1rem;
      }
      .feature-text p {
        font-size: 1.1rem;
        line-height: 1.7;
      }
      html[data-theme="light"] .feature-text p {
        color: #4a5568 !important;
      }
      html[data-theme="dark"] .feature-text p {
        color: rgba(255,255,255,0.7) !important;
      }

      .cta-section {
        border-radius: 20px;
        padding: 4rem 2rem;
      }
      .cta-section h2 {
        font-weight: 700;
      }

      /* Sections avec fond blanc */
      .white-bg-section {
        background-color: #ffffff;
        border-radius: 20px;
      }
      .white-bg-section .stat-card {
        background: transparent !important;
        border: none !important;
        box-shadow: none !important;
        padding: 0; /* Le padding est maintenant sur la section parente */
      }
      .white-bg-section .stat-card:hover {
        transform: none; /* On désactive l'effet sur la carte individuelle */
      }
      .white-bg-section, .white-bg-section h2, .white-bg-section .stat-number {
        color: #1a1a2e !important;
      }
      .white-bg-section .lead, .white-bg-section .stat-label, .white-bg-section p {
        color: #4a5568 !important;
      }

      .animated-section {
        animation: fadeInUp 0.8s ease-out forwards;
        opacity: 0;
      }
      /* Couleurs des tags */
      .tag-communication { background-color: rgba(59, 130, 246, 0.15); color: #60a5fa; }
      .tag-pedagogy { background-color: rgba(16, 185, 129, 0.15); color: #34d399; }
      .tag-organization { background-color: rgba(251, 191, 36, 0.15); color: #fbbf24; }

      html[data-theme="light"] .tag-communication { background-color: rgba(13, 110, 253, 0.1); color: #0d6efd; }
      html[data-theme="light"] .tag-pedagogy { background-color: rgba(25, 135, 84, 0.1); color: #198754; }
      html[data-theme="light"] .tag-organization { background-color: rgba(255, 193, 7, 0.15); color: #d4a800; }

      /* Theme toggle button icons */
      /* Par défaut (thème clair), on affiche l'icône de la lune pour passer au thème sombre */
      #themeToggle .moon-icon { display: block; }
      #themeToggle .sun-icon { display: none; }
      /* En thème sombre, on affiche l'icône du soleil pour passer au thème clair */
      html[data-theme="dark"] #themeToggle .moon-icon { display: none; }
      html[data-theme="dark"] #themeToggle .sun-icon { display: block; }

      /* Bouton Retour en Haut */
      .back-to-top-btn {
        position: fixed;
        bottom: 30px;
        right: 30px;
        width: 50px;
        height: 50px;
        border-radius: 16px; /* Plus moderne */
        background: rgba(17, 24, 39, 0.3); /* Fond transparent comme la navbar */
        color: white;
        border: 1px solid rgba(255, 255, 255, 0.1);
        box-shadow: 0 4px 20px rgba(0, 0, 0, 0.2);
        backdrop-filter: blur(8px);
        -webkit-backdrop-filter: blur(8px);
        cursor: pointer;
        transition: opacity 0.3s ease, transform 0.3s ease, background-color 0.3s ease;
        z-index: 1000;
        display: flex;
        align-items: center;
        justify-content: center;
        opacity: 0;
        transform: translateY(20px);
        pointer-events: none;
        text-decoration: none;
      }
      .back-to-top-btn.visible {
        opacity: 1;
        transform: translateY(0);
        pointer-events: auto;
      }
      .back-to-top-btn:hover {
        background: rgba(17, 24, 39, 0.5); /* Plus opaque au survol */
        transform: scale(1.1);
        color: white;
      }
      html[data-theme="light"] .back-to-top-btn {
          background: rgba(255, 255, 255, 0.3);
          color: #1a1a2e;
          border: 1px solid rgba(0,0,0,0.08);
          box-shadow: 0 4px 20px rgba(0, 0, 0, 0.1);
      }
      html[data-theme="light"] .back-to-top-btn:hover {
          background: rgba(255, 255, 255, 0.5);
          color: #0d6efd;
      }

      /* Animations */
      @keyframes fadeInUp {
        from {
          opacity: 0;
          transform: translateY(30px);
        }
        to {
          opacity: 1;
          transform: translateY(0);
        }
      }

      .hero-section .badge,
      .hero-section h1,
      .hero-section .lead,
      .hero-section .d-flex {
        animation: fadeInUp 0.8s ease-out forwards;
        opacity: 0; /* Démarrer caché */
      }

      /* Délais échelonnés pour les éléments du hero */
      .hero-section h1 { animation-delay: 0.2s; }
      .hero-section .lead { animation-delay: 0.4s; }
      .hero-section .d-flex { animation-delay: 0.6s; }

      /* Pour les animations au défilement */
      .animated-section-on-scroll,
      .feature-item,
      .cta-section {
        opacity: 0;
        transition: opacity 0.8s ease-out, transform 0.8s ease-out;
        transform: translateY(30px);
      }

      .animated-section-on-scroll.is-visible,
      .feature-item.is-visible,
      .cta-section.is-visible {
        opacity: 1;
        transform: translateY(0);
      }

      /* Délais échelonnés pour les cartes de statistiques */
      .stats-section .row > div:nth-child(2) .animated-section-on-scroll { transition-delay: 0.1s; }
      .stats-section .row > div:nth-child(3) .animated-section-on-scroll { transition-delay: 0.2s; }
      .stats-section .row > div:nth-child(4) .animated-section-on-scroll { transition-delay: 0.3s; }

      /* Styles pour l'avatar dans la barre de navigation */
      .navbar-avatar {
        width: 36px;
        height: 36px;
        border-radius: 50%;
        object-fit: cover;
      }

      .navbar-avatar-placeholder {
        width: 36px;
        height: 36px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 600;
        background-color: var(--bs-primary);
        color: white;
        font-size: 1rem;
      }
    </style>
  </head>
  <body>
    <header class="navbar navbar-expand-lg rounded-4 bg-body-tertiary px-4 py-2">
      <div class="container-fluid px-0">
        <a href="/" class="navbar-brand d-flex align-items-center gap-2 fw-bold text-decoration-none">
            <span class="d-inline-flex align-items-center justify-content-center rounded-3 bg-primary text-white p-2">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="28" height="28">
                <defs>
                  <filter id="glow-home" x="-20%" y="-20%" width="140%" height="140%">
                    <feGaussianBlur stdDeviation="1.2" result="blur" />
                    <feComposite in="SourceGraphic" in2="blur" operator="over" />
                  </filter>
                </defs>
                <g filter="url(#glow-home)" fill="none" stroke="#FFFFFF" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                  <polygon points="12,3 22,8 12,13 2,8" />
                  <path d="M6,10.2 v3.8 c0,2.2 2.7,4 6,4 s6-1.8 6-4 v-3.8" />
                  <path d="M18,11 v3.5" />
                  <circle cx="18" cy="15.5" r="1" fill="#FFFFFF" />
                </g>
              </svg>
            </span>
            <span>EducOS-pro</span>
        </a>
          
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNavbar">
          <span class="navbar-toggler-icon">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <line x1="3" y1="6" x2="21" y2="6" />
              <line x1="3" y1="12" x2="21" y2="12" />
              <line x1="3" y1="18" x2="21" y2="18" />
            </svg>
          </span>
        </button>

        <div class="collapse navbar-collapse" id="mainNavbar">
          <ul class="navbar-nav ms-auto align-items-center">
            <li class="nav-item">
              <button id="themeToggle" class="nav-icon-btn" aria-label="Toggle theme">
                <svg class="sun-icon" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <circle cx="12" cy="12" r="5" /><line x1="12" y1="1" x2="12" y2="3" /><line x1="12" y1="21" x2="12" y2="23" /><line x1="4.22" y1="4.22" x2="5.64" y2="5.64" /><line x1="18.36" y1="18.36" x2="19.78" y2="19.78" /><line x1="1" y1="12" x2="3" y2="12" /><line x1="21" y1="12" x2="23" y2="12" /><line x1="4.22" y1="19.78" x2="5.64" y2="18.36" /><line x1="18.36" y1="5.64" x2="19.78" y2="4.22" />
                </svg>
                <svg class="moon-icon" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z" />
                </svg>
              </button>
            </li>
            <% if (user) { %>
              <!-- Menu déroulant de l'utilisateur -->
              <li class="nav-item dropdown">
                <a class="nav-link dropdown-toggle d-flex align-items-center gap-2" href="#" id="navbarUserDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                  <% if (user.avatar_url) { %>
                    <img src="<%= user.avatar_url %>" alt="Avatar" class="navbar-avatar">
                  <% } else { %>
                    <div class="navbar-avatar-placeholder">
                      <%= user.name.charAt(0).toUpperCase() %>
                    </div>
                  <% } %>
                  <span class="d-none d-lg-inline text-white-75"><%= user.name %></span>
                </a>
                <ul class="dropdown-menu dropdown-menu-end" aria-labelledby="navbarUserDropdown">
                  <li>
                    <a class="dropdown-item d-flex align-items-center" href="/profile">
                      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="me-2"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path><circle cx="12" cy="7" r="4"></circle></svg>
                      Mon Profil
                    </a>
                  </li>
                  <li><hr class="dropdown-divider"></li>
                  <li>
                    <a class="dropdown-item text-danger d-flex align-items-center" href="/logout">
                      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="me-2"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"></path><polyline points="16 17 21 12 16 7"></polyline><line x1="21" y1="12" x2="9" y2="12"></line></svg>
                      Déconnexion
                    </a>
                  </li>
                </ul>
              </li>
            <% } %>
          </ul>
        </div>
      </div>
    </header>

    <main>
      <!-- Hero Section -->
      <section class="hero-section">
        <!-- Carrousel en arrière-plan -->
        <div id="heroCarousel" class="carousel slide hero-carousel" data-bs-ride="carousel" data-bs-interval="15000">
          <div class="carousel-inner">
            <div class="carousel-item active">
              <img src="/img/bg.png" class="d-block w-100" alt="Scène d'école 1">
            </div>
            <div class="carousel-item">
              <img src="/img/bg1.png" class="d-block w-100" alt="Scène d'école 2">
            </div>
            <div class="carousel-item">
              <img src="/img/bg2.png" class="d-block w-100" alt="Scène d'école 3">
            </div>
          </div>
        </div>

        <div class="container">
          <span class="badge bg-success mb-3 d-inline-flex align-items-center gap-2 px-3 py-2">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M12 2L20 7V17L12 22L4 17V7L12 2Z" stroke-linejoin="round"/>
            </svg>
            EducOS-pro  v 1.0.0
          </span>
          <h1 class="display-3">La plateforme scolaire unifiée que vous attendiez.</h1>
          <p class="lead">Gérez la vie scolaire, de la communication aux notes, en un seul endroit. Simple, puissant et accessible pour tous.</p>
          <div class="d-flex flex-wrap justify-content-center gap-3">
            <a href="/register" class="btn btn-success btn-lg">Commencer l'aventure</a>
            <% if (user) { %>
              <% const redirectPath = user.role === 'administrateur' ? '/admin' : '/dashboard'; %>
              <a href="<%= redirectPath %>" class="btn btn-outline-light btn-lg">Accéder à mon espace</a>
            <% } else { %>
              <a href="/login" class="btn btn-outline-light btn-lg">Accéder à mon espace</a>
            <% } %>
          </div>

          <div class="scroll-down-container">
            <a href="#about-section" class="scroll-down-link" aria-label="Faire défiler vers le bas">
