<%- include('partials/head') %>
<%- include('partials/navbar') %>

<div class="container page-shell py-4">
    <div class="themed-container">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h1 class="h3 mb-0"><%= title %></h1>
        </div>

        <%- include('partials/messages') %>

        <%# --- Section des Raccourcis (Widgets) --- %>
        <% if (widgets && widgets.length > 0) { %>
            <h2 class="mb-4">Raccourcis de gestion</h2>
            <div class="row">
                <% widgets.forEach(widget => { %>
                <div class="col-xl-3 col-md-6 mb-4">
                    <a href="<%= widget.link %>" class="text-decoration-none">
                    <div class="card dashboard-stat h-100">
                        <div class="card-body text-center">
                        <div class="stat-icon mb-3">
                            <i data-feather="<%= widget.icon %>" width="36" height="36"></i>
                        </div>
                        <h5 class="card-title mb-2"><%= widget.title %></h5>
                        <p class="card-text text-muted small"><%= widget.description %></p>
                        </div>
                    </div>
                    </a>
                </div>
                <% }); %>
            </div>
        <% } %>

        <%# --- Section des Statistiques avec Graphiques --- %>
        <% if (stats) { %>
            <h2 class="mb-4 mt-5">Statistiques</h2>
            <div class="row">
                <% if (currentUser.role === 'ADMINISTRATOR') { %>
                    <div class="col-lg-8 mb-4">
                        <div class="card h-100">
                            <div class="card-header">Répartition des utilisateurs</div>
                            <div class="card-body d-flex justify-content-center align-items-center p-4">
                                <canvas id="userDistributionChart" style="max-height: 300px;"></canvas>
                            </div>
                        </div>
                    </div>
                    <div class="col-lg-4 mb-4">
                        <div class="card h-100 text-center bg-warning bg-opacity-10 border-warning">
                            <div class="card-body d-flex flex-column justify-content-center">
                                <h5 class="card-title">Comptes en attente</h5>
                                <p class="display-4 fw-bold my-3"><%= stats.pendingCount %></p>
                                <p class="text-muted">Utilisateurs attendant une approbation.</p>
                                <a href="/admin" class="btn btn-warning">Gérer les approbations</a>
                            </div>
                        </div>
                    </div>
                <% } %>
                <% if (currentUser.role === 'SUPER_ADMIN') { %>
                    <div class="col-lg-8 mb-4">
                        <div class="card h-100">
                            <div class="card-header">Statistiques globales</div>
                            <div class="card-body p-4">
                                <canvas id="globalStatsChart"></canvas>
                            </div>
                        </div>
                    </div>
                    <div class="col-lg-4 mb-4">
                        <div class="card h-100 text-center bg-warning bg-opacity-10 border-warning">
                            <div class="card-body d-flex flex-column justify-content-center">
                                <h5 class="card-title">Comptes en attente</h5>
                                <p class="display-4 fw-bold my-3"><%= stats.pendingCount %></p>
                                <p class="text-muted">Nouveaux utilisateurs sur la plateforme.</p>
                                <a href="/admin" class="btn btn-warning">Gérer les approbations</a>
                            </div>
                        </div>
                    </div>
                <% } %>
            </div>
        <% } %>
    </div>
</div>

<!-- Données pour le script, injectées de manière sécurisée -->
<script id="dashboard-data" type="application/json">
    <%- JSON.stringify({ stats: stats || {}, userRole: currentUser.role }) %>
</script>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script>
    document.addEventListener('DOMContentLoaded', function() {
        if (typeof feather !== 'undefined') {
            feather.replace();
        }

        const dataElement = document.getElementById('dashboard-data');
        const { stats, userRole } = JSON.parse(dataElement.textContent);

        const isDarkMode = document.documentElement.getAttribute('data-theme') === 'dark';
        const gridColor = isDarkMode ? 'rgba(255, 255, 255, 0.1)' : 'rgba(0, 0, 0, 0.1)';
        const textColor = isDarkMode ? '#e0e0e0' : '#1a1a2e';

        if (userRole === 'ADMINISTRATOR') {
            const ctx = document.getElementById('userDistributionChart');
            if (ctx) {
                if (stats.studentCount > 0 || stats.professorCount > 0 || stats.parentCount > 0) {
                    new Chart(ctx, {
                        type: 'doughnut',
                        data: {
                            labels: ['Élèves', 'Professeurs', 'Parents'],
                            datasets: [{
                                label: 'Nombre d\'utilisateurs',
                                data: [stats.studentCount, stats.professorCount, stats.parentCount],
                                backgroundColor: ['rgba(54, 162, 235, 0.7)', 'rgba(255, 206, 86, 0.7)', 'rgba(75, 192, 192, 0.7)'],
                                borderColor: isDarkMode ? '#16213e' : '#fff',
                                borderWidth: 2
                            }]
                        },
                        options: {
                            responsive: true,
                            maintainAspectRatio: false,
                            plugins: { legend: { position: 'top', labels: { color: textColor } } }
                        }
                    });
                } else {
                    ctx.parentElement.innerHTML = '<div class="text-center text-muted p-5">Aucune donnée à afficher pour le graphique.</div>';
                }
            }
        }

        if (userRole === 'SUPER_ADMIN') {
            const ctx = document.getElementById('globalStatsChart');
            if (ctx) {
                if (stats.totalUserCount > 0 || stats.adminCount > 0 || stats.establishmentCount > 0) {
                    const maxStatValue = Math.max(stats.totalUserCount, stats.adminCount, stats.establishmentCount, 1);
                    const yStepSize = Math.max(1, Math.ceil(maxStatValue / 5));

                    new Chart(ctx, {
                        type: 'bar',
                        data: {
                            labels: ['Utilisateurs (Total)', 'Admins Scolaires', 'Établissements'],
                            datasets: [{
                                label: 'Statistiques Globales',
                                data: [stats.totalUserCount, stats.adminCount, stats.establishmentCount],
                                backgroundColor: ['rgba(153, 102, 255, 0.6)', 'rgba(255, 159, 64, 0.6)', 'rgba(255, 99, 132, 0.6)'],
                                borderColor: ['rgba(153, 102, 255, 1)', 'rgba(255, 159, 64, 1)', 'rgba(255, 99, 132, 1)'],
                                borderWidth: 1
                            }]
                        },
                        options: {
                            responsive: true,
                            scales: {
                                y: { beginAtZero: true, ticks: { color: textColor, stepSize: yStepSize }, grid: { color: gridColor } },
                                x: { ticks: { color: textColor }, grid: { color: gridColor } }
                            },
                            plugins: { legend: { display: false } }
                        }
                    });
                } else {
                    ctx.parentElement.innerHTML = '<div class="text-center text-muted p-5">Aucune donnée statistique globale à afficher.</div>';
                }
            }
        }
    });
</script>

<%- include('partials/footer') %>