<%- include('partials/head') %>
<%- include('partials/navbar') %>

<div class="container page-shell py-4">
    <div class="themed-container">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h1 class="h3 mb-0"><%= title %></h1>
        </div>

        <%- include('partials/messages') %>

        <%# --- Section des Raccourcis (Widgets) --- %>
        <% if (widgets && widgets.length > 0) { %>
            <h2 class="mb-4">Raccourcis de gestion</h2>
            <div class="row">
                <% widgets.forEach(widget => { %>
                <div class="col-xl-3 col-md-6 mb-4">
                    <a href="<%= widget.link %>" class="text-decoration-none">
                    <div class="card dashboard-stat h-100">
                        <div class="card-body text-center">
                        <div class="stat-icon mb-3">
                            <i data-feather="<%= widget.icon %>" width="36" height="36"></i>
                        </div>
                        <h5 class="card-title mb-2"><%= widget.title %></h5>
                        <p class="card-text text-muted small"><%= widget.description %></p>
                        </div>
                    </div>
                    </a>
                </div>
                <% }); %>
            </div>
        <% } %>

        <%# --- Section des Statistiques avec Graphiques --- %>
        <% if (stats) { %>
            <h2 class="mb-4 mt-5">Statistiques</h2>
            <div class="row">
                <% if (currentUser.role === 'ADMINISTRATOR') { %>
                    <div class="col-md-6 col-lg-3 mb-4">
                        <div class="card h-100"><div class="card-body text-center d-flex flex-column justify-content-center"><h5 class="card-title text-muted">Élèves</h5><p class="display-4 fw-bold my-2" id="adminStudentCount"><%= stats.studentCount %></p></div></div>
                    </div>
                    <div class="col-md-6 col-lg-3 mb-4">
                        <div class="card h-100"><div class="card-body text-center d-flex flex-column justify-content-center"><h5 class="card-title text-muted">Professeurs</h5><p class="display-4 fw-bold my-2" id="adminProfessorCount"><%= stats.professorCount %></p></div></div>
                    </div>
                    <div class="col-md-6 col-lg-3 mb-4">
                        <div class="card h-100"><div class="card-body text-center d-flex flex-column justify-content-center"><h5 class="card-title text-muted">Parents</h5><p class="display-4 fw-bold my-2" id="adminParentCount"><%= stats.parentCount %></p></div></div>
                    </div>
                    <div class="col-md-6 col-lg-3 mb-4">
                        <div class="card h-100 text-center bg-warning bg-opacity-10 border-warning">
                            <div class="card-body d-flex flex-column justify-content-center">
                                <h5 class="card-title">Comptes en attente</h5>
                                <p class="display-4 fw-bold my-3" id="adminPendingCount"><%= stats.pendingCount %></p>
                                <a href="/admin" class="btn btn-sm btn-warning">Gérer</a>
                            </div>
                        </div>
                    </div>
                <% } %>
                <% if (currentUser.role === 'SUPER_ADMIN') { %>
                    <div class="col-md-6 col-lg-3 mb-4">
                        <div class="card h-100"><div class="card-body text-center d-flex flex-column justify-content-center"><h5 class="card-title text-muted">Utilisateurs (Total)</h5><p class="display-4 fw-bold my-2" id="superAdminTotalUsers"><%= stats.totalUserCount %></p></div></div>
                    </div>
                    <div class="col-md-6 col-lg-3 mb-4">
                        <div class="card h-100"><div class="card-body text-center d-flex flex-column justify-content-center"><h5 class="card-title text-muted">Admins Scolaires</h5><p class="display-4 fw-bold my-2" id="superAdminAdminCount"><%= stats.adminCount %></p></div></div>
                    </div>
                    <div class="col-md-6 col-lg-3 mb-4">
                        <div class="card h-100"><div class="card-body text-center d-flex flex-column justify-content-center"><h5 class="card-title text-muted">Établissements</h5><p class="display-4 fw-bold my-2" id="superAdminEstablishmentCount"><%= stats.establishmentCount %></p></div></div>
                    </div>
                    <div class="col-md-6 col-lg-3 mb-4">
                        <div class="card h-100 text-center bg-warning bg-opacity-10 border-warning">
                            <div class="card-body d-flex flex-column justify-content-center">
                                <h5 class="card-title">Comptes en attente</h5>
                                <p class="display-4 fw-bold my-3" id="superAdminPendingCount"><%= stats.pendingCount %></p>
                                <a href="/admin" class="btn btn-sm btn-warning">Gérer</a>
                            </div>
                        </div>
                    </div>

                    <% if (stats.establishmentsWithCounts && stats.establishmentsWithCounts.length > 0) { %>
                        <div class="col-12">
                            <h3 class="mb-4 mt-5">Utilisateurs par Établissement</h3>
                            <div class="table-responsive">
                                <table class="table table-hover">
                                    <thead>
                                        <tr>
                                            <th>Établissement</th>
                                            <th class="text-end">Utilisateurs Approuvés</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <% stats.establishmentsWithCounts.forEach(est => { %>
                                            <tr>
                                                <td><%= est.name %></td>
                                                <td class="text-end fw-bold" id="establishment-count-<%= est.id %>"><%= est.userCount %></td>
                                            </tr>
                                        <% }); %>
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    <% } %>
                <% } %>
            </div>
        <% } %>
    </div>
</div>

<!-- Données pour le script, injectées de manière sécurisée pour éviter les erreurs de linter -->
<script id="admin-dashboard-data" type="application/json">
    <%- JSON.stringify({
        role: currentUser.role,
        establishment_id: currentUser.establishment_id
    }) %>
</script>

<script src="/socket.io/socket.io.js"></script>
<script>
    document.addEventListener('DOMContentLoaded', function() {
        if (typeof feather !== 'undefined') {
            feather.replace();
        }

        const dataElement = document.getElementById('admin-dashboard-data');
        const currentUserData = JSON.parse(dataElement.textContent);

        // Connexion au namespace authentifié par défaut
        const socket = io();

        socket.on('adminStatsUpdate', function(data) {
            if (currentUserData.role === 'SUPER_ADMIN' && data.superAdminStats) {
                const stats = data.superAdminStats;
                document.getElementById('superAdminTotalUsers').textContent = stats.totalUserCount;
                document.getElementById('superAdminAdminCount').textContent = stats.adminCount;
                document.getElementById('superAdminEstablishmentCount').textContent = stats.establishmentCount;
                document.getElementById('superAdminPendingCount').textContent = stats.pendingCount;

                if (stats.establishmentsWithCounts) {
                    stats.establishmentsWithCounts.forEach(est => {
                        const el = document.getElementById(`establishment-count-${est.id}`);
                        if (el) el.textContent = est.userCount;
                    });
                }
            }

            if (currentUserData.role === 'ADMINISTRATOR' && data.adminStats && data.adminStats.establishmentId === currentUserData.establishment_id) {
                const stats = data.adminStats;
                document.getElementById('adminStudentCount').textContent = stats.studentCount;
                document.getElementById('adminProfessorCount').textContent = stats.professorCount;
                document.getElementById('adminParentCount').textContent = stats.parentCount;
                document.getElementById('adminPendingCount').textContent = stats.pendingCount;
            }
        });
    });
</script>

<%- include('partials/page-end-scripts') %>
<%- include('partials/footer') %>