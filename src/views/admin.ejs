<%- include('partials/head') %>
<%- include('partials/navbar') %>

<div class="container page-shell py-4">
    <div class="themed-container">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h1 class="h3 mb-0"><%= title %></h1>
        </div>

        <%- include('partials/messages') %>

        <%# --- Section des Raccourcis (Widgets) --- %>
        <% if (widgets && widgets.length > 0) { %>
            <h2 class="mb-4">Raccourcis de gestion</h2>
            <div class="row">
                <% widgets.forEach(widget => { %>
                <div class="col-xl-3 col-md-6 mb-4">
                    <a href="<%= widget.link %>" class="text-decoration-none">
                    <div class="card dashboard-stat h-100">
                        <div class="card-body text-center">
                        <div class="stat-icon mb-3">
                            <i data-feather="<%= widget.icon %>" width="36" height="36"></i>
                        </div>
                        <h5 class="card-title mb-2"><%= widget.title %></h5>
                        <p class="card-text text-muted small"><%= widget.description %></p>
                        </div>
                    </div>
                    </a>
                </div>
                <% }); %>
            </div>
        <% } %>

        <%# --- Section des Statistiques avec Graphiques --- %>
        <% if (stats) { %>
            <h2 class="mb-4 mt-5">Statistiques</h2>
            <div class="row">
                <% if (currentUser.role === 'ADMINISTRATOR') { %>
                    <div class="col-lg-8 mb-4">
                        <div class="card h-100">
                            <div class="card-header">Répartition des utilisateurs</div>
                            <div class="card-body d-flex justify-content-center align-items-center p-4">
                                <canvas id="userDistributionChart" style="max-height: 300px;"></canvas>
                            </div>
                        </div>
                    </div>
                    <div class="col-lg-4 mb-4">
                        <div class="card h-100 text-center bg-warning bg-opacity-10 border-warning">
                            <div class="card-body d-flex flex-column justify-content-center">
                                <h5 class="card-title">Comptes en attente</h5>
                                <p class="display-4 fw-bold my-3"><%= stats.pendingCount %></p>
                                <p class="text-muted">Utilisateurs attendant une approbation.</p>
                                <a href="/admin" class="btn btn-warning">Gérer les approbations</a>
                            </div>
                        </div>
                    </div>
                <% } %>
                <% if (currentUser.role === 'SUPER_ADMIN') { %>
                    <div class="col-lg-8 mb-4">
                        <div class="card h-100">
                            <div class="card-header">Statistiques globales</div>
                            <div class="card-body p-4">
                                <canvas id="globalStatsChart"></canvas>
                            </div>
                        </div>
                    </div>
                    <div class="col-lg-4 mb-4">
                        <div class="card h-100 text-center bg-warning bg-opacity-10 border-warning">
                            <div class="card-body d-flex flex-column justify-content-center">
                                <h5 class="card-title">Comptes en attente</h5>
                                <p class="display-4 fw-bold my-3"><%= stats.pendingCount %></p>
                                <p class="text-muted">Nouveaux utilisateurs sur la plateforme.</p>
                                <a href="/admin" class="btn btn-warning">Gérer les approbations</a>
                            </div>
                        </div>
                    </div>
                <% } %>
            </div>
        <% } %>

        <h2 class="mb-4 mt-5">
            <% if (currentUser.role === 'SUPER_ADMIN') { %>
                Gestion des Administrateurs
            <% } else { %>
                Gestion des Utilisateurs
            <% } %>
        </h2>
        <div class="table-responsive">
            <table class="table table-hover align-middle">
                <thead>
                    <tr>
                        <th>Utilisateur</th>
                        <% if (currentUser.role === 'SUPER_ADMIN') { %>
                            <th>Établissement</th>
                            <th>Utilisateurs Approuvés</th>
                        <% } else { %>
                            <th>Rôle</th>
                            <th>Statut</th>
                        <% } %>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    <% if (typeof users !== 'undefined' && users.length > 0) { %>
                        <% users.forEach(user => { %>
                            <tr>
                                <!-- Colonne Utilisateur -->
                                <td>
                                    <div class="d-flex align-items-center">
                                        <img src="<%= user.avatar_url || '/img/user.png' %>" alt="Avatar" class="list-avatar me-3">
                                        <div>
                                            <div class="fw-bold"><%= user.name %></div>
                                            <div class="text-muted small"><%= user.email %></div>
                                        </div>
                                    </div>
                                </td>

                                <% if (currentUser.role === 'SUPER_ADMIN') { %>
                                    <!-- Vue Super Admin -->
                                    <td>
                                        <span class="text-muted"><%= user.establishment_name || 'Non affilié' %></span>
                                    </td>
                                    <td>
                                        <span class="badge bg-primary rounded-pill fs-6" id="user-count-<%= user.establishment_id %>">
                                            <%= user.userCount %>
                                        </span>
                                    </td>
                                    <td class="text-end">
                                        <div class="d-flex gap-2 justify-content-end">
                                            <button type="button" onclick="window.location.href='mailto:<%= user.email %>'" class="btn btn-sm btn-outline-secondary">Contacter</button>
                                            <form action="/admin/users/<%= user.id %>/delete" method="POST" class="d-inline mb-0">
                                                <button type="submit" class="btn btn-sm btn-outline-danger" onclick="return confirm('Êtes-vous sûr de vouloir supprimer cet administrateur ? Cette action est irréversible.');">Supprimer</button>
                                            </form>
                                        </div>
                                    </td>
                                <% } else { %>
                                    <!-- Vue Admin d'école -->
                                    <td>
                                        <span class="badge bg-secondary text-capitalize"><%= user.role %></span>
                                    </td>
                                    <td>
                                        <% if (user.approved) { %>
                                            <span class="badge bg-success">Approuvé</span>
                                        <% } else { %>
                                            <span class="badge bg-warning text-dark">En attente</span>
                                        <% } %>
                                    </td>
                                    <td class="text-end">
                                        <div class="d-flex gap-2 justify-content-end">
                                            <% if (!user.approved) { %>
                                                <form action="/admin/users/<%= user.id %>/approve" method="POST" class="d-inline">
                                                    <button type="submit" class="btn btn-sm btn-success">Approuver</button>
                                                </form>
                                            <% } %>
                                            <form action="/admin/users/<%= user.id %>/delete" method="POST" class="d-inline">
                                                <button type="submit" class="btn btn-sm btn-outline-danger" onclick="return confirm('Êtes-vous sûr de vouloir supprimer cet utilisateur ?');">Supprimer</button>
                                            </form>
                                        </div>
                                    </td>
                                <% } %>
                            </tr>
                        <% }) %>
                    <% } else { %>
                        <tr>
                            <td colspan="5" class="text-center text-muted py-4">
                                <% if (currentUser.role === 'SUPER_ADMIN') { %>
                                    Aucun administrateur d'établissement trouvé.
                                <% } else { %>
                                    Aucun utilisateur trouvé dans votre établissement.
                                <% } %>
                            </td>
                        </tr>
                    <% } %>
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- Données pour le script, injectées de manière sécurisée pour éviter les erreurs de linter -->
<script id="admin-data" type="application/json">
    <%- JSON.stringify({ stats: stats || {}, userRole: currentUser.role }) %>
</script>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script>
    document.addEventListener('DOMContentLoaded', function() {
        // S'assure que les icônes Feather sont bien rendues après l'ajout dynamique
        if (typeof feather !== 'undefined') {
            feather.replace();
        }

        // Récupère et parse les données depuis la balise script dédiée
        const dataElement = document.getElementById('admin-data');
        const { stats, userRole } = JSON.parse(dataElement.textContent);

        const isDarkMode = document.documentElement.getAttribute('data-theme') === 'dark';
        const gridColor = isDarkMode ? 'rgba(255, 255, 255, 0.1)' : 'rgba(0, 0, 0, 0.1)';
        const textColor = isDarkMode ? '#e0e0e0' : '#1a1a2e';

        if (userRole === 'ADMINISTRATOR') {
            const ctx = document.getElementById('userDistributionChart');
            if (ctx) {
                if (stats.studentCount > 0 || stats.professorCount > 0 || stats.parentCount > 0) {
                    new Chart(ctx, {
                        type: 'doughnut',
                        data: {
                            labels: ['Élèves', 'Professeurs', 'Parents'],
                            datasets: [{
                                label: 'Nombre d\'utilisateurs',
                                data: [stats.studentCount, stats.professorCount, stats.parentCount],
                                backgroundColor: [
                                    'rgba(54, 162, 235, 0.7)',
                                    'rgba(255, 206, 86, 0.7)',
                                    'rgba(75, 192, 192, 0.7)'
                                ],
                                borderColor: isDarkMode ? '#16213e' : '#fff',
                                borderWidth: 2
                            }]
                        },
                        options: {
                            responsive: true,
                            maintainAspectRatio: false,
                            plugins: {
                                legend: {
                                    position: 'top',
                                    labels: {
                                        color: textColor
                                    }
                                }
                            }
                        }
                    });
                } else {
                    ctx.parentElement.innerHTML = '<div class="text-center text-muted p-5">Aucune donnée à afficher pour le graphique de répartition.</div>';
                }
            }
        }

        if (userRole === 'SUPER_ADMIN') {
            const ctx = document.getElementById('globalStatsChart');
            if (ctx) {
                const maxStatValue = Math.max(stats.totalUserCount, stats.professorCount, stats.establishmentCount, 1);
                const yStepSize = Math.max(1, Math.ceil(maxStatValue / 5)); // Vise environ 5 étapes sur l'axe Y

                new Chart(ctx, {
                    type: 'bar',
                    data: {
                        labels: ['Utilisateurs Actifs', 'Professeurs', 'Établissements'],
                        datasets: [{
                            label: 'Statistiques Globales',
                            data: [stats.totalUserCount, stats.professorCount, stats.establishmentCount],
                            backgroundColor: ['rgba(153, 102, 255, 0.6)', 'rgba(255, 159, 64, 0.6)', 'rgba(255, 99, 132, 0.6)'],
                            borderColor: ['rgba(153, 102, 255, 1)', 'rgba(255, 159, 64, 1)', 'rgba(255, 99, 132, 1)'],
                            borderWidth: 1
                        }]
                    },
                    options: {
                        responsive: true,
                        scales: {
                            y: { beginAtZero: true, ticks: { color: textColor, stepSize: yStepSize }, grid: { color: gridColor } },
                            x: { ticks: { color: textColor }, grid: { color: gridColor } }
                        },
                        plugins: { legend: { display: false } }
                    }
                });
            }
        }
    });
</script>

<% if (currentUser.role === 'SUPER_ADMIN') { %>
    <script src="/socket.io/socket.io.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            // On se connecte au namespace global car l'event est émis globalement
            const socket = io();

            socket.on('establishmentUserCountUpdate', function(data) {
                const { establishmentId, count } = data;
                const countElement = document.getElementById(`user-count-${establishmentId}`);
                if (countElement) {
                    const oldValue = parseInt(countElement.textContent, 10);
                    countElement.textContent = count;

                    // Animation pour mettre en évidence le changement
                    let animationClass = 'flash-increase';
                    if (count < oldValue) {
                        animationClass = 'flash-decrease';
                    }
                    
                    countElement.classList.remove('flash-increase', 'flash-decrease');
                    // Force le reflow pour que l'animation puisse rejouer
                    void countElement.offsetWidth; 
                    countElement.classList.add(animationClass);
                }
            });
        });
    </script>
    <style>
        @keyframes flash-increase {
            0% { background-color: var(--bs-primary); transform: scale(1); }
            50% { background-color: var(--bs-success); transform: scale(1.2); }
            100% { background-color: var(--bs-primary); transform: scale(1); }
        }
        @keyframes flash-decrease {
            0% { background-color: var(--bs-primary); transform: scale(1); }
            50% { background-color: var(--bs-danger); transform: scale(1.2); }
            100% { background-color: var(--bs-primary); transform: scale(1); }
        }
        .flash-increase {
            animation: flash-increase 0.8s ease-out;
        }
        .flash-decrease {
            animation: flash-decrease 0.8s ease-out;
        }
    </style>
<% } %>

<%- include('partials/footer') %>