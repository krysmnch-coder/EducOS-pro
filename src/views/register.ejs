</div>

<script>
  function togglePasswordVisibility(inputId, toggler) {
    const passwordInput = document.getElementById(inputId);
    const eyeIcon = toggler.querySelector('.eye-icon');
    const eyeSlashIcon = toggler.querySelector('.eye-slash-icon');

    if (passwordInput) {
      const type = passwordInput.getAttribute('type') === 'password' ? 'text' : 'password';
      passwordInput.setAttribute('type', type);
      eyeIcon.classList.toggle('d-none');
      eyeSlashIcon.classList.toggle('d-none');
    }
  }
</script>

<script>
  const roleSelect = document.getElementById('role');
  const teacherFields = document.getElementById('teacher-fields');
  const studentFields = document.getElementById('student-fields');
  const parentFields = document.getElementById('parent-fields');
  const addChildBtn = document.getElementById('add-child-btn');
  const childrenList = document.getElementById('children-list');
  let childIndex = 0;

  function updateHiddenClassInput(index) {
    const entry = document.querySelector(`.child-entry[data-index="${index}"]`);
    if (!entry) return;

    const levelSelect = entry.querySelector('.class-level-select');
    const letterSelect = entry.querySelector('.class-suffix-letter-select');
    const numberSelect = entry.querySelector('.class-suffix-number-select');
    const hiddenInput = entry.querySelector('.student-class-hidden-input');

    const level = levelSelect.value;
    const letter = letterSelect.value;
    const number = numberSelect.value;

    // Priorité à la lettre si les deux suffixes sont choisis
    let suffix = '';
    if (letter) {
      suffix = letter;
    } else if (number) {
      suffix = number;
    }

    hiddenInput.value = `${level} ${suffix}`.trim();
  }
  function addChildEntry() {
    const index = childIndex++;
    const entry = document.createElement('div');
    entry.className = 'child-entry border rounded-3 p-3 mb-3';
    entry.dataset.index = index;
    entry.innerHTML = `
      <div class="d-flex justify-content-between align-items-center mb-3">
        <h6 class="mb-0">Enfant ${childrenList.children.length + 1}</h6>
        <button type="button" class="btn btn-sm btn-outline-danger remove-child-btn">Supprimer</button>
      </div>
      <div class="row g-3">
        <div class="col-md-6">
          <label class="form-label">Prénom</label>
          <input type="text" name="children[${index}][first_name]" class="form-control" placeholder="Prénom de l'enfant" required />
        </div>
        <div class="col-md-6">
          <label class="form-label">Nom</label>
          <input type="text" name="children[${index}][last_name]" class="form-control" placeholder="Nom de l'enfant" required />
        </div>
      </div>
      <div class="row g-3 mt-2">
        <div class="col-md-3">
            <label class="form-label">Matricule</label>
            <input type="text" name="children[${index}][matricule]" class="form-control" placeholder="Matricule" required />
        </div>
        <div class="col-md-5">
          <label class="form-label">Niveau</label>
            <select class="form-select form-select-sm class-level-select" data-index="${index}" required>
              <option value="" disabled selected>-- Choisir --</option>
              <optgroup label="Lycée">
                <option value="Terminale">Terminale</option>
                <option value="Première">Première</option>
                <option value="Seconde">Seconde</option>
              </optgroup>
              <optgroup label="Collège">
                <option value="Troisième">Troisième</option>
                <option value="Quatrième">Quatrième</option>
                <option value="Cinquième">Cinquième</option>
                <option value="Sixième">Sixième</option>
              </optgroup>
              <optgroup label="Primaire">
                <option value="CM2">CM2</option><option value="CM1">CM1</option><option value="CE2">CE2</option><option value="CE1">CE1</option><option value="CP">CP</option>
              </optgroup>
              <optgroup label="Maternelle">
                <option value="Grande Section">Grande Section</option>
                <option value="Moyenne Section">Moyenne Section</option>
                <option value="Petite Section">Petite Section</option>
                <option value="Toute Petite Section">Toute Petite Section</option>
              </optgroup>
            </select>
        </div>
        <div class="col-md-2">
          <label class="form-label">Lettre</label>
            <select class="form-select form-select-sm class-suffix-letter-select" data-index="${index}">
              <option value="" selected>Aucune</option>
              ${'ABCDEFGHIJKLMNOPQRSTUVWXYZ'.split('').map(l => `<option value="${l}">${l}</option>`).join('')}
            </select>
        </div>
        <div class="col-md-2">
          <label class="form-label">N°</label>
            <select class="form-select form-select-sm class-suffix-number-select" data-index="${index}">
              <option value="" selected>Aucun</option>
              ${Array.from({length: 20}, (_, i) => i + 1).map(n => `<option value="${n}">${n}</option>`).join('')}
            </select>
        </div>
      </div>
      <input type="hidden" name="children[${index}][student_class]" class="student-class-hidden-input" />
    `;
    
    const classSelects = entry.querySelectorAll('.class-level-select, .class-suffix-letter-select, .class-suffix-number-select');
    classSelects.forEach(select => select.addEventListener('change', (event) => updateHiddenClassInput(event.target.dataset.index)));

    const removeBtn = entry.querySelector('.remove-child-btn');
    removeBtn.addEventListener('click', () => {
      if (childrenList.children.length > 1) {
        entry.remove();
        updateChildNames();
      }
    });
    childrenList.appendChild(entry);
    updateChildNames();
  }

  function updateChildNames() {
    Array.from(childrenList.children).forEach((entry, idx) => {
      // Mettre à jour l'index principal de l'entrée
      entry.dataset.index = idx;

      const title = entry.querySelector('h6');
      if (title) title.textContent = `Enfant ${idx + 1}`;
      const inputs = entry.querySelectorAll('input');
      inputs.forEach((input) => {
        const nameParts = input.name.match(/children\[(\d+)\]\[([^\]]+)\]/);
        if (nameParts) {
          input.name = `children[${idx}][${nameParts[2]}]`;
        }
      });
      // Mettre à jour l'index des selects de classe
      const selects = entry.querySelectorAll('select');
      selects.forEach(select => {
        select.dataset.index = idx;
      });
    });
  }

  function updateRoleFields() {
    const role = roleSelect.value;
    // Gère la visibilité des sections
    teacherFields.classList.toggle('d-none', role !== 'professeur');
    studentFields.classList.toggle('d-none', role !== 'eleve');
    parentFields.classList.toggle('d-none', role !== 'parent');

    // Désactive les champs des sections masquées pour qu'ils ne soient pas soumis avec le formulaire.
    teacherFields.querySelectorAll('input, select').forEach(el => el.disabled = (role !== 'professeur'));
    studentFields.querySelectorAll('input, select').forEach(el => el.disabled = (role !== 'eleve'));
    parentFields.querySelectorAll('input, select').forEach(el => el.disabled = (role !== 'parent'));

    if (role === 'parent' && childrenList && childrenList.children.length === 0) {
      addChildEntry();
    }
  }

  if (addChildBtn) {
    addChildBtn.addEventListener('click', addChildEntry);
  }
  if (roleSelect) {
    roleSelect.addEventListener('change', updateRoleFields);
    updateRoleFields();
  }
</script>

<script src="/js/theme.js"></script>
<%- include('partials/footer') %>
